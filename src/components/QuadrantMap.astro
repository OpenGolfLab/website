---
interface Props {
  map: any;
  regionLabel: string;
  svgLabel: string;
  xCaption: string;
  yCaption: string;
  legend: { cls: string; label: string }[];
}

const { map, regionLabel, svgLabel, xCaption, yCaption, legend } = Astro.props;
---

<div class="ballmap-wrap" role="region" aria-label={regionLabel}>
  <svg
    viewBox={`0 0 ${map.W} ${map.H}`}
    class="ballmap"
    role="img"
    aria-label={svgLabel}
  >
    {/* midlines */}
    <line class="ballmap-mid" x1={map.xMid} y1={map.PAD.t} x2={map.xMid} y2={map.bottom} />
    <line class="ballmap-mid" x1={map.PAD.l} y1={map.yMid} x2={map.right} y2={map.yMid} />

    {/* quadrant labels */}
    {map.qcaps.map((c: any) => (
      <text class="ballmap-q" text-anchor={c.a} x={c.x} y={c.y}>{c.t}</text>
    ))}

    {/* axis captions: one per axis, arrows point along the scale */}
    <text
      class="ballmap-axis"
      text-anchor="middle"
      x={(map.PAD.l + map.right) / 2}
      y={map.H - 12}
    >{xCaption}</text>
    <text
      class="ballmap-axis"
      text-anchor="middle"
      transform={`translate(14 ${(map.PAD.t + map.bottom) / 2}) rotate(-90)`}
    >{yCaption}</text>

    {/* dots */}
    {map.dots.map((d: any) => (
      <g class="ballmap-pt">
        <title>{d.title}</title>
        <line
          class="ballmap-lead"
          x1={d.x}
          y1={d.y}
          x2={d.leadX}
          y2={d.leadY}
        />
        <circle
          class:list={["ballmap-dot", d.cls]}
          cx={d.x}
          cy={d.y}
          r="6"
        />
        <text
          class="ballmap-lbl"
          x={d.lblX}
          y={d.lblY}
          text-anchor={d.anchor}
        >
          {d.label}
        </text>
      </g>
    ))}
  </svg>

  <div class="ballmap-legend">
    {legend.map((k) => (
      <span><i class={`ballmap-key ${k.cls}`} aria-hidden="true"></i> {k.label}</span>
    ))}
  </div>
</div>

<style>
  /* ---- Quadrant map ---- */
  .ballmap-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.25rem 1.25rem 1rem;
    max-width: 1060px;
  }
  .ballmap {
    width: 100%;
    height: auto;
    display: block;
  }
  .ballmap-mid {
    stroke: var(--border-strong);
    stroke-dasharray: 5 5;
  }
  .ballmap-q {
    fill: var(--text);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    paint-order: stroke;
    stroke: var(--surface);
    stroke-width: 4px;
    stroke-linejoin: round;
  }
  .ballmap-axis {
    fill: var(--text-muted);
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
  }
  .ballmap-lead {
    stroke: var(--text-dim);
    stroke-width: 1;
    opacity: 0.75;
  }
  .ballmap-dot {
    stroke: var(--bg-elevated);
    stroke-width: 2;
  }
  .ballmap-dot.premium {
    fill: var(--green);
  }
  .ballmap-dot.value {
    fill: var(--cyan);
  }
  /* Iron map category colors, one distinct hue per category, running from the
     player's end (green → cyan → violet) to the forgiveness end (amber → grey). */
  .ballmap-dot.cat-blade {
    fill: var(--green-bright);
  }
  .ballmap-dot.cat-pcb {
    fill: var(--cyan);
  }
  .ballmap-dot.cat-pd {
    fill: var(--violet);
  }
  .ballmap-dot.cat-gi {
    fill: var(--amber);
  }
  .ballmap-dot.cat-sgi {
    fill: var(--text-dim);
  }
  .ballmap-lbl {
    fill: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    paint-order: stroke;
    stroke: var(--surface);
    stroke-width: 3.5px;
    stroke-linejoin: round;
  }
  .ballmap-pt:hover .ballmap-lbl {
    fill: var(--green-bright);
    font-weight: 700;
  }
  .ballmap-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    margin-top: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.3;
    color: var(--text-muted);
  }
  .ballmap-key {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin-right: 0.35rem;
  }
  .ballmap-key.premium {
    background: var(--green);
  }
  .ballmap-key.value {
    background: var(--cyan);
  }
  .ballmap-key.cat-blade {
    background: var(--green-bright);
  }
  .ballmap-key.cat-pcb {
    background: var(--cyan);
  }
  .ballmap-key.cat-pd {
    background: var(--violet);
  }
  .ballmap-key.cat-gi {
    background: var(--amber);
  }
  .ballmap-key.cat-sgi {
    background: var(--text-dim);
  }

  @media (max-width: 700px) {
    .ballmap-wrap {
      display: none;
    }
  }
</style>
