---
import { LAB_SECTIONS } from "../consts";

// Normalize the current path (strip trailing slash) for active-link matching.
// "/lab" must match exactly, or it would light up on every child route.
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) =>
  href === "/lab" ? path === "/lab" : path === href || path.startsWith(href + "/");
---

<div class="lab-nav-bar">
  <div class="container">
    <nav class="lab-nav" aria-label="The Lab sections">
      {
        LAB_SECTIONS.map((section) => (
          <a
            href={section.href}
            class:list={["lab-nav-link", { active: isActive(section.href) }]}
            aria-current={isActive(section.href) ? "page" : undefined}
          >
            {section.label}
          </a>
        ))
      }
    </nav>
  </div>
</div>

<style>
  /* Sits directly under the sticky site nav, and sticks below it on scroll. */
  .lab-nav-bar {
    position: sticky;
    top: var(--nav-h);
    z-index: 90;
    background: var(--bg-translucent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .lab-nav {
    display: flex;
    align-items: stretch;
    gap: 0.25rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .lab-nav::-webkit-scrollbar {
    display: none;
  }
  .lab-nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    padding: 0.85rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    border-bottom: 2px solid transparent;
    transition: color 0.15s var(--ease), border-color 0.15s var(--ease);
  }
  .lab-nav-link:hover {
    color: var(--text-muted);
  }
  .lab-nav-link.active {
    color: var(--green);
    border-bottom-color: var(--green);
  }
  .lab-nav-link:first-child {
    padding-left: 0;
  }

  @media (max-width: 700px) {
    .lab-nav-link {
      font-size: 0.72rem;
      padding: 0.75rem 0.7rem;
    }
  }
</style>
