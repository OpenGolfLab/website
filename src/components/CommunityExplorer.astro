---
/**
 * CommunityExplorer, the interactive half of the Community Data page.
 *
 * Client-side by necessity: the filters (club, gear, ball, handicap, age)
 * recombine at view time, so the dots can't be prerendered. Everything renders
 * from /data/community_points.json, the same aggregate file the desktop app's
 * Community tab reads. Each dot is one golfer's MEDIAN for one club. Raw shots
 * never reach the browser because they never leave the private data repo.
 *
 * No framework, no dependencies: one <script> that builds an SVG scatter, a
 * compact per-club table, and the driver leaderboard.
 */
---

<section class="lab-band" id="explorer">
  <div class="lab-band-head">
    <p class="eyebrow">Explore</p>
    <h2>Community dispersion</h2>
    <p class="text-muted" style="max-width:66ch;">
      Every dot is one golfer's typical shot with one club: their median carry
      and median offline, computed from all the shots they've shared. Filter by
      club, gear, ball, handicap, or age. Colors match the Golf Sim Analytics
      app.
    </p>
  </div>

  <div id="x-filters" class="x-filters" hidden>
    <div class="x-clubs" id="x-clubs" role="group" aria-label="Filter by club"></div>
    <div class="x-selects" id="x-selects"></div>
  </div>

  <div id="x-body" class="x-body" hidden>
    <div class="x-plot-wrap">
      <svg id="x-plot" class="x-plot" viewBox="0 0 640 460" role="img"
        aria-label="Scatter plot of community median shots, offline versus carry"></svg>
      <div id="x-tip" class="x-tip" hidden></div>
      <p class="x-plot-caption">
        Offline (yards) across, carry (yards) up. Hover a dot for the golfer
        behind it.
      </p>
    </div>
    <div class="x-side">
      <table class="x-table">
        <thead>
          <tr><th>Club</th><th>Carry</th><th>Golfers</th></tr>
        </thead>
        <tbody id="x-table-body"></tbody>
      </table>
      <p id="x-count" class="x-count tnum"></p>
    </div>
  </div>

  <p id="x-empty" class="x-empty" hidden>
    No golfers match these filters yet. Clear a filter, or be the golfer who
    fills this gap:
    <a href="/download">contribute your sessions</a>.
  </p>
  <p id="x-offline" class="x-empty" hidden>
    Community data hasn't loaded. It appears here as soon as enough golfers
    have contributed.
  </p>
</section>

<section class="lab-band" id="leaderboard-band" hidden>
  <div class="lab-band-head">
    <p class="eyebrow">Leaderboard</p>
    <h2>The Bomber Board</h2>
    <p class="text-muted" style="max-width:66ch;">
      The community's ten biggest hitters, ranked by median driver ball speed.
      Medians, not hero swings: every number is the middle of all that golfer's
      shared driver shots, so one lucky strike can't make this list. Declare
      your driver in the app and it shows up next to your name.
    </p>
  </div>
  <div class="x-lb-wrap">
    {/* Original flying-wing silhouette (drawn here, not a licensed asset),
        ghosted behind the board for the stealth-bomber nod. */}
    <svg class="x-bomber" viewBox="0 0 200 70" aria-hidden="true" focusable="false">
      <path d="M100,2 L198,52 L164,52 L150,40 L136,52 L112,52 L100,64 L88,52 L64,52 L50,40 L36,52 L2,52 Z" />
    </svg>
    <table class="x-table x-lb">
      <thead>
        <tr>
          <th>#</th><th>Golfer</th><th>Ball speed</th><th>Club speed</th>
          <th>Carry</th><th>Shots</th>
        </tr>
      </thead>
      <tbody id="x-lb-body"></tbody>
    </table>
  </div>
</section>

<script>
  // Club colors mirror the desktop app's config.CLUB_COLORS so a 7I is the
  // same green here as in Golf Sim Analytics.
  const CLUB_COLORS: Record<string, string> = {
    Dr: "#844834", "3W": "#8c6238", "5W": "#99713e",
    "2I": "#a68545", "3I": "#b39a52", "4I": "#bcab5c", "5I": "#c1a84f",
    "6I": "#9ea96a", "7I": "#7f9f69", "8I": "#6b9a70", "9I": "#619490",
    Pw: "#5a8ba4", Gw: "#4d759d", Sw: "#43617c", Lw: "#385069",
  };
  const FALLBACK = "#8a8a8a";
  const CLUB_ORDER = Object.keys(CLUB_COLORS);
  const NOT_SPECIFIED = "Not specified";

  const norm = (c: string) => {
    const t = (c || "").trim();
    const hit = CLUB_ORDER.find((k) => k.toLowerCase() === t.toLowerCase());
    return hit || t;
  };
  const colorOf = (c: string) => CLUB_COLORS[norm(c)] || FALLBACK;
  const slotOf = (club: string) => {
    const c = norm(club).toUpperCase();
    if (c === "DR") return "driver";
    if (["PW", "GW", "SW", "LW"].includes(c)) return "wedges";
    if (/^[2-9]I$/.test(c)) return "irons";
    return null;
  };
  const gearLabel = (p: any) =>
    [p.club_brand, p.club_model].filter(Boolean).join(" ") || NOT_SPECIFIED;

  const $ = (id: string) => document.getElementById(id)!;
  const state: Record<string, string> = {
    club: "All", driver: "All", irons: "All", wedges: "All",
    ball: "All", handicap: "All", age: "All",
  };
  let points: any[] = [];

  async function boot() {
    let payload: any;
    try {
      const res = await fetch("/data/community_points.json");
      if (!res.ok) throw new Error(String(res.status));
      payload = await res.json();
    } catch {
      $("x-offline").hidden = false;
      return;
    }
    points = (payload.points || []).filter(
      (p: any) => p.carry != null && p.offline != null,
    );
    if (!points.length) {
      $("x-offline").hidden = false;
      return;
    }
    buildFilters();
    render();
    $("x-filters").hidden = false;
    $("x-body").hidden = false;
    renderLeaderboard(payload.driver_leaderboard || []);
  }

  // ---- filters ------------------------------------------------------------
  function buildFilters() {
    const clubs = [...new Set(points.map((p) => norm(p.club)))].sort(
      (a, b) => (CLUB_ORDER.indexOf(a) + 99 || 999) - (CLUB_ORDER.indexOf(b) + 99 || 999),
    );
    const wrap = $("x-clubs");
    const mkChip = (label: string, value: string, color?: string) => {
      const b = document.createElement("button");
      b.type = "button";
      b.className = "x-chip";
      b.dataset.value = value;
      if (color) {
        const dot = document.createElement("span");
        dot.className = "x-dot";
        dot.style.background = color;
        b.appendChild(dot);
      }
      b.appendChild(document.createTextNode(label));
      b.addEventListener("click", () => {
        state.club = value;
        wrap.querySelectorAll(".x-chip").forEach((c) =>
          c.classList.toggle("active", (c as HTMLElement).dataset.value === value));
        render();
      });
      wrap.appendChild(b);
      return b;
    };
    mkChip("All clubs", "All").classList.add("active");
    clubs.forEach((c) => mkChip(c, c, colorOf(c)));

    // Selects: gear per bag slot, then ball / handicap / age.
    const selects = $("x-selects");
    const opts = (vals: string[], anyLabel: string) => ["All", ...vals].map(
      (v) => ({ value: v, label: v === "All" ? anyLabel : v }));
    const distinct = (fn: (p: any) => string | undefined, subset?: (p: any) => boolean) => {
      const vals = new Set<string>();
      points.filter(subset || (() => true)).forEach((p) => {
        vals.add(fn(p) || NOT_SPECIFIED);
      });
      const arr = [...vals].filter((v) => v !== NOT_SPECIFIED).sort();
      if (vals.has(NOT_SPECIFIED)) arr.push(NOT_SPECIFIED);
      return arr;
    };
    const mkSelect = (key: string, label: string, values: string[]) => {
      if (!values.length) return;
      const lab = document.createElement("label");
      lab.className = "x-select";
      lab.innerHTML = `<span>${label}</span>`;
      const sel = document.createElement("select");
      opts(values, "All").forEach(({ value, label: l }) => {
        const o = document.createElement("option");
        o.value = value;
        o.textContent = l;
        sel.appendChild(o);
      });
      sel.addEventListener("change", () => { state[key] = sel.value; render(); });
      lab.appendChild(sel);
      selects.appendChild(lab);
    };
    mkSelect("driver", "Driver", distinct(gearLabel, (p) => slotOf(p.club) === "driver"));
    mkSelect("irons", "Irons", distinct(gearLabel, (p) => slotOf(p.club) === "irons"));
    mkSelect("wedges", "Wedges", distinct(gearLabel, (p) => slotOf(p.club) === "wedges"));
    mkSelect("ball", "Ball", distinct((p) => p.ball_model));
    mkSelect("handicap", "Handicap", distinct((p) => p.handicap));
    mkSelect("age", "Age", distinct((p) => p.age));
  }

  function filtered() {
    return points.filter((p) => {
      const club = norm(p.club);
      if (state.club !== "All" && club !== state.club) return false;
      const slot = slotOf(club);
      // A gear filter narrows within its own bag slot: picking a driver model
      // filters driver dots and leaves iron dots governed by the iron filter.
      if (slot && state[slot] !== "All" && gearLabel(p) !== state[slot]) return false;
      if (state.ball !== "All" && (p.ball_model || NOT_SPECIFIED) !== state.ball) return false;
      if (state.handicap !== "All" && (p.handicap || NOT_SPECIFIED) !== state.handicap) return false;
      if (state.age !== "All" && (p.age || NOT_SPECIFIED) !== state.age) return false;
      return true;
    });
  }

  // ---- plot ---------------------------------------------------------------
  const NS = "http://www.w3.org/2000/svg";
  const el = (tag: string, attrs: Record<string, string | number>) => {
    const n = document.createElementNS(NS, tag);
    for (const [k, v] of Object.entries(attrs)) n.setAttribute(k, String(v));
    return n;
  };

  function render() {
    const pts = filtered();
    const svg = $("x-plot");
    svg.textContent = "";
    $("x-empty").hidden = pts.length > 0;
    $("x-body").hidden = pts.length === 0;
    if (!pts.length) return;

    const W = 640, H = 460, m = { l: 52, r: 16, t: 14, b: 40 };
    const xs = pts.map((p) => p.offline), ys = pts.map((p) => p.carry);
    const xMax = Math.max(8, ...xs.map(Math.abs)) * 1.15;
    const yMin = Math.min(...ys), yMax = Math.max(...ys);
    const pad = Math.max(10, (yMax - yMin) * 0.12);
    const y0 = Math.max(0, yMin - pad), y1 = yMax + pad;
    const X = (v: number) => m.l + ((v + xMax) / (2 * xMax)) * (W - m.l - m.r);
    const Y = (v: number) => H - m.b - ((v - y0) / (y1 - y0)) * (H - m.t - m.b);

    // gridlines + labels
    const xticks = niceTicks(-xMax, xMax, 7);
    const yticks = niceTicks(y0, y1, 6);
    for (const t of yticks) {
      svg.appendChild(el("line", { x1: m.l, x2: W - m.r, y1: Y(t), y2: Y(t), class: "x-grid" }));
      const lab = el("text", { x: m.l - 8, y: Y(t) + 4, class: "x-tick", "text-anchor": "end" });
      lab.textContent = String(t);
      svg.appendChild(lab);
    }
    for (const t of xticks) {
      const lab = el("text", { x: X(t), y: H - m.b + 18, class: "x-tick", "text-anchor": "middle" });
      lab.textContent = String(t);
      svg.appendChild(lab);
    }
    svg.appendChild(el("line", { x1: X(0), x2: X(0), y1: m.t, y2: H - m.b, class: "x-center" }));
    const xl = el("text", { x: (m.l + W - m.r) / 2, y: H - 6, class: "x-axis-label", "text-anchor": "middle" });
    xl.textContent = "Offline (yd)";
    svg.appendChild(xl);
    const ylab = el("text", {
      x: 14, y: (m.t + H - m.b) / 2, class: "x-axis-label", "text-anchor": "middle",
      transform: `rotate(-90 14 ${(m.t + H - m.b) / 2})`,
    });
    ylab.textContent = "Carry (yd)";
    svg.appendChild(ylab);

    const tip = $("x-tip");
    for (const p of pts) {
      const dot = el("circle", {
        cx: X(p.offline), cy: Y(p.carry), r: 5.5,
        fill: colorOf(p.club), class: "x-point",
      });
      dot.addEventListener("mouseenter", (ev) => showTip(ev as MouseEvent, p));
      dot.addEventListener("mousemove", (ev) => moveTip(ev as MouseEvent));
      dot.addEventListener("mouseleave", () => { tip.hidden = true; });
      svg.appendChild(dot);
    }

    // side table: per-club roll-up of what's plotted
    const byClub = new Map<string, any[]>();
    pts.forEach((p) => {
      const c = norm(p.club);
      byClub.set(c, [...(byClub.get(c) || []), p]);
    });
    const body = $("x-table-body");
    body.textContent = "";
    [...byClub.keys()]
      .sort((a, b) => (CLUB_ORDER.indexOf(a) + 99 || 999) - (CLUB_ORDER.indexOf(b) + 99 || 999))
      .forEach((c) => {
        const rows = byClub.get(c)!;
        const carries = rows.map((r) => r.carry).sort((a, b) => a - b);
        const med = carries[Math.floor(carries.length / 2)];
        const tr = document.createElement("tr");
        tr.innerHTML =
          `<td><span class="x-dot" style="background:${colorOf(c)}"></span>${c}</td>` +
          `<td class="tnum">${Math.round(med)} yd</td>` +
          `<td class="tnum">${rows.length}</td>`;
        body.appendChild(tr);
      });
    $("x-count").textContent =
      `${pts.length} golfer-club medians · ${pts.reduce((s, p) => s + (p.n || 0), 0).toLocaleString()} shots behind them`;
  }

  function niceTicks(lo: number, hi: number, n: number) {
    const span = hi - lo;
    const step = Math.pow(10, Math.floor(Math.log10(span / n)));
    const err = span / n / step;
    const mult = err >= 7.5 ? 10 : err >= 3.5 ? 5 : err >= 1.5 ? 2 : 1;
    const s = step * mult;
    const out = [];
    for (let v = Math.ceil(lo / s) * s; v <= hi + 1e-9; v += s) out.push(Math.round(v * 100) / 100);
    return out;
  }

  function tipHTML(p: any) {
    const rows = [
      `<strong>${p.display_name || "Anonymous"}</strong> · ${norm(p.club)}`,
      `Median carry ${p.carry} yd · offline ${p.offline > 0 ? "+" : ""}${p.offline} yd`,
      `${p.n} shots`,
    ];
    const gear = gearLabel(p);
    if (gear !== NOT_SPECIFIED) rows.push(gear);
    if (p.ball_model) rows.push(`Ball: ${p.ball_model}`);
    if (p.handicap) rows.push(`Handicap ${p.handicap}`);
    if (p.age) rows.push(`Age ${p.age}`);
    if (p.launch_monitor) rows.push(p.launch_monitor);
    return rows.join("<br>");
  }

  function showTip(ev: MouseEvent, p: any) {
    const tip = $("x-tip");
    tip.innerHTML = tipHTML(p);
    tip.hidden = false;
    moveTip(ev);
  }
  function moveTip(ev: MouseEvent) {
    const tip = $("x-tip");
    const wrap = tip.parentElement!.getBoundingClientRect();
    tip.style.left = `${Math.min(ev.clientX - wrap.left + 14, wrap.width - 220)}px`;
    tip.style.top = `${ev.clientY - wrap.top + 14}px`;
  }

  // ---- leaderboard --------------------------------------------------------
  function renderLeaderboard(board: any[]) {
    if (!board.length) return;
    const body = $("x-lb-body");
    board.forEach((e) => {
      const tr = document.createElement("tr");
      const gear = e.driver
        ? `<span class="x-lb-gear">${escapeHTML(e.driver)}</span>`
        : "";
      tr.innerHTML =
        `<td class="tnum x-lb-rank">${e.rank}</td>` +
        `<td class="x-lb-name">${escapeHTML(e.display_name)}${gear}</td>` +
        `<td class="tnum"><strong>${e.ball_speed}</strong> mph</td>` +
        `<td class="tnum">${e.club_speed != null ? e.club_speed + " mph" : "–"}</td>` +
        `<td class="tnum">${Math.round(e.carry)} yd</td>` +
        `<td class="tnum">${e.n}</td>`;
      body.appendChild(tr);
    });
    $("leaderboard-band").hidden = false;
  }
  const escapeHTML = (s: string) =>
    s.replace(/[&<>"']/g, (c) => `&#${c.charCodeAt(0)};`);

  boot();
</script>

<style>
  .x-filters {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 1.25rem;
  }
  .x-clubs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .x-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.32rem 0.6rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: color 0.15s var(--ease), border-color 0.15s var(--ease);
  }
  .x-chip:hover { color: var(--text); }
  .x-chip.active {
    color: var(--text);
    border-color: var(--green);
  }
  .x-dot {
    display: inline-block;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .x-selects {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
  }
  .x-select {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-dim);
  }
  .x-select select {
    font: inherit;
    text-transform: none;
    letter-spacing: 0;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.3rem 0.45rem;
    max-width: 13rem;
  }

  .x-body {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(200px, 1fr);
    gap: var(--gap);
    align-items: start;
  }
  .x-plot-wrap { position: relative; }
  .x-plot {
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .x-plot-caption {
    margin-top: 0.45rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .x-tip {
    position: absolute;
    max-width: 220px;
    pointer-events: none;
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.45;
    padding: 0.5rem 0.65rem;
    z-index: 5;
  }
  .x-tip strong { color: var(--text); }

  .x-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .x-table th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.55rem 0.7rem;
    border-bottom: 1px solid var(--border);
  }
  .x-table td {
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.88rem;
  }
  .x-table tr:last-child td { border-bottom: none; }
  .x-table td .x-dot { margin-right: 0.4rem; }
  .x-count {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .x-empty {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px dashed var(--border-strong);
    padding: 1rem 1.25rem;
    max-width: 560px;
  }

  .x-lb-wrap {
    position: relative;
    max-width: 640px;
    overflow-x: auto;
  }
  /* The frosted bomber: a big, barely-there flying wing behind the numbers.
     Blur + low opacity keeps it atmospheric instead of busy; pointer-events
     off so it never eats a click. */
  .x-bomber {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%) rotate(-8deg);
    width: min(520px, 92%);
    filter: blur(1.5px);
    opacity: 0.07;
    pointer-events: none;
    z-index: 0;
  }
  .x-bomber path {
    fill: var(--text);
  }
  .x-lb { position: relative; z-index: 1; background: transparent; }
  .x-lb td { background: transparent; }
  .x-lb-rank { color: var(--text-dim); }
  .x-lb-name { color: var(--text); font-weight: 600; }
  .x-lb-gear {
    display: block;
    font-weight: 400;
    font-size: 0.76rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
  }
  .x-lb td strong { color: var(--green); }

  @media (max-width: 760px) {
    .x-body { grid-template-columns: 1fr; }
  }
</style>
