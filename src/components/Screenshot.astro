---
// Screenshot figure. Shows the WHOLE image at its natural aspect ratio — never
// crops. If real intrinsic dimensions are passed (width + height), the frame
// reserves the correct space up-front to avoid layout shift; otherwise the
// image simply sizes itself once loaded. Real images live in
// /public/images/screenshots/.
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
}
const { src, alt, caption, width, height, loading = "lazy" } = Astro.props;
const hasDims = !!(width && height);
---

<figure class="shot">
  <div class="shot-frame" style={hasDims ? `aspect-ratio:${width}/${height}` : undefined}>
    <img
      src={src}
      alt={alt}
      width={hasDims ? width : undefined}
      height={hasDims ? height : undefined}
      loading={loading}
      decoding="async"
    />
    <span class="shot-scan" aria-hidden="true"></span>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .shot {
    margin: 0;
  }
  .shot-frame {
    position: relative;
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border-strong);
    overflow: hidden;
    background:
      linear-gradient(180deg, var(--surface) 0%, var(--bg-elevated) 100%);
    box-shadow: var(--shadow);
  }
  /* height:auto + contain means the full image is always shown, at its own
     aspect ratio — no left/right (or top/bottom) cropping. */
  .shot-frame img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }
  /* Faint scan-line sheen to reinforce the launch-monitor feel. */
  .shot-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      100deg,
      transparent 40%,
      var(--green-tint) 50%,
      transparent 60%
    );
  }
  figcaption {
    margin-top: 0.7rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }
</style>
