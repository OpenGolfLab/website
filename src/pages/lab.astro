---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { GITHUB_URL, GITHUB_WATCH_URL } from "../consts";

// Research-category posts surface here, paired with the data.
const labPosts = (
  await getCollection("blog", ({ data }) => !data.draft && data.category === "Research")
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "The Lab";
const description =
  "The OpenGolfLab community analytics hub — an open framework where sim golfers contribute anonymized ball and club metrics to build community-driven analytics: real-world ball comparisons, gapping distributions by handicap, and launch/spin norms.";

const pillars = [
  {
    title: "Real-world ball comparisons",
    body: "Aggregate carry, spin and launch across balls and simulators to see how models actually differ — not marketing numbers, but community data.",
    tag: "Balls",
  },
  {
    title: "Gapping distributions by handicap",
    body: "What does a 12-handicap's 7-iron carry, really? Distributions built from thousands of shots, sliced by skill band.",
    tag: "Gapping",
  },
  {
    title: "Launch & spin norms",
    body: "Trustworthy reference windows for every club — so the app can flag your shots against the community, not just Tour ideals.",
    tag: "Norms",
  },
];

// If real community aggregates have been published to public/data/summary.json,
// read them at build time and render them. Otherwise fall back to the labeled
// illustrative sample below. (Produced by the aggregator in opengolflab-data.)
const DEFAULT_BAND = "10-14";
let live: any = null;
try {
  const p = path.resolve("public/data/summary.json");
  if (fs.existsSync(p)) live = JSON.parse(fs.readFileSync(p, "utf-8"));
} catch {
  live = null;
}
const isLive = !!(live && live.totals && live.totals.shots > 0 && Array.isArray(live.gapping) && live.gapping.length);

// 2026 driver rankings — aggregated from club-review outlets across the web.
// Generated by scripts/build-driver-rankings.mjs (run `npm run rankings`).
let rankings: any = null;
try {
  const rp = path.resolve("public/data/driver-rankings.json");
  if (fs.existsSync(rp)) rankings = JSON.parse(fs.readFileSync(rp, "utf-8"));
} catch {
  rankings = null;
}
const hasRankings = !!(
  rankings &&
  Array.isArray(rankings.rankers) &&
  rankings.rankers.length &&
  Array.isArray(rankings.drivers) &&
  rankings.drivers.length
);
// Compact column labels for the (long) outlet names.
const rankerShort: Record<string, string> = {
  mygolfspy: "MyGolfSpy",
  golfmonthly: "Golf Monthly",
  todaysgolfer: "Today's Golfer",
  golfwrx: "GolfWRX",
  breakingeighty: "Breaking 80",
  hole19: "Hole19",
  golflens: "GolfLens",
  independentgolfreviews: "Indep. GR",
};

// Segmented tables (by priority / by player profile).
let segments: any = null;
try {
  const sp = path.resolve("public/data/driver-segments.json");
  if (fs.existsSync(sp)) segments = JSON.parse(fs.readFileSync(sp, "utf-8"));
} catch {
  segments = null;
}
const hasSegments = !!(
  segments &&
  Array.isArray(segments.features) &&
  segments.features.length &&
  Array.isArray(segments.profiles) &&
  segments.profiles.length
);

// --- uncertainty "forest plot" geometry ---
const UW = 150; // svg width units
const UH = 26; // svg height units
const UPAD = 9;
const UCY = 12; // baseline y
const ux = (v: number) => UPAD + (v / 100) * (UW - 2 * UPAD);
const dotR = (ev: string) => (ev === "high" ? 5 : ev === "medium" ? 4 : 3);

const num = (v: number) => Number(v).toLocaleString("en-US");

let previewRows;
let bandLabel = DEFAULT_BAND;
let dist: number[];
let binLabels: string[];
let distClub = "7 Iron";

if (isLive) {
  const bands = live.gapping.map((g: any) => g.handicap_band);
  bandLabel = bands.includes(DEFAULT_BAND) ? DEFAULT_BAND : bands[0];
  previewRows = live.gapping
    .filter((g: any) => g.handicap_band === bandLabel)
    .sort((a: any, b: any) => b.carry - a.carry)
    .map((r: any) => ({
      club: r.club,
      carry: r.carry != null ? String(r.carry) : "—",
      ball: r.ball != null ? String(r.ball) : "—",
      launch: r.launch != null ? String(r.launch) : "—",
      spin: r.spin != null ? num(r.spin) : "—",
      n: num(r.shots),
    }));
  const counts: number[] = live.distribution?.counts ?? [];
  const max = Math.max(1, ...counts);
  dist = counts.map((c) => Math.round((c / max) * 100));
  binLabels = (live.distribution?.bins ?? []).map((b: string, i: number) => (i % 2 === 0 ? b : ""));
  distClub = live.distribution?.club ?? distClub;
} else {
  // Illustrative SAMPLE rows (~10-handicap band). NOT real community data.
  previewRows = [
    { club: "Driver", carry: "245", ball: "152", launch: "13.5", spin: "2,650", n: "1,240" },
    { club: "7 Iron", carry: "152", ball: "115", launch: "18.5", spin: "6,300", n: "1,890" },
    { club: "PW", carry: "118", ball: "98", launch: "24.6", spin: "8,600", n: "1,510" },
  ];
  dist = [6, 14, 28, 55, 82, 100, 86, 60, 32, 12];
  binLabels = ["135", "", "145", "", "155", "", "165", "", "175", ""];
}
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span class="pill lab-status">◐ Coming soon</span>
      <h1>The Lab</h1>
      <p class="lede" style="margin-top:1rem;">
        Your data makes your game measurable. Pooled — anonymized and opt-in —
        it makes the whole simulator community measurable. The Lab is an open
        framework for turning thousands of sessions into analytics no single
        golfer could ever produce alone.
      </p>
      <div class="hero-cta" style="margin-top:1.6rem;">
        <a href={GITHUB_WATCH_URL} class="btn btn-primary" rel="noopener">
          Watch the repo
        </a>
        <a href="/blog" class="btn btn-secondary">Follow the blog</a>
      </div>
      <p class="lab-noemail">
        No newsletter, no sign-up. Watch the
        <a href={GITHUB_URL} rel="noopener">GitHub repo</a> or follow the
        <a href="/blog">blog</a> and you'll know the moment data goes live.
      </p>
    </div>
  </section>

  <div class="container lab-body">
    <!-- Vision pillars -->
    <section class="lab-section" aria-labelledby="vision">
      <p class="eyebrow">The vision</p>
      <h2 id="vision">Three things a shared dataset unlocks</h2>
      <div class="pillars">
        {
          pillars.map((p) => (
            <article class="card pillar">
              <span class="pill">{p.tag}</span>
              <h3>{p.title}</h3>
              <p class="text-muted">{p.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- How contribution will work -->
    <section class="lab-section" aria-labelledby="how">
      <p class="eyebrow">How it will work</p>
      <h2 id="how">Open, anonymized, opt-in</h2>
      <ol class="lab-steps">
        <li class="card">
          <span class="step-n tnum">01</span>
          <div>
            <h3>You opt in</h3>
            <p class="text-muted">
              Contribution is off by default. Nothing is shared unless you turn
              it on — and even then, only stripped-down metrics leave your
              machine.
            </p>
          </div>
        </li>
        <li class="card">
          <span class="step-n tnum">02</span>
          <div>
            <h3>Metrics are anonymized</h3>
            <p class="text-muted">
              Ball speed, launch, spin, carry and club — never your name, your
              rounds, or anything that identifies you. The raw data stays local.
            </p>
          </div>
        </li>
        <li class="card">
          <span class="step-n tnum">03</span>
          <div>
            <h3>The community benefits</h3>
            <p class="text-muted">
              Aggregates flow back into open tables and charts anyone can use —
              and into better benchmarks inside the app itself.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <!-- Data preview (structured so real tables/charts slot in later) -->
    <section class="lab-section" aria-labelledby="preview">
      <p class="eyebrow">Preview</p>
      <div class="preview-head">
        <h2 id="preview">Community gapping — {bandLabel} handicap</h2>
        {
          isLive ? (
            <span class="sample-badge live-badge">
              {num(live.totals.contributors)} contributors · {num(live.totals.shots)} shots
            </span>
          ) : (
            <span class="sample-badge">Sample data</span>
          )
        }
      </div>
      {
        isLive ? (
          <p class="text-muted" style="max-width:62ch;margin-bottom:1.25rem;">
            Live community aggregates for the <strong>{bandLabel}</strong> handicap
            band, built from {num(live.totals.shots)} contributed shots.
            Last updated {live.generated_date}.
          </p>
        ) : (
          <p class="text-muted" style="max-width:62ch;margin-bottom:1.25rem;">
            A preview of the shape the real dataset will take. The numbers below are
            <strong>illustrative samples</strong> (roughly a 10-handicap band) — not
            yet real community data. Once contributions begin, live figures replace
            them here.
          </p>
        )
      }

      <div class="table-wrap" role="region" aria-label="Community gapping sample table" tabindex="0">
        <table class="data-table">
          <caption class="sr-only">
            Community gapping by club — carry, ball speed, launch, spin and
            sample size.
          </caption>
          <thead>
            <tr>
              <th scope="col">Club</th>
              <th scope="col">Carry (yd)</th>
              <th scope="col">Ball (mph)</th>
              <th scope="col">Launch (°)</th>
              <th scope="col">Spin (rpm)</th>
              <th scope="col">Shots</th>
            </tr>
          </thead>
          <tbody>
            {
              previewRows.map((r) => (
                <tr>
                  <th scope="row">{r.club}</th>
                  <td>{r.carry}</td>
                  <td>{r.ball}</td>
                  <td>{r.launch}</td>
                  <td>{r.spin}</td>
                  <td>{r.n}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <!-- Illustrative distribution chart (inline SVG, no chart library) -->
      <figure class="dist-chart">
        <figcaption class="dist-cap">
          <span>{distClub} carry distribution{isLive ? "" : " — sample"}</span>
          <span class:list={["sample-badge", { "live-badge": isLive }]}>
            {isLive ? "Community" : "Illustrative"}
          </span>
        </figcaption>
        <svg
          viewBox="0 0 800 320"
          class="dist-svg"
          role="img"
          aria-label="Illustrative histogram of 7-iron carry distances, sample data."
        >
          <line class="dist-axis" x1="55" y1="275" x2="782" y2="275"></line>
          <text
            class="dist-lbl"
            x="18"
            y="150"
            font-size="13"
            text-anchor="middle"
            transform="rotate(-90 18 150)">shots</text
          >
          {
            dist.map((v, i) => {
              const L = 55;
              const R = 782;
              const slot = (R - L) / dist.length;
              const bw = slot * 0.66;
              const x = L + i * slot + (slot - bw) / 2;
              const h = (v / 100) * 245;
              const y = 275 - h;
              const op = (0.4 + 0.55 * (v / 100)).toFixed(2);
              return (
                <g>
                  <rect class="dist-bar" x={x} y={y} width={bw} height={h} rx="3" style={`opacity:${op}`} />
                  {binLabels[i] && (
                    <text class="dist-lbl" x={x + bw / 2} y="295" font-size="12" text-anchor="middle">
                      {binLabels[i]}
                    </text>
                  )}
                </g>
              );
            })
          }
          <text class="dist-lbl" x="418" y="314" font-size="12" text-anchor="middle">Carry (yards)</text>
        </svg>
      </figure>
    </section>

    <!-- 2026 driver rankings — aggregated from club-review outlets across the web -->
    {
      hasRankings && (
        <section class="lab-section" aria-labelledby="rankings">
          <p class="eyebrow">Equipment</p>
          <div class="preview-head">
            <h2 id="rankings">2026 driver rankings — the web's consensus</h2>
            <span class="sample-badge live-badge">
              {rankings.totals.rankers} outlets · {rankings.totals.drivers} drivers
            </span>
          </div>
          <p class="text-muted" style="max-width:66ch;margin-bottom:1.25rem;">
            We comb the major club-review outlets, record where each one ranks
            every 2026 driver, and tally them into a single table. Each column is
            a ranker — linked to their article, full credit to them — and each
            cell is that outlet's placement for that driver. The{" "}
            <strong>Consensus</strong> column combines every list with a
            normalized Borda count, so a driver is rewarded both for ranking
            highly and for showing up across many outlets. Last updated{" "}
            {rankings.generated_date}.
          </p>

          <div
            class="table-wrap"
            role="region"
            aria-label="2026 driver rankings by outlet"
            tabindex="0"
          >
            <table class="data-table rankings-table">
              <caption class="sr-only">
                2026 driver rankings: consensus standing, an opinion score with an
                uncertainty band and sample size, and each outlet's placement per
                driver.
              </caption>
              <thead>
                <tr>
                  <th scope="col">#</th>
                  <th scope="col">Driver</th>
                  <th scope="col" class="unc-col-h">Opinion (0–100) &amp; confidence</th>
                  {rankings.rankers.map((r: any) => (
                    <th scope="col">
                      <a
                        href={r.url}
                        rel="noopener nofollow"
                        target="_blank"
                        title={`${r.title} — ${r.name}`}
                      >
                        {rankerShort[r.id] ?? r.name}
                      </a>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {rankings.drivers.map((d: any) => (
                  <tr class:list={{ "is-podium": d.consensus <= 3 }}>
                    <td class="tnum rank-consensus">{d.consensus}</td>
                    <th scope="row">{d.model}</th>
                    <td class="unc-cell">
                      <svg
                        class="unc"
                        viewBox={`0 0 ${UW} ${UH}`}
                        role="img"
                        aria-label={`Opinion score ${d.meanScore} of 100 from ${d.appearances} ${d.appearances === 1 ? "review" : "reviews"}; agreement ${d.agreement}.`}
                      >
                        <line class="unc-axis" x1={ux(0)} y1={UCY} x2={ux(100)} y2={UCY} />
                        {d.appearances > 1 && d.bandLow !== null && (
                          <Fragment>
                            <line
                              class="unc-range"
                              x1={ux(d.scoreMin)}
                              y1={UCY}
                              x2={ux(d.scoreMax)}
                              y2={UCY}
                            />
                            <rect
                              class="unc-band"
                              x={ux(d.bandLow)}
                              y={UCY - 4.5}
                              width={Math.max(1.5, ux(d.bandHigh) - ux(d.bandLow))}
                              height="9"
                              rx="2"
                            />
                          </Fragment>
                        )}
                        <circle
                          class:list={["unc-dot", `ev-${d.evidence}`, { single: d.appearances === 1 }]}
                          cx={ux(d.meanScore)}
                          cy={UCY}
                          r={dotR(d.evidence)}
                        />
                      </svg>
                      <span class="unc-meta">
                        <span class="unc-n tnum">n={d.appearances}</span>
                        <span class:list={["agree", `a-${d.agreement}`]}>{d.agreement}</span>
                      </span>
                    </td>
                    {rankings.rankers.map((r: any) => (
                      <td class="tnum">
                        {d.ranks[r.id] ? (
                          d.ranks[r.id]
                        ) : (
                          <span class="rank-empty">·</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="unc-legend">
            <p class="eyebrow" style="margin-top:1.4rem;">
              Reading the opinion column
            </p>
            <p class="text-muted" style="max-width:70ch;">
              Each outlet's placement is turned into a 0–100 opinion score
              (that outlet's #1 = 100, its last place = 0), so a rank on a
              short list and a long list are comparable. The graphic then shows
              how much the outlets agreed, and how much evidence there is:
            </p>
            <ul class="unc-key">
              <li>
                <svg viewBox={`0 0 ${UW} ${UH}`} class="unc unc-key-svg" aria-hidden="true">
                  <line class="unc-axis" x1={ux(0)} y1={UCY} x2={ux(100)} y2={UCY} />
                  <line class="unc-range" x1={ux(25)} y1={UCY} x2={ux(90)} y2={UCY} />
                  <rect class="unc-band" x={ux(40)} y={UCY - 4.5} width={ux(75) - ux(40)} height="9" rx="2" />
                  <circle class="unc-dot ev-high" cx={ux(58)} cy={UCY} r="5" />
                </svg>
                <span
                  ><strong>Dot</strong> = average opinion. <strong>Shaded band</strong>
                  = ±1 SD (how much reviewers disagree). <strong>Thin line</strong>
                  = full range of placements.</span
                >
              </li>
              <li>
                <span class="unc-key-dots" aria-hidden="true">
                  <svg viewBox="0 0 70 20" class="unc-key-svg2">
                    <circle class="unc-dot ev-low" cx="12" cy="10" r="3" />
                    <circle class="unc-dot ev-medium" cx="34" cy="10" r="4" />
                    <circle class="unc-dot ev-high" cx="58" cy="10" r="5" />
                  </svg>
                </span>
                <span
                  ><strong>Dot size = evidence</strong>: small = 1–2 outlets,
                  medium = 3–4, large = 5+. A bigger dot means more reviewers
                  looked at it — a small dot isn't "worse", just less certain.</span
                >
              </li>
              <li>
                <span class="unc-key-dots" aria-hidden="true">
                  <svg viewBox="0 0 24 20" class="unc-key-svg2">
                    <circle class="unc-dot ev-low single" cx="12" cy="10" r="4" />
                  </svg>
                </span>
                <span
                  ><strong>Hollow dot = single review.</strong> One outlet's
                  opinion only — treat with caution (wide uncertainty).
                  Labels <em>tight / mixed / wide</em> summarise the spread.</span
                >
              </li>
            </ul>
          </div>

          <div class="rankings-credits">
            <p class="eyebrow" style="margin-top:1.6rem;">
              Credits &amp; sources
            </p>
            <ul class="credit-list">
              {rankings.rankers.map((r: any) => (
                <li>
                  <a href={r.url} rel="noopener nofollow" target="_blank">
                    {r.name}
                  </a>
                  <span class="text-dim"> — {r.title}</span>
                </li>
              ))}
            </ul>
            <p class="text-dim rankings-note">
              Consensus is a normalized Borda count across the outlets above, each
              list weighted equally regardless of length. Model variants (e.g.
              Callaway Quantum Triple Diamond vs. Triple Diamond Max) are kept
              separate because outlets rate them separately. Sources that publish
              an unranked showcase rather than an ordinal ranking, or that list
              prior-generation clubs, are not included.
            </p>
          </div>
        </section>
      )
    }

    <!-- Segmented views: by player profile and by priority/feature -->
    {
      hasSegments && (
        <section class="lab-section" aria-labelledby="segments">
          <p class="eyebrow">Equipment</p>
          <h2 id="segments">Which driver for whom?</h2>
          <p class="text-muted" style="max-width:66ch;margin-bottom:0.5rem;">
            A single consensus hides the fact that the "best" driver depends on
            your swing and what you want from it. These two tables break the same
            outlets' picks out by player profile and by performance priority. Each
            cell is what that outlet crowned (linked to their article); the{" "}
            <strong>Most named</strong> column tallies where outlets agree — and
            where they don't.
          </p>

          {[
            { title: "By player profile", sub: "Swing speed & handicap", rows: segments.profiles, head: "Profile" },
            { title: "By priority", sub: "What you want most from a driver", rows: segments.features, head: "Priority" },
          ].map((tbl: any) => (
            <div class="seg-block">
              <div class="preview-head" style="margin-top:1.6rem;">
                <h3 class="seg-title">{tbl.title}</h3>
                <span class="seg-sub">{tbl.sub}</span>
              </div>
              <div class="table-wrap" role="region" aria-label={tbl.title} tabindex="0">
                <table class="data-table seg-table">
                  <thead>
                    <tr>
                      <th scope="col">{tbl.head}</th>
                      <th scope="col">Most named</th>
                      {segments.rankers.map((r: any) => (
                        <th scope="col">
                          <a href={r.url} rel="noopener nofollow" target="_blank" title={`${r.title} — ${r.name}`}>
                            {rankerShort[r.id] ?? r.name}
                          </a>
                        </th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {tbl.rows.map((row: any) => (
                      <tr>
                        <th scope="row">
                          <span class="seg-label">{row.label}</span>
                          {row.group && <span class="seg-group">{row.group}</span>}
                        </th>
                        <td class="seg-leaders">
                          {row.count === 0 ? (
                            <span class="rank-empty">·</span>
                          ) : (
                            <Fragment>
                              <span class="seg-leader-name">{row.leaders.join(" / ")}</span>
                              {row.leaderCount > 1 && <span class="seg-leader-count">{row.leaderCount}×</span>}
                            </Fragment>
                          )}
                        </td>
                        {segments.rankers.map((r: any) => {
                          const cell = row.cells.find((c: any) => c.ranker === r.id);
                          return (
                            <td class="seg-cell">
                              {cell ? (
                                <a
                                  href={r.url}
                                  rel="noopener nofollow"
                                  target="_blank"
                                  class:list={["seg-pick", { lead: row.leaders.includes(cell.model) }]}
                                >
                                  {cell.model}
                                </a>
                              ) : (
                                <span class="rank-empty">·</span>
                              )}
                            </td>
                          );
                        })}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}

          <p class="text-dim rankings-note" style="margin-top:1.1rem;">
            Cells show each outlet's category winner for 2026, linked to their
            article. Blank = that outlet didn't name a pick for that segment.
            Profile picks come from the outlets that break testing out by swing
            speed or handicap (MyGolfSpy, GolfWRX, Hole19, Golf Monthly, Breaking
            Eighty, Independent Golf Reviews).
          </p>
        </section>
      )
    }

    <!-- From the Lab: Research-category articles, paired with the data -->
    <section class="lab-section" aria-labelledby="writing">
      <p class="eyebrow">From the Lab</p>
      <h2 id="writing">Field notes &amp; findings</h2>
      <p class="text-muted" style="max-width:60ch;margin-bottom:1.5rem;">
        Write-ups that go with the data — methodology, early results, and the
        thinking behind the framework.
      </p>

      {
        labPosts.length === 0 ? (
          <div class="card lab-empty">
            <p class="text-muted">
              The first findings aren't published yet. Follow the
              <a href="/blog">blog</a> or watch the
              <a href={GITHUB_URL} rel="noopener">GitHub repo</a> and you'll see
              them the moment they land.
            </p>
          </div>
        ) : (
          <ul class="lab-posts">
            {labPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}/`} class="card lab-post">
                  <div class="lab-post-meta">
                    <span class="pill lab-post-cat">Research</span>
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <h3>{post.data.title}</h3>
                  <p class="text-muted">{post.data.description}</p>
