---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { GITHUB_URL, GITHUB_WATCH_URL } from "../consts";

const title = "The Lab";
const description =
  "The OpenGolfLab community analytics hub — an open framework where sim golfers contribute anonymized ball and club metrics to build community-driven analytics: real-world ball comparisons, gapping distributions by handicap, and launch/spin norms.";

// 2026 driver lineup spectrum + market pricing
let lineupsData: any = null;
try {
  const rp = path.resolve("public/data/driver-lineups.json");
  if (fs.existsSync(rp)) lineupsData = JSON.parse(fs.readFileSync(rp, "utf-8"));
} catch {
  lineupsData = null;
}
const hasLineups = !!(
  lineupsData &&
  Array.isArray(lineupsData.lineups) &&
  lineupsData.lineups.length
);
const lineups = hasLineups ? lineupsData.lineups : [];

// All models flattened, for build-time stats and the pricing chart.
const allModels = lineups.flatMap((l: any) =>
  (l.models ?? []).map((m: any) => ({ ...m, brand: l.brand }))
);
const modelCount = allModels.length;
const sortedPrices = [...allModels.map((m: any) => m.price)].sort((a, b) => a - b);
const medianPrice = sortedPrices.length
  ? sortedPrices.length % 2 === 1
    ? sortedPrices[(sortedPrices.length - 1) / 2]
    : Math.round((sortedPrices[sortedPrices.length / 2 - 1] + sortedPrices[sortedPrices.length / 2]) / 2)
  : 0;
const discounted = allModels
  .map((m: any) => ({ ...m, savings: m.msrp - m.price, pct: m.msrp > 0 ? ((m.msrp - m.price) / m.msrp) * 100 : 0 }))
  .filter((m: any) => m.savings > 0)
  .sort((a: any, b: any) => b.pct - a.pct);
const biggestDiscount = discounted[0];

// Pricing chart axis: $0-based, gridlines every $200, rounded up past the max MSRP.
const maxRawPrice = allModels.reduce((max: number, m: any) => Math.max(max, m.msrp, m.price), 0);
const axisMaxRounded = Math.max(200, Math.ceil((maxRawPrice + 1) / 200) * 200);
const axisTicks: number[] = [];
for (let v = 0; v <= axisMaxRounded; v += 200) axisTicks.push(v);
const pricingLineups = lineups.map((l: any) => ({
  brand: l.brand,
  models: [...(l.models ?? [])].sort((a: any, b: any) => a.price - b.price),
}));

// Spectrum: sort each brand's models by position, then stagger label height
// only where neighboring models sit close enough on the track to collide —
// so labels stay level unless they actually need separating, instead of
// climbing in lockstep (which made rightmost/"distance" models always sit
// highest regardless of how much room they actually had).
const STAGGER_GAP = 16; // position-% below which two labels are considered close
const spectrumLineups = lineups.map((l: any) => {
  const models = [...(l.models ?? [])].sort((a: any, b: any) => a.position - b.position);
  let prevPosition: number | null = null;
  let stagger = 0;
  const staggered = models.map((m: any) => {
    stagger = prevPosition !== null && m.position - prevPosition < STAGGER_GAP ? (stagger + 1) % 3 : 0;
    prevPosition = m.position;
    return { ...m, stagger };
  });
  return { brand: l.brand, models: staggered };
});

// ---- Community aggregates (summary.json v2 — tiered) --------------------------
// Written by the opengolflab-data aggregator. Optional: absent, or present with
// empty tiers, until enough contributors clear the publish threshold. The page
// degrades to the "in progress" build-status list until real data exists.
let summaryData: any = null;
try {
  const sp = path.resolve("public/data/summary.json");
  if (fs.existsSync(sp)) summaryData = JSON.parse(fs.readFileSync(sp, "utf-8"));
} catch {
  summaryData = null;
}

const TIER_META = [
  { key: "all", src: "community", label: "All", blurb: "Every contributor that clears quality control." },
  { key: "verified", src: "verified", label: "Verified", blurb: "Spin-measuring monitors, proven contributors." },
  { key: "reference", src: "reference", label: "Reference", blurb: "A curated core of vetted contributors." },
];

// A driver dispersion cell → SVG ellipse geometry (the "typical player" spread).
const DISP = { sx: 2.4, sy: 2.4, k: 1.5, cx0: 110, cy: 88 }; // px/yd, ~1σ look
function driverEllipse(clubs: any[]) {
  const dr = clubs.find((c: any) => String(c.club || "").toUpperCase() === "DR");
  const d = dr?.dispersion;
  if (!d || d.lateral_mad == null || d.depth_mad == null) return null;
  return {
    cx: DISP.cx0 + (d.offline_bias ?? 0) * DISP.sx,
    cy: DISP.cy,
    rx: Math.max(5, d.lateral_mad * DISP.k * DISP.sx),
    ry: Math.max(5, d.depth_mad * DISP.k * DISP.sy),
    lateral: d.lateral_mad,
    depth: d.depth_mad,
    bias: d.offline_bias ?? 0,
  };
}

const tierViews = TIER_META.map((t) => {
  const blk = summaryData?.tiers?.[t.src] ?? {};
  const clubs = Array.isArray(blk?.clubs) ? blk.clubs : [];
  return {
    ...t,
    contributors: blk?.totals?.contributors ?? 0,
    shots: blk?.totals?.shots ?? 0,
    clubs,
    ellipse: driverEllipse(clubs),
  };
});
const hasCommunityData = tierViews.some((t) => t.clubs.length > 0);
// Default the toggle to the highest-trust tier that actually has data.
const defaultTierKey =
  [...tierViews].reverse().find((t) => t.clubs.length > 0)?.key ?? "all";
const generatedDate = summaryData?.generated_date ?? null;
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span class="pill lab-status">◐ Community dataset in progress</span>
      <h1>The Lab</h1>
      <p class="lede" style="margin-top:1rem;">
        Every shot from your launch monitor tells a story about your game,
        but the bigger picture requires a crowd. The Lab aggregates
        anonymized simulator sessions to build what no individual can:
        community-driven ball and club comparisons, true gapping by
        handicap, and launch and spin norms to help you find the absolute
        best equipment for your game.
      </p>
      <div class="hero-cta" style="margin-top:1.6rem;">
        <a href={GITHUB_WATCH_URL} class="btn btn-primary" rel="noopener">
          Watch the repo
        </a>
        <a href="/blog" class="btn btn-secondary">Follow the blog</a>
      </div>
      <p class="lab-noemail">
        No newsletter, no sign-up. Watch the
        <a href={GITHUB_URL} rel="noopener">GitHub repo</a> or follow the
        <a href="/blog">blog</a> and you'll know the moment data goes live.
      </p>
    </div>
  </section>

  <div class="container lab-body">

    <!-- ============ BAND 1: LIVE NOW — MARKET DATA ============ -->
    <section class="lab-band">
      <div class="lab-band-head">
        <span class="pill lab-band-pill live">Live now</span>
        <h2>Market data</h2>
        <p class="text-muted" style="max-width:66ch;">
          Editorial market snapshots we maintain ourselves — not yet
          community-sourced. That's a separate effort, in progress below.
        </p>
      </div>

      {
        hasLineups && (
          <section class="lab-section" aria-labelledby="lineups">
            <p class="eyebrow">Equipment</p>
            <h3 id="lineups">2026 Driver Lineup Spectrum</h3>
            <p class="text-muted" style="max-width:66ch;margin-bottom:1.25rem;">
              A complete map of every major manufacturer's current driver lineup, plotted across a spectrum from maximum forgiveness to pure distance. Use this matrix to understand exactly where a club sits in a brand's ecosystem.
            </p>

            <div class="continuum-wrap" role="region" aria-label="2026 driver continuum">
              <div class="continuum-header">
                <span>Max Forgiveness</span>
                <span class="text-dim">Balanced / Core</span>
                <span>Pure Distance</span>
              </div>

              <div class="continuum-body">
                {spectrumLineups.map((lineup: any) => (
                  <div class="continuum-row">
                    <div class="continuum-brand">
                      <strong>{lineup.brand}</strong>
                    </div>
                    <div class="continuum-track-area">
                      <div class="continuum-track-line" aria-hidden="true" />
                      {[0, 25, 50, 75, 100].map((tick) => (
                        <span class="continuum-gridline" style={`left:${tick}%`} aria-hidden="true" />
                      ))}
                      {lineup.models.map((model: any) => (
                        <div
                          class="continuum-node"
                          style={`left: ${model.position}%; --stagger: ${model.stagger};`}
                        >
                          <span class="continuum-node-dot" aria-hidden="true" />
                          <span class="continuum-node-label">{model.name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>

            </div>

            <!-- Mobile-only fallback: stacked per-brand lists, no forced horizontal scroll. -->
            <div class="continuum-mobile">
              {spectrumLineups.map((lineup: any) => (
                <div class="continuum-mobile-brand">
                  <strong>{lineup.brand}</strong>
                  <ul>
                    {lineup.models.map((model: any) => (
                      <li>
                        <span>{model.name}</span>
                        <span class="continuum-mobile-pos tnum">{model.position}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <p class="lab-caption">
              Positions are editorial estimates from manufacturer positioning + published MOI; not yet community data.
            </p>
          </section>
        )
      }

      {
        hasLineups && (
          <section class="lab-section" aria-labelledby="pricing">
            <div class="preview-head">
              <h3 id="pricing">Market Pricing</h3>
            </div>
            <p class="text-muted" style="max-width:66ch;">
              Today's best retail prices vs. MSRP. Hollow dot = MSRP. Filled dot = lowest price found today, connected by a line — green marks a real discount. Click any row to shop.
            </p>
            <p class="lab-stat-line tnum">
              {modelCount} drivers · median street price ${medianPrice}
              {biggestDiscount && (
                <>
                  {" "}· biggest discount: {biggestDiscount.name} −{Math.round(biggestDiscount.pct)}%
                </>
              )}
            </p>

            <div class="price-chart-wrap" role="region" aria-label="Pricing dumbbell chart">
              <div class="price-chart-axis" aria-hidden="true">
                <div class="price-chart-axis-spacer" />
                <div class="price-chart-axis-ticks">
                  {axisTicks.map((t) => (
                    <span class="price-chart-axis-tick" style={`left:${(t / axisMaxRounded) * 100}%`}>${t}</span>
                  ))}
                </div>
              </div>

              <div class="price-chart-body">
                {pricingLineups.map((lineup: any) => (
                  <div class="price-chart-group">
                    <div class="price-chart-brand">{lineup.brand}</div>
                    <div class="price-chart-bars">
                      {lineup.models.map((model: any) => {
                        const msrpPct = (model.msrp / axisMaxRounded) * 100;
                        const pricePct = (model.price / axisMaxRounded) * 100;
                        const savings = model.msrp - model.price;
                        const hasDiscount = savings > 0;
                        return (
                          <a
                            href={model.dealerUrl || "#"}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="price-row"
                            class:list={[{ discounted: hasDiscount }]}
                          >
                            <span class="price-row-model">{model.name}</span>
                            <div class="price-row-track">
                              {axisTicks.map((t) => (
                                <span class="price-chart-gridline" style={`left:${(t / axisMaxRounded) * 100}%`} aria-hidden="true" />
                              ))}
                              <span
                                class="price-row-connector"
                                style={`left:${Math.min(msrpPct, pricePct)}%; width:${Math.abs(msrpPct - pricePct)}%;`}
                                aria-hidden="true"
                              />
                              <span class="price-row-dot msrp" style={`left:${msrpPct}%`} aria-hidden="true" />
                              <span
                                class="price-row-dot price"
                                class:list={[{ discount: hasDiscount }]}
                                style={`left:${pricePct}%`}
                                aria-hidden="true"
                              />
                            </div>
                            <span class="price-row-values tnum">
                              <span class="price-row-price">${model.price}</span>
                              {hasDiscount && <span class="price-row-msrp">${model.msrp}</span>}
                              <span class="price-row-dealer">{model.dealer || "—"}</span>
                            </span>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )
      }
    </section>

    <!-- ============ BAND 2: COMMUNITY DATASET ============ -->
    <section class="lab-band">
      <div class="lab-band-head">
        <span class:list={["pill", "lab-band-pill", hasCommunityData ? "live" : "progress"]}>
          {hasCommunityData ? "Live now" : "In progress"}
        </span>
        <h2>Community dataset</h2>
        <p class="text-muted" style="max-width:66ch;">
          {hasCommunityData
            ? "Launch and spin norms and driver dispersion, built from anonymized, opt-in sessions. Filter by the data-quality tier you trust."
            : "The real payoff — real ball comparisons, gapping by handicap, and launch/spin norms, built from anonymized, opt-in sessions. Here's where it stands today."}
        </p>
      </div>

      {
        hasCommunityData ? (
          <div class="tiers">
            {tierViews.map((t: any) => (
              <input
                type="radio"
                name="tier"
                id={`tier-${t.key}`}
                class="tier-radio"
                checked={t.key === defaultTierKey}
              />
            ))}

            <div class="tier-labels" role="group" aria-label="Data-quality tier">
              {tierViews.map((t: any) => (
                <label for={`tier-${t.key}`} class="tier-label">
                  {t.label}
                  <span class="tier-count tnum">{t.contributors}</span>
                </label>
              ))}
            </div>

            {tierViews.map((t: any) => (
              <div class:list={["tier-panel", `panel-${t.key}`]}>
                {t.clubs.length ? (
                  <div class="tier-inner">
                    <p class="tier-blurb">
                      {t.blurb}{" "}
                      <span class="text-dim">
                        · {t.contributors} contributors · {t.shots.toLocaleString()} shots
                      </span>
                    </p>

                    <div class="norms-wrap">
                      <table class="norms">
                        <thead>
                          <tr>
                            <th>Club</th>
                            <th>Carry</th>
                            <th>Ball</th>
                            <th>Launch</th>
                            <th>Spin</th>
                            <th>Golfers</th>
                          </tr>
                        </thead>
                        <tbody>
                          {t.clubs.map((c: any) => (
                            <tr>
                              <td class="norms-club">{c.club}</td>
                              <td>
                                <span class="norms-big tnum">
                                  {c.carry?.med}
                                  <span class="norms-unit">yd</span>
                                </span>
                                <span class="norms-range tnum">
                                  {c.carry?.p10}–{c.carry?.p90}
                                </span>
                              </td>
                              <td class="tnum">{c.ball ?? "—"}</td>
                              <td class="tnum">{c.launch ?? "—"}</td>
                              <td>
                                {c.spin?.value != null ? (
                                  <span class="tnum">{c.spin.value}</span>
                                ) : (
                                  <span class="lock" title="Spin publishes at the Verified tier and up — measured, not modeled.">
                                    Verified+
                                  </span>
                                )}
                              </td>
                              <td class="tnum norms-n">{c.contributors}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>

                    {t.ellipse && (
                      <div class="disp">
                        <div class="disp-title">Driver — typical dispersion</div>
                        <svg viewBox="0 0 220 176" class="disp-svg" role="img"
                          aria-label={`Typical driver dispersion, about ${Math.round(t.ellipse.lateral * 2)} yards wide and ${Math.round(t.ellipse.depth * 2)} yards deep`}>
                          <line x1="110" y1="12" x2="110" y2="164" class="disp-axis" />
                          <line x1="18" y1="88" x2="202" y2="88" class="disp-axis" />
                          <ellipse cx={t.ellipse.cx} cy={t.ellipse.cy} rx={t.ellipse.rx} ry={t.ellipse.ry} class="disp-ell" />
                          <circle cx={t.ellipse.cx} cy={t.ellipse.cy} r="2.5" class="disp-center" />
                        </svg>
                        <div class="disp-legend">
                          <span>± {t.ellipse.lateral} yd side</span>
                          <span>± {t.ellipse.depth} yd depth</span>
                          {t.ellipse.bias !== 0 && (
                            <span>{t.ellipse.bias > 0 ? "right" : "left"} bias {Math.abs(t.ellipse.bias)} yd</span>
                          )}
                        </div>
                      </div>
                    )}
                  </div>
                ) : (
                  <p class="tier-empty">
                    Not enough {t.label !== "All" ? t.label.toLowerCase() + "-tier " : ""}data
                    yet to publish — need {summaryData?.meta?.min_contributors ?? 8} golfers
                    per club. Try the All tab.
                  </p>
                )}
              </div>
            ))}

            <p class="lab-caption">
              Median of each golfer's own median — one golfer, one vote, so a big
              session can't skew a number. Ranges are 10th–90th percentile across
              golfers.{generatedDate && <> Updated {generatedDate}.</>}
            </p>
          </div>
        ) : (
          <ul class="build-status">
            <li class="done"><span class="build-mark">✓</span> Capture pipeline</li>
            <li class="done"><span class="build-mark">✓</span> Schema v1.1</li>
            <li class="done"><span class="build-mark">✓</span> Aggregation + QA</li>
            <li class="active"><span class="build-mark">◐</span> First dataset</li>
          </ul>
        )
      }
    </section>

    <!-- ============ BAND 3: HOW TO HELP ============ -->
    <section class="lab-band lab-band-cta">
      <div class="card lab-cta-card">
        <h2>Help shape the framework</h2>
        <p class="text-muted" style="margin-top:0.5rem;max-width:56ch;">
          The Lab is being built in the open. Ideas about schema, privacy, or
          which analytics matter most are welcome on GitHub.
        </p>
        <div class="hero-cta" style="margin-top:1.2rem;">
          <a href={GITHUB_URL} class="btn btn-primary" rel="noopener">Open on GitHub</a>
          <a href="/download" class="btn btn-secondary">Get the app</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .lab-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: radial-gradient(
      120% 90% at 50% -20%,
      var(--green-tint),
      transparent 60%
    );
  }
  .lab-hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(2rem, 5vw, 3rem);
    max-width: 64ch;
  }
  .lab-status {
    color: var(--green);
    border-color: var(--green-dim);
    margin-bottom: 1rem;
  }
  .lab-noemail {
    margin-top: 1.3rem;
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .lab-body {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 7vw, 5rem);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  /* ---- Status bands ---- */
  .lab-band {
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 4vw, 2.5rem);
  }
  .lab-band-head h2 {
    margin-top: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .lab-band-pill {
    font-weight: 600;
  }
  .lab-band-pill.live {
    color: var(--green);
    border-color: var(--green-dim);
  }
  .lab-band-pill.progress {
    color: var(--amber);
    border-color: var(--amber);
  }
  .lab-section h3 {
    margin-bottom: 0.6rem;
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
  }
  .lab-section + .lab-section {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .lab-caption {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .lab-stat-line {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
  }

  /* ---- Build status list ---- */
  .build-status {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .build-status li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 0.9rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
  }
  .build-mark {
    font-size: 1rem;
  }
  .build-status li.done {
    color: var(--text);
  }
  .build-status li.done .build-mark {
    color: var(--green);
  }
  .build-status li.active {
    color: var(--text);
    border-color: var(--amber);
  }
  .build-status li.active .build-mark {
    color: var(--amber);
  }
  .build-status li.pending {
    color: var(--text-dim);
  }
  .build-status li.pending .build-mark {
    color: var(--text-dim);
  }

  .lab-cta-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  /* ---- Continuum / spectrum ---- */
  .continuum-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.25rem 1.5rem 0.85rem;
    overflow-x: auto;
    max-width: 1000px;
  }
  .continuum-header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-left: 140px;
    margin-bottom: 1.1rem;
  }
  .continuum-body {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    min-width: 560px;
  }
  .continuum-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .continuum-brand {
    width: 116px;
    flex-shrink: 0;
    color: var(--green);
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .continuum-track-area {
    flex-grow: 1;
    position: relative;
    height: 34px;
  }
  .continuum-track-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-strong);
    transform: translateY(-50%);
  }
  .continuum-gridline {
    position: absolute;
    top: -6px;
    bottom: -6px;
    width: 1px;
    background: var(--border);
    opacity: 0.6;
  }
  .continuum-node {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .continuum-node-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
