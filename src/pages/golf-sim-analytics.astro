---
import BaseLayout from "../layouts/BaseLayout.astro";
import Screenshot from "../components/Screenshot.astro";
import JsonLd from "../components/JsonLd.astro";
import {
  LATEST_RELEASE_URL,
  PRODUCT_NAME,
  PRODUCT_OS,
  PRODUCT_PRICE,
  SITE_TAGLINE,
  SITE_URL,
} from "../consts";

const title = "Golf Sim Analytics";
const description = `${PRODUCT_NAME} is a free Windows app for GSPro — zero-click capture, 15 interactive dashboards, deep per-shot metrics, and PGA Tour benchmarks. Local-first and private.`;

// Signature capabilities — the "why it's different" strip.
const capabilities = [
  { label: "Zero-click capture", detail: "picked up from GSPro automatically" },
  { label: "Deep per-shot metrics", detail: "carry, ball, launch, spin, smash" },
  { label: "Tour & handicap benchmarks", detail: "one-click overlays, 5–20" },
  { label: "Local-first & private", detail: "your data never leaves your PC" },
];

// The six categories, each a killer feature with the dashboards folded in.
const dashboards = [
  {
    cat: "Metrics",
    stat: "6 dashboards",
    title: "Know every number",
    items: "Dispersion · Trajectory · Club Gapping · Swing Efficiency · Shot Quality · Shot & Club Trends",
  },
  {
    cat: "Optimization",
    stat: "3 dashboards",
    title: "Dial it in",
    items: "Launch & Spin · Session Comparison · Shot Shape",
  },
  {
    cat: "Club Fitting",
    stat: "A/B · live",
    title: "Test before you buy",
    items: "Compare shafts and adapter settings head-to-head with live shot capture, and let the dispersion decide.",
  },
  {
    cat: "Speed Training",
    stat: "3 views",
    title: "Find free speed",
    items: "Cruising speed · Fatigue curve · Long-term progression",
  },
  {
    cat: "On-Course",
    stat: "Automatic",
    title: "Every round, scored",
    items: "Scorecards build themselves from your rounds — no manual entry.",
  },
  {
    cat: "Live",
    stat: "Real-time",
    title: "Watch it happen",
    items: "A dispersion plot that updates shot by shot as you hit.",
  },
];

const steps = [
  { n: "01", title: "Export or play", body: "Hit export in GSPro's Practice Range, or just start a round." },
  { n: "02", title: "Auto-ingest", body: "The app detects GSPro's files the instant they appear and files everything into local Parquet." },
  { n: "03", title: "Explore dashboards", body: "Open any of the 15 dashboards, hover shots for full metrics, and drop in benchmarks." },
];

const softwareLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: PRODUCT_NAME,
  applicationCategory: "SportsApplication",
  operatingSystem: "Windows 10, Windows 11",
  softwareVersion: "latest",
  downloadUrl: LATEST_RELEASE_URL,
  url: `${SITE_URL}/golf-sim-analytics`,
  description,
  offers: { "@type": "Offer", price: PRODUCT_PRICE, priceCurrency: "USD" },
  publisher: { "@type": "Organization", name: "OpenGolfLab", url: SITE_URL },
};
---

<BaseLayout title={title} description={description}>
  <JsonLd slot="head" data={softwareLd} />

  <!-- ============================ HERO ============================ -->
  <section class="app-hero">
    <div class="grid-bg"></div>
    <div class="container app-hero-inner">
      <div class="app-hero-copy">
        <p class="eyebrow">The app · free for GSPro</p>
        <h1>Golf Sim Analytics</h1>
        <p class="app-hero-tagline">{SITE_TAGLINE}</p>
        <p class="lede" style="margin-top:1.1rem;">
          A free Windows app that turns every GSPro session into deep,
          interactive analytics — automatically. No imports, no accounts,
          nothing leaves your machine.
        </p>
        <div class="hero-cta">
          <a href={LATEST_RELEASE_URL} class="btn btn-primary btn-lg" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg
            >
            Download for Windows
          </a>
          <a href="/download" class="btn btn-secondary btn-lg">Install guide &amp; FAQ</a>
        </div>
        <div class="hero-chips" role="list" aria-label="Example shot readout">
          <span class="stat-chip" role="listitem"><span class="label">Smash</span><b>1.49</b></span>
          <span class="stat-chip" role="listitem"><span class="label">Carry</span><b>285</b> yd</span>
          <span class="stat-chip" role="listitem"><span class="label">Ball</span><b>167</b> mph</span>
          <span class="stat-chip" role="listitem"><span class="label">Spin</span><b>2,610</b> rpm</span>
        </div>
        <p class="app-free-note">Free forever · {PRODUCT_OS} · No account required</p>
      </div>
    </div>
  </section>

  <section class="container app-hero-shot">
    <Screenshot
      src="/images/screenshots/home.jpg"
      alt="Golf Sim Analytics home dashboard showing a session summary with carry distances, a dispersion plot, and per-club metrics."
      loading="eager"
      width={2000}
      height={1194}
      caption="The home dashboard — a live readout of your latest session."
    />
  </section>

  <!-- ========================= WHY ========================= -->
  <section class="section" style="padding-bottom:0;">
    <div class="container">
      <p class="eyebrow">Why it exists</p>
      <h2 class="app-why-h">GSPro shows you the shot. It doesn't remember it.</h2>

      <!-- Signature capabilities strip -->
      <ul class="caps">
        {
          capabilities.map((c) => (
            <li class="cap">
              <span class="cap-dot" aria-hidden="true"></span>
              <span class="cap-label">{c.label}</span>
              <span class="cap-detail">{c.detail}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ==================== DASHBOARDS (killer tiles) ==================== -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">What you get</p>
      <h2>15 dashboards across six areas</h2>
      <p class="lede" style="margin-top:0.75rem;max-width:60ch;">
        Every angle on your ball flight — grouped so you can go from a glance to
        a deep dive.
      </p>

      <div class="dash-grid">
        {
          dashboards.map((d) => (
            <article class="card dash">
              <div class="dash-top">
                <span class="dash-cat">{d.cat}</span>
                <span class="dash-stat tnum">{d.stat}</span>
              </div>
              <h3>{d.title}</h3>
              <p class="text-muted">{d.items}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= SCREENSHOTS ======================= -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">A look inside</p>
      <h2>Data-forward on every screen</h2>
      <div class="screens-grid">
        <Screenshot
          src="/images/screenshots/dispersion.jpg"
          alt="Dispersion dashboard plotting shot landing positions with left-right and carry scatter, colored by club, against an ideal target ellipse."
          width={2000}
          height={1194}
          caption="Carry 105 yd · Spin 9,451 rpm · Smash 0.95"
        />
        <Screenshot
          src="/images/screenshots/gapping_benchmarks.jpg"
          alt="Club gapping chart with carry-distance bars for each club overlaid with PGA Tour benchmark markers to reveal distance gaps."
          width={2000}
          height={1194}
          caption="Gap to 5i: +17 yd"
        />
        <Screenshot
          src="/images/screenshots/trajectory.jpg"
          alt="Trajectory dashboard showing flight paths for every club with launch angle, peak height, and descent angle box plots flagged against ideal windows."
          width={2000}
          height={1194}
          caption="Wedges arc past 150 ft; the driver stays flatter, peaking under 100."
        />
      </div>
    </div>
  </section>

  <!-- ======================= HOW IT WORKS ======================= -->
  <section class="section how" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">How it works</p>
      <h2>Three steps, and two of them are just playing golf</h2>
      <ol class="steps">
        {
          steps.map((s) => (
            <li class="step card">
              <span class="step-n tnum">{s.n}</span>
              <h3>{s.title}</h3>
              <p class="text-muted">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===================== PART OF SOMETHING BIGGER ===================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="app-lab card">
        <div class="grid-bg" style="opacity:0.5"></div>
        <div class="app-lab-inner">
          <p class="eyebrow">Part of the bigger picture</p>
          <h2>A practice tool that can also be a research instrument</h2>
          <p class="lede" style="margin-top:0.75rem;">
            Capture your shots for yourself — and, if you choose to, help build
            the open equipment data taking shape in <a href="/lab">the Lab</a>.
          </p>
          <div class="hero-cta">
            <a href="/lab" class="btn btn-secondary">See the mission</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= FINAL CTA ========================= -->
  <section class="section-tight">
    <div class="container final-cta">
      <h2>Start with your very next session</h2>
      <p class="lede mx-auto" style="margin-top:0.6rem;">
        Free, private, and Windows-ready. Install it, play, and watch your
        numbers show up.
      </p>
      <div class="hero-cta" style="justify-content:center;">
        <a href={LATEST_RELEASE_URL} class="btn btn-primary btn-lg" rel="noopener">Download for Windows</a>
        <a href="/download" class="btn btn-secondary btn-lg">System requirements</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .app-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: radial-gradient(110% 90% at 20% -10%, var(--green-tint), transparent 60%);
  }
  .app-hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(2.25rem, 6vw, 4rem) clamp(1.5rem, 4vw, 2.75rem);
  }
  .app-hero-copy {
    max-width: 62ch;
  }
  .app-hero-tagline {
    margin-top: 0.6rem;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--green);
    letter-spacing: 0.02em;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.6rem;
  }
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.6rem;
  }
  .app-free-note {
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .app-hero-shot {
    margin-top: -1.5rem;
    position: relative;
    z-index: 2;
  }
  .app-why-h {
    max-width: 20ch;
  }

  /* Capabilities strip */
  .caps {
    margin-top: 2rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .cap {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .cap-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--green);
    margin-bottom: 0.5rem;
  }
  .cap-label {
    font-family: var(--font-head);
    font-weight: 600;
    color: var(--text);
    font-size: 1rem;
  }
  .cap-detail {
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  /* Dashboard tiles */
  .dash-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .dash {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .dash:hover {
    border-color: var(--green-dim);
    transform: translateY(-2px);
  }
  .dash-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }
  .dash-cat {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green);
    font-weight: 600;
  }
  .dash-stat {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    white-space: nowrap;
  }
  .dash h3 {
    font-size: 1.2rem;
  }

  .screens-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  .steps {
    margin-top: 2rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .step-n {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .step h3 {
    margin-top: 0.6rem;
    font-size: 1.2rem;
  }
  .step p {
    margin-top: 0.4rem;
  }

  .app-lab {
    position: relative;
    overflow: hidden;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .app-lab-inner {
    position: relative;
    z-index: 1;
    max-width: 62ch;
  }

  .final-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 900px) {
    .caps {
      grid-template-columns: repeat(2, 1fr);
    }
    .dash-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .steps {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 680px) {
    .caps,
    .dash-grid,
    .screens-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
