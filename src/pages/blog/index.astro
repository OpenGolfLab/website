---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";

const title = "Blog";
const description =
  "Updates from OpenGolfLab, releases, deep dives on simulator analytics, and progress on the community data Lab.";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Category filter bar, only show categories that actually have posts.
const ORDER = ["Research", "Product", "Guides", "Updates"] as const;
const present = ORDER.filter((c) => posts.some((p) => p.data.category === c));
const filters = ["All", ...present];
---

<BaseLayout title={title} description={description}>
  <section class="section-tight blog-hero">
    <div class="grid-bg"></div>
    <div class="container blog-hero-inner">
      <p class="eyebrow">Field notes</p>
      <h1>The OpenGolfLab blog</h1>
      <p class="lede" style="margin-top:0.9rem;">
        Release notes, analytics deep dives, and progress on the open community
        Lab. Prefer a reader? <a href="/rss.xml">Grab the RSS feed.</a>
      </p>
    </div>
  </section>

  <div class="container blog-body">
    {
      posts.length === 0 ? (
        <p class="text-muted">No posts yet, check back soon.</p>
      ) : (
        <>
          <div class="filter-bar" role="group" aria-label="Filter posts by category">
            {filters.map((f, i) => (
              <button
                class:list={["filter-btn", { active: i === 0 }]}
                data-filter={f}
                type="button"
                aria-pressed={i === 0 ? "true" : "false"}
              >
                {f}
              </button>
            ))}
          </div>

          <ul class="post-list" id="post-list">
            {posts.map((post) => (
              <li data-category={post.data.category}>
                <a href={`/blog/${post.id}/`} class="post-card card">
                  <div class="post-meta">
                    <span class:list={["pill", "cat", `cat-${post.data.category}`]}>
                      {post.data.category}
                    </span>
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <h3>{post.data.title}</h3>
                  <p class="text-muted">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="post-card-tags">
                      {post.data.tags.map((t) => (
                        <span class="pill">#{t}</span>
                      ))}
                    </div>
                  )}
                </a>
              </li>
            ))}
          </ul>

          <p class="no-match text-muted" hidden>No posts in this category yet.</p>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  // Minimal client-side category filter (no framework).
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items = document.querySelectorAll<HTMLLIElement>("#post-list > li");
  const empty = document.querySelector<HTMLParagraphElement>(".no-match");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle("active", on);
        b.setAttribute("aria-pressed", String(on));
      });
      let shown = 0;
      items.forEach((li) => {
        const match = filter === "All" || li.dataset.category === filter;
        li.hidden = !match;
        if (match) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    });
  });
</script>

<style>
  .blog-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .blog-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 60ch;
    padding-block: clamp(2.5rem, 6vw, 3.5rem);
  }
  .blog-body {
    padding-block: clamp(2.5rem, 6vw, 3.5rem);
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition: color 0.15s var(--ease), border-color 0.15s var(--ease),
      background 0.15s var(--ease);
  }
  .filter-btn:hover {
    color: var(--text);
    border-color: var(--green-dim);
  }
  .filter-btn.active {
    color: var(--green-ink);
    background: var(--green);
    border-color: var(--green);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  /* Category pill colors */
  .cat {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
  }
  .cat-Research {
    color: var(--green);
    border-color: var(--green-dim);
  }
  .cat-Product {
    color: var(--cyan);
    border-color: rgba(79, 214, 224, 0.35);
  }
  .cat-Guides {
    color: var(--amber);
    border-color: rgba(255, 207, 92, 0.35);
  }
  .cat-Updates {
    color: var(--violet);
    border-color: rgba(185, 140, 255, 0.35);
  }

  /* List */
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.1rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    height: 100%;
    color: inherit;
  }
  .post-card:hover {
    border-color: var(--green-dim);
  }
  .post-card h3 {
    font-size: 1.25rem;
  }
  .post-card-tags {
    margin-top: auto;
    padding-top: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  @media (max-width: 780px) {
    .post-list {
      grid-template-columns: 1fr;
    }
  }
</style>
