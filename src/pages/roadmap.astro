---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GITHUB_URL } from "../consts";

const title = "Roadmap";
const description =
  "What's shipped, what's being built, and what's planned for OpenGolfLab and Golf Sim Analytics — an honest, public list with no dates attached.";

// Deliberately no dates. This is a free project built in spare time; a missed
// date is a broken promise, an ordered list is not.
type Item = { name: string; detail: string; where: string };
type Group = {
  key: string;
  mark: string;
  label: string;
  blurb: string;
  items: Item[];
};

const groups: Group[] = [
  {
    key: "shipped",
    mark: "✓",
    label: "Shipped",
    blurb: "Live today. Go use it.",
    items: [
      {
        name: "Golf Sim Analytics",
        detail:
          "The free Windows app: automatic GSPro capture, 15 dashboards across six categories, everything stored locally. No import step, ever.",
        where: "App",
      },
      {
        name: "Live shot tracking",
        detail:
          "Dispersion, club speed and personal-best alerts update as you hit, straight off the GSPro range feed.",
        where: "App",
      },
      {
        name: "Driver lineup spectrum",
        detail:
          "Every major 2026 driver mapped from maximum forgiveness to pure distance, brand by brand.",
        where: "Lab · Market",
      },
      {
        name: "Market pricing",
        detail:
          "Street price against MSRP for every driver in the lineup, with the dealer named and no commission taken.",
        where: "Lab · Market",
      },
      {
        name: "Golf balls in Market Data",
        detail:
          "Every major ball mapped from soft-and-straight to max tour spin — construction, compression, and per-dozen street pricing, same treatment as the drivers.",
        where: "Lab · Market",
      },
      {
        name: "Contribution pipeline",
        detail:
          "Consent-gated, anonymized export from the app through to aggregation — schema v1.1, quality control, and per-contributor summaries.",
        where: "Lab · Community",
      },
    ],
  },
  {
    key: "building",
    mark: "◐",
    label: "Building now",
    blurb: "Actively in progress — the next thing you'll see change.",
    items: [
      {
        name: "The first community dataset",
        detail:
          "Everything upstream is built and tested. What's left is contributors: no club publishes until enough golfers have submitted it, so the numbers are worth reading on day one.",
        where: "Lab · Community",
      },
    ],
  },
  {
    key: "next",
    mark: "○",
    label: "Planned",
    blurb: "Committed to, in roughly this order, once the dataset supports it.",
    items: [
      {
        name: "Ball comparisons",
        detail:
          "What a premium ball actually does for your game, measured across thousands of real shots rather than a robot and a marketing budget. The question that started this project.",
        where: "Lab · Community",
      },
      {
        name: "Gapping by handicap",
        detail:
          "What real distance gaps look like at your level, so you can tell a genuine hole in your set from a magazine number.",
        where: "Lab · Community",
      },
      {
        name: "Norms by swing speed band",
        detail:
          "Launch, spin, and dispersion norms sliced by driver speed as well as handicap — a 95 mph twelve and a 108 mph twelve need different answers, and one number can't serve both.",
        where: "Lab · Community",
      },
      {
        name: "Club model & year in the schema",
        detail:
          "An optional club make/model/year field in contributions, so the Lab can eventually answer \"what does a 2020 driver actually give up to a 2026?\" with real golfers instead of robots.",
        where: "Lab · Community",
      },
      {
        name: "Irons in Market Data",
        detail:
          "Player's through game-improvement lineups on a forgiveness-to-workability spectrum, with lofts called out.",
        where: "Lab · Market",
      },
    ],
  },
  {
    key: "exploring",
    mark: "·",
    label: "Exploring",
    blurb:
      "Ideas we like that aren't committed. Tell us if one of these matters to you — that's how it moves up.",
    items: [
      {
        name: "Handicap tracking",
        detail:
          "Needs a round-and-scoring data model the app doesn't have yet. A real project in its own right, not a weekend feature.",
        where: "App",
      },
      {
        name: "Voice caddy",
        detail:
          "Spoken feedback between shots so you can keep your head up. Parked — it means taking on a speech dependency, and we'd want it to earn that.",
        where: "App",
      },
    ],
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-tight road-hero">
    <div class="grid-bg"></div>
    <div class="container road-hero-inner">
      <span class="pill road-pill">Updated continuously</span>
      <h1>Roadmap</h1>
      <p class="lede" style="margin-top:1rem;">
        Everything OpenGolfLab has shipped, is building, and intends to build —
        in one honest list. No dates: this is a free project built in spare
        time, and a missed date is a broken promise. Order is a real signal;
        timing isn't.
      </p>
      <div class="hero-cta" style="margin-top:1.6rem;">
        <a href="/download" class="btn btn-primary">Get the app</a>
        <a href={GITHUB_URL} class="btn btn-secondary" rel="noopener">
          Request a feature
        </a>
      </div>
    </div>
  </section>

  <div class="container road-body">
    {
      groups.map((g) => (
        <section class:list={["road-group", `is-${g.key}`]}>
          <div class="road-group-head">
            <h2>
              <span class="road-mark" aria-hidden="true">{g.mark}</span>
              {g.label}
            </h2>
            <p class="text-muted">{g.blurb}</p>
          </div>

          <ul class="road-list">
            {g.items.map((item) => (
              <li class="road-item">
                <div class="road-item-head">
                  <h3>{item.name}</h3>
                  <span class="road-where">{item.where}</span>
                </div>
                <p>{item.detail}</p>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    <section class="card road-cta">
      <h2>Something missing?</h2>
      <p class="text-muted" style="margin-top:0.5rem;max-width:56ch;">
        This list is shaped by what people actually ask for. Open an issue on
        GitHub — feature requests, schema arguments and privacy scrutiny are all
        equally welcome.
      </p>
      <div class="hero-cta" style="margin-top:1.2rem;">
        <a href={GITHUB_URL} class="btn btn-primary" rel="noopener">
          Open on GitHub
        </a>
        <a href="/blog" class="btn btn-secondary">Follow the blog</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .road-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: radial-gradient(
      120% 90% at 50% -20%,
      var(--green-tint),
      transparent 60%
    );
  }
  .road-hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(2rem, 5vw, 3rem);
    max-width: 64ch;
  }
  .road-pill {
    color: var(--green);
    border-color: var(--green-dim);
    margin-bottom: 1rem;
  }

  .road-body {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 6vw, 4rem);
    padding-block: clamp(2rem, 5vw, 3rem);
  }

  .road-group-head {
    margin-bottom: 1.5rem;
  }
  .road-group-head h2 {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.4rem;
  }
  .road-group-head p {
    font-size: 0.95rem;
  }
  .road-mark {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .is-shipped .road-mark {
    color: var(--green);
  }
  .is-building .road-mark {
    color: var(--amber);
  }
  .is-next .road-mark,
  .is-exploring .road-mark {
    color: var(--text-dim);
  }

  .road-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0;
    border-top: 1px solid var(--border);
  }
  .road-item {
    border-bottom: 1px solid var(--border);
    border-left: 2px solid transparent;
    padding: 1.1rem 1.25rem;
    background: var(--surface);
    transition: border-color 0.2s var(--ease);
  }
  .is-shipped .road-item {
    border-left-color: var(--green-dim);
  }
  .is-building .road-item {
    border-left-color: var(--amber);
  }
  .is-next .road-item {
    background: var(--bg-elevated);
  }
  .is-exploring .road-item {
    background: transparent;
    border-left-style: dashed;
    border-left-color: var(--border-strong);
  }
  .road-item-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }
  .road-item h3 {
    font-size: 1.05rem;
  }
  .is-next .road-item h3,
  .is-exploring .road-item h3 {
    color: var(--text-muted);
  }
  .road-where {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
  }
  .road-item p {
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .road-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
</style>
