---
import BaseLayout from "../layouts/BaseLayout.astro";
import GearNav from "../components/GearNav.astro";
import PriceChart from "../components/PriceChart.astro";
import QuadrantMap from "../components/QuadrantMap.astro";
import MobileLineupList from "../components/MobileLineupList.astro";
import {
  loadMarket,
  loadBallMarket,
  loadIronMarket,
  loadWedgeMarket,
} from "../lib/lab";
import "../styles/lab.css";

const title = "Gear Guide";
const description =
  "What clubs and balls exist, what they're designed to do, and what they actually cost today. Every 2026 driver mapped from forgiveness to distance, every iron and wedge mapped by head type and real lofts, and every ball mapped by spin and compression, with street prices for the whole bag. Independently researched gear snapshots from OpenGolfLab.";

const {
  hasLineups,
  modelCount,
  brandCount,
  medianPrice,
  biggestDiscount,
  axisMaxRounded,
  axisTicks,
  pricingLineups,
  spectrumLineups,
} = loadMarket();

const balls = loadBallMarket();
const irons = loadIronMarket();
const wedges = loadWedgeMarket();

// ---- Shared quadrant-map label layout --------------------------------------
// Hurricane-chart style: every dot carries its full label, placed on a fixed
// grid of rows so the result reads as tidy stacks rather than scatter. A
// label may sit far from its dot, whitespace is found by sliding sideways
// first, then hopping rows, and anything not directly beside its dot gets a
// leader line back to it. Labels never overlap each other, a dot, a quadrant
// caption, or the plot edges; distance is sacrificed instead.
function placeQuadrantLabels(
  dots: any[],
  qcaps: any[],
  W: number,
  H: number,
  PAD: any,
) {
  const CHAR_W = 7.8; // ~14px font
  const ROW_H = 18; // label row pitch
  const boxes: any[] = dots.map((d: any) => ({
    x1: d.x - 8, y1: d.y - 8, x2: d.x + 8, y2: d.y + 8,
  }));
  for (const c of qcaps) {
    const w = c.t.length * 8.5;
    boxes.push({
      x1: (c.a === "start" ? c.x : c.x - w) - 4,
      y1: c.y - 16,
      x2: (c.a === "start" ? c.x + w : c.x) + 4,
      y2: c.y + 5,
    });
  }
  const hits = (a: any) =>
    boxes.some(
      (b) => a.x1 < b.x2 + 3 && b.x1 < a.x2 + 3 && a.y1 < b.y2 + 2 && b.y1 < a.y2 + 2,
    );

  // Leader-line hygiene: two leaders crossing, or a leader slicing through
  // unrelated dots, is what makes a labeled scatter read as spaghetti, both
  // get scored as heavy penalties below.
  const placedLeads: any[] = [];
  const orient = (ax: number, ay: number, bx: number, by: number, cx: number, cy: number) =>
    Math.sign((bx - ax) * (cy - ay) - (by - ay) * (cx - ax));
  const segsCross = (p: any, q: any) => {
    const o1 = orient(p.x1, p.y1, p.x2, p.y2, q.x1, q.y1);
    const o2 = orient(p.x1, p.y1, p.x2, p.y2, q.x2, q.y2);
    const o3 = orient(q.x1, q.y1, q.x2, q.y2, p.x1, p.y1);
    const o4 = orient(q.x1, q.y1, q.x2, q.y2, p.x2, p.y2);
    return o1 !== o2 && o3 !== o4 && o1 !== 0 && o2 !== 0 && o3 !== 0 && o4 !== 0;
  };
  const pointSegDist = (px: number, py: number, s: any) => {
    const dx = s.x2 - s.x1;
    const dy = s.y2 - s.y1;
    const len2 = dx * dx + dy * dy;
    const t = len2 === 0 ? 0 : Math.max(0, Math.min(1, ((px - s.x1) * dx + (py - s.y1) * dy) / len2));
    return Math.hypot(px - (s.x1 + t * dx), py - (s.y1 + t * dy));
  };

  // Candidate slots: every label row × outward horizontal offsets from the
  // dot. Scored by leader length (vertical travel penalized so labels prefer
  // drifting sideways into open space) plus the hygiene penalties.
  const rowYs: number[] = [];
  for (let y = PAD.t + 34; y <= H - PAD.b - 8; y += ROW_H) rowYs.push(y);
  const DISTS = [14, 34, 62, 98, 142, 194, 254, 322, 400];
  const xMidPlot = (PAD.l + W - PAD.r) / 2;

  const findSlot = (d: any, exclude: number) => {
    const w = d.label.length * CHAR_W;
    // Point labels toward the plot's horizontal center first, on these
    // diagonal-band maps that's where the open quadrants are.
    const sides = d.x < xMidPlot ? [1, -1] : [-1, 1];
    let pick: any = null;
    let bestScore = Infinity;
    for (const row of rowYs) {
      const dy = Math.abs(row - d.y);
      if (dy * 2.2 >= bestScore) continue;
      for (const dist of DISTS) {
        const base = dist + dy * 2.2;
        if (base >= bestScore) break;
        for (const side of sides) {
          const ax = d.x + dist * side;
          const x1 = side > 0 ? ax : ax - w;
          const x2 = x1 + w;
          if (x1 < PAD.l + 2 || x2 > W - PAD.r - 2) continue;
          const box = { x1: x1 - 2, y1: row - 13, x2: x2 + 2, y2: row + 4 };
          if (hits(box)) continue;
          // Leader for this candidate: dot → closest point on the box.
          const lx = Math.min(Math.max(d.x, box.x1), box.x2);
          const ly = Math.min(Math.max(d.y, box.y1), box.y2);
          const seg = { x1: d.x, y1: d.y, x2: lx, y2: ly };
          let penalty = 0;
          for (let k = 0; k < placedLeads.length; k++) {
            if (k !== exclude && placedLeads[k] && segsCross(seg, placedLeads[k])) penalty += 550;
          }
          for (const o of dots) {
            if (o === d) continue;
            if (pointSegDist(o.x, o.y, seg) < 8) penalty += 90;
          }
          const score = base + penalty;
          if (score < bestScore) {
            pick = { ax, row, anchor: side > 0 ? "start" : "end", box, seg, score };
            bestScore = score;
          }
        }
      }
    }
    // Fallback (dense beyond saving): sit right of the dot regardless.
    if (!pick) {
      const ax = d.x + 12;
      const box = { x1: ax - 2, y1: d.y - 9, x2: ax + w + 2, y2: d.y + 8 };
      pick = { ax, row: d.y + 4, anchor: "start", box, seg: { x1: d.x, y1: d.y, x2: ax, y2: d.y }, score: 0 };
    }
    return pick;
  };

  // First pass: place top-to-bottom. The label boxes join the obstacle list
  // as they land, so `hits` sees them via `boxes`.
  const ordered = [...dots].sort((a: any, b: any) => a.y - b.y || a.x - b.x);
  const picks: any[] = [];
  for (const d of ordered) {
    const pick = findSlot(d, -1);
    boxes.push(pick.box);
    placedLeads.push(pick.seg);
    picks.push(pick);
  }

  // Refinement: early labels were placed blind to later ones, so rip each
  // one out (longest leaders first) and re-place it with the full picture,
  // this is what untangles crossing leaders in the dense clusters.
  const nDots = ordered.length;
  const boxIndexOffset = boxes.length - nDots;
  for (let iter = 0; iter < 8; iter++) {
    const order = picks
      .map((p: any, i: number) => ({ i, len: Math.hypot(p.seg.x2 - p.seg.x1, p.seg.y2 - p.seg.y1) }))
      .sort((a, b) => b.len - a.len);
    for (const { i } of order) {
      const d = ordered[i];
      boxes[boxIndexOffset + i] = { x1: -99, y1: -99, x2: -98, y2: -98 };
      placedLeads[i] = null;
      const pick = findSlot(d, i);
      boxes[boxIndexOffset + i] = pick.box;
      placedLeads[i] = pick.seg;
      picks[i] = pick;
    }
  }

  return ordered.map((d: any, i: number) => {
    const pick = picks[i];
    const far = Math.hypot(pick.seg.x2 - d.x, pick.seg.y2 - d.y) > 11;
    return {
      ...d,
      lbl: { dx: pick.ax - d.x, dy: pick.row - d.y, anchor: pick.anchor },
      far,
      leadX: pick.seg.x2,
      leadY: pick.seg.y2,
    };
  });
}

// ---- Edge-column label layout ---------------------------------------------
// Reference-chart style: instead of floating each label near its dot, every
// label is parked in a tidy vertical column in the margin, the left gutter
// for dots left of centre, the right gutter for dots right of centre, and
// tied back to its dot with a single straight leader.
//
// Each column owns a fixed ladder of label slots (sorted by the dots' heights,
// then spread just far enough apart to never touch). Which dot lands in which
// slot is then decided by a crossing-minimising pass: starting from height
// order, adjacent slots trade dots whenever the swap removes more leader
// crossings than it adds. That untangles the fans that appear wherever several
// dots share a height (common on the iron map, where many sets share a loft)
// without any hand-tuned tie-break rule.
function placeColumnLabels(
  dots: any[],
  W: number,
  H: number,
  PAD: any,
  splitX: number,
) {
  const ROW_H = 18; // vertical pitch between stacked labels (label glyphs ~17px)
  const GAP = 8; // gutter breathing room between label text and plot edge
  const topY = PAD.t + 14;
  const botY = H - PAD.b - 4;
  const leftEdge = PAD.l; // right edge of the left-hand label column
  const rightEdge = W - PAD.r; // left edge of the right-hand label column

  // Proper segment crossing (shared endpoints don't count, leaders never
  // share one anyway, since dots and slots are all distinct).
  const orient = (ax: number, ay: number, bx: number, by: number, cx: number, cy: number) =>
    Math.sign((bx - ax) * (cy - ay) - (by - ay) * (cx - ax));
  const segsCross = (p: any, q: any) => {
    const o1 = orient(p.x1, p.y1, p.x2, p.y2, q.x1, q.y1);
    const o2 = orient(p.x1, p.y1, p.x2, p.y2, q.x2, q.y2);
    const o3 = orient(q.x1, q.y1, q.x2, q.y2, p.x1, p.y1);
    const o4 = orient(q.x1, q.y1, q.x2, q.y2, p.x2, p.y2);
    return o1 !== o2 && o3 !== o4 && o1 !== 0 && o2 !== 0 && o3 !== 0 && o4 !== 0;
  };

  const layoutSide = (side: any[], edgeX: number) => {
    // Slot ladder: targets are the dots' own heights, relaxed so no two labels
    // sit closer than ROW_H (down-sweep, then up-sweep off the bottom, then a
    // top clamp).
    const slots = side
      .map((d: any) => d.y)
      .sort((a: number, b: number) => a - b);
    for (let i = 1; i < slots.length; i++) {
      if (slots[i] < slots[i - 1] + ROW_H) slots[i] = slots[i - 1] + ROW_H;
    }
    for (let i = slots.length - 1; i >= 0; i--) {
      const maxY = i === slots.length - 1 ? botY : slots[i + 1] - ROW_H;
      if (slots[i] > maxY) slots[i] = maxY;
    }
    for (let i = 0; i < slots.length; i++) {
      const minY = i === 0 ? topY : slots[i - 1] + ROW_H;
      if (slots[i] < minY) slots[i] = minY;
    }

    // Assign dots to slots, starting in height order, then untangle by trading
    // dots between adjacent slots whenever it nets out fewer crossings.
    const assign = side
      .slice()
      .sort((a: any, b: any) => a.y - b.y)
      .map((d: any, i: number) => ({ d, sy: slots[i] }));
    const seg = (a: any) => ({ x1: edgeX, y1: a.sy, x2: a.d.x, y2: a.d.y });
    const involve = (k: number) => {
      let c = 0;
      for (let m = 0; m < assign.length; m++) {
        if (m !== k && segsCross(seg(assign[k]), seg(assign[m]))) c++;
      }
      return c;
    };
    // A dot may only move a few slots from its height-sorted position, so the
    // label stays near its dot; within that window any improving trade is
    // taken. The small window is enough to untangle the same-height fans while
    // keeping leaders short.
    const WIN = 6;
    for (let pass = 0; pass < 60; pass++) {
      let improved = false;
      for (let k = 0; k < assign.length - 1; k++) {
        for (let j = k + 1; j <= Math.min(k + WIN, assign.length - 1); j++) {
          const adj = segsCross(seg(assign[k]), seg(assign[j])) ? 1 : 0;
          const before = involve(k) + involve(j) - adj;
          const t = assign[k].d;
          assign[k].d = assign[j].d;
          assign[j].d = t;
          const adj2 = segsCross(seg(assign[k]), seg(assign[j])) ? 1 : 0;
          const after = involve(k) + involve(j) - adj2;
          if (after < before) improved = true;
          else {
            const t2 = assign[k].d;
            assign[k].d = assign[j].d;
            assign[j].d = t2;
          }
        }
      }
      if (!improved) break;
    }
    return assign;
  };

  const out: any[] = [];
  for (const it of layoutSide(dots.filter((d: any) => d.x < splitX), leftEdge - GAP)) {
    out.push({
      ...it.d,
      lblX: leftEdge - GAP,
      lblY: it.sy + 4,
      anchor: "end",
      leadX: leftEdge - GAP,
      leadY: it.sy,
    });
  }
  for (const it of layoutSide(dots.filter((d: any) => d.x >= splitX), rightEdge + GAP)) {
    out.push({
      ...it.d,
      lblX: rightEdge + GAP,
      lblY: it.sy + 4,
      anchor: "start",
      leadX: rightEdge + GAP,
      leadY: it.sy,
    });
  }
  return out;
}

// ---- Ball quadrant map ----------------------------------------------------
// One plot that carries the whole buying decision:
//   x, spin, decreasing left → right (spectrum position, reversed)
//   y, compression, increasing bottom → top
// So the firm, low-spin distance balls land top-right and the soft,
// straight-flying swing-saver balls land bottom-right.
const ballMap = (() => {
  if (!balls.hasLineups) return null;
  const W = 960;
  const H = 858;
  // Wide left/right pads carve out the two label gutters; the tall bottom pad
  // reserves a clear band below the plot for the lower quadrant captions.
  const PAD = { l: 220, r: 228, t: 30, b: 84 };
  const pw = W - PAD.l - PAD.r;
  const ph = H - PAD.t - PAD.b;

  const pts = balls.spectrumLineups.flatMap((l: any) =>
    l.models.map((m: any) => ({ ...m, brand: l.brand })),
  );
  const comps = pts.map((p: any) => p.compression);
  const cMin = Math.min(...comps) - 5;
  const cMax = Math.max(...comps) + 5;
  const X_MID = 50; // spectrum position that splits low spin from tour spin
  const Y_MID = 75; // compression above which a ball plays firm / fast-swing

  const toX = (pos: number) => PAD.l + ((100 - pos) / 100) * pw;
  // Piecewise y-scale: most balls crowd the firm (high-compression) band, so
  // the region above Y_MID gets more than its linear share of the height.
  const TOP_FRAC = 0.6;
  const topPh = ph * TOP_FRAC;
  const toY = (comp: number) =>
    comp >= Y_MID
      ? PAD.t + ((cMax - comp) / (cMax - Y_MID)) * topPh
      : PAD.t + topPh + ((Y_MID - comp) / (Y_MID - cMin)) * (ph - topPh);

  // Full names: every label carries its brand so any ball is recognizable on
  // its own (unless the model name already starts with the brand).
  const dots = pts.map((p: any) => ({
    ...p,
    x: toX(p.position),
    y: toY(p.compression),
    premium: /urethane/i.test(p.construction),
    cls: /urethane/i.test(p.construction) ? "premium" : "value",
    title: `${p.brand} ${p.name}, ${p.construction}, compression ~${p.compression}, $${p.price}/dz`,
    label: p.name.toLowerCase().startsWith(p.brand.toLowerCase())
      ? p.name
      : `${p.brand} ${p.name}`,
  }));

  const qcaps = [
    { t: "Fast swing, tour spin", a: "start", x: PAD.l + 10, y: PAD.t + 18 },
    { t: "Fast swing, low spin", a: "end", x: W - PAD.r - 10, y: PAD.t + 18 },
    { t: "Slower swing, soft with spin", a: "start", x: PAD.l + 10, y: H - PAD.b + 34 },
    { t: "Slower swing, straight and soft", a: "end", x: W - PAD.r - 10, y: H - PAD.b + 34 },
  ];
  const labeled = placeColumnLabels(dots, W, H, PAD, toX(X_MID));

  return {
    W, H, PAD,
    xMid: toX(X_MID),
    yMid: toY(Y_MID),
    right: W - PAD.r,
    bottom: H - PAD.b,
    dots: labeled,
    qcaps,
  };
})();

// "Find yourself on the map", each player profile points at the region of
// the map they should shop, matching the quadrant captions on the plot.
const ballProfiles = [
  {
    tag: "105+ mph driver",
    title: "The speed player",
    body: "You compress everything. A firm tour ball turns that speed into carry and still bites on the greens.",
    quadrant: "↖ Shop the top-left: fast swing, tour spin",
  },
  {
    tag: "Fast, but ballooning",
    title: "The spin fighter",
    body: "Plenty of speed, too much height and curve. Firm and low-spin flattens the flight and buys roll.",
    quadrant: "↗ Shop the top-right: fast swing, low spin",
  },
  {
    tag: "85–105 mph driver",
    title: "The all-rounder",
    body: "Most golfers. Mid-compression urethane near the middle of the map keeps greenside spin without costing ball speed.",
    quadrant: "◎ Shop the center, either side of the crosshair",
  },
  {
    tag: "Under 85 mph · seniors · slice fighters",
    title: "The smooth swinger",
    body: "Soft, low-spin balls launch higher, curve less, and feel better at lower speeds, less backspin means less sidespin too.",
    quadrant: "↘ Shop the bottom-right: slower swing, straight and soft",
  },
];

// ---- Iron quadrant map ------------------------------------------------------
// One plot that carries the whole buying decision:
//   x, head design, max forgiveness left → compact precision right
//   y, stamped 7-iron loft, stronger (more built-in distance) toward the top
// So the juiced game-improvement sets land top-left, hollow-body players
// distance irons top-right, blades and traditional cavity backs bottom-right,
// and the honest-lofted launch helpers bottom-left.
const IRON_CATS: Record<string, { label: string; cls: string; blurb: string }> = {
  "blade": {
    label: "Muscle back / blade",
    cls: "cat-blade",
    blurb: "pure feel and workability, zero help",
  },
  "players-cb": {
    label: "Players cavity back",
    cls: "cat-pcb",
    blurb: "feel first, with a small safety net",
  },
  "players-distance": {
    label: "Players distance",
    cls: "cat-pd",
    blurb: "compact head hiding a hot face",
  },
  "game-improvement": {
    label: "Game improvement",
    cls: "cat-gi",
    blurb: "distance and help for most golfers",
  },
  "max-gi": {
    label: "Max game improvement",
    cls: "cat-sgi",
    blurb: "everything aimed at forgiveness",
  },
};

const ironMap = (() => {
  if (!irons.hasLineups) return null;
  const W = 960;
  const H = 985;
  // Wide left/right pads carve out the two label gutters; the tall bottom pad
  // reserves a clear band below the plot for the lower quadrant captions.
  const PAD = { l: 235, r: 192, t: 30, b: 91 };
  const pw = W - PAD.l - PAD.r;
  const ph = H - PAD.t - PAD.b;

  const pts = irons.spectrumLineups.flatMap((l: any) =>
    l.models.map((m: any) => ({ ...m, brand: l.brand })),
  );
  const X_MID = 45; // spectrum position separating help-first from precision-first heads
  const Y_MID = 30.75; // 7-iron loft splitting juiced lofts (above) from traditional (below)
  const L_MIN = 26.5;
  const L_MAX = 35.5;

  // Piecewise x-scale: the game-improvement half of the market is crowded, so
  // the region left of X_MID gets more than its linear share of the width.
  const LEFT_FRAC = 0.55;
  const leftPw = pw * LEFT_FRAC;
  const toX = (pos: number) =>
    pos <= X_MID
      ? PAD.l + (pos / X_MID) * leftPw
      : PAD.l + leftPw + ((pos - X_MID) / (100 - X_MID)) * (pw - leftPw);
  // Stronger (numerically lower) loft = more built-in distance = higher up.
  const toY = (loft: number) => PAD.t + ((loft - L_MIN) / (L_MAX - L_MIN)) * ph;

  // Full names: every label carries its brand so any set is recognizable on
  // its own (unless the model name already starts with the brand).
  const dots = pts.map((p: any) => ({
    ...p,
    x: toX(p.position),
    y: toY(p.loft7),
    cls: IRON_CATS[p.category]?.cls ?? "cat-gi",
    title: `${p.brand} ${p.name}, ${IRON_CATS[p.category]?.label ?? p.category}, ${p.construction}, 7-iron ${p.loft7}°, $${p.price} (${p.config})`,
    label: p.name.toLowerCase().startsWith(p.brand.toLowerCase())
      ? p.name
      : `${p.brand} ${p.name}`,
  }));

  const qcaps = [
    { t: "Max help, juiced lofts", a: "start", x: PAD.l + 10, y: PAD.t + 18 },
    { t: "Compact looks, hidden speed", a: "end", x: W - PAD.r - 10, y: PAD.t + 18 },
    { t: "Forgiving, honest lofts", a: "start", x: PAD.l + 10, y: H - PAD.b + 34 },
    { t: "Feel, flight control, workability", a: "end", x: W - PAD.r - 10, y: H - PAD.b + 34 },
  ];

  return {
    W, H, PAD,
    xMid: toX(X_MID),
    yMid: toY(Y_MID),
    right: W - PAD.r,
    bottom: H - PAD.b,
    dots: placeColumnLabels(dots, W, H, PAD, toX(X_MID)),
    qcaps,
  };
})();

// "Find yourself on the map", each player profile points at the region of
// the iron map they should shop, matching the quadrant captions on the plot.
const ironProfiles = [
  {
    tag: "20+ handicap · learning contact",
    title: "The improver",
    body: "Mishits are your normal shot, so buy forgiveness first: wide soles, big faces and strong lofts that turn thin strikes into playable ones.",
    quadrant: "↖ Shop the top-left: max help, juiced lofts",
  },
  {
    tag: "Mid handicap · chasing carry",
    title: "The distance shopper",
    body: "Hollow-body players distance irons hide a hot, flexing face in a compact head, speed on mishits without the shovel look at address.",
    quadrant: "↗ Shop the top-right: compact looks, hidden speed",
  },
  {
    tag: "Slower swing · ball won't climb",
    title: "The launch seeker",
    body: "Stronger lofts make a low-flight problem worse. Lightweight builds and weaker high-launch lofts buy you height, and height is carry.",
    quadrant: "↙ Shop the bottom-left: forgiving, honest lofts",
  },
  {
    tag: "Single digits · flights the ball",
    title: "The ball-striker",
    body: "You trade distance help for precision: traditional lofts, thin toplines, and heads that move the ball both ways on demand.",
    quadrant: "↘ Shop the bottom-right: feel and workability",
  },
];

// ---- Wedge quadrant map ----------------------------------------------------
// One plot for the short-game buying decision:
//   x, head type, max forgiveness (cavity) left → compact tour blade right
//   y, sole bounce, low (firm turf / shallow attack) bottom → high (soft turf
//       / steep attack) top
// So the forgiving cavity wedges land left, tour blades right, and every model
// stacks by how much bounce its signature sole carries.
const WEDGE_CATS: Record<string, { label: string; cls: string; blurb: string }> = {
  "tour": {
    label: "Tour / blade",
    cls: "cat-blade",
    blurb: "compact and workable, full grind range",
  },
  "forged": {
    label: "Forged players",
    cls: "cat-pcb",
    blurb: "soft forged feel in a tour shape",
  },
  "full-face": {
    label: "Full-face / high-toe",
    cls: "cat-pd",
    blurb: "extra toe surface for open-face spin",
  },
  "game-improvement": {
    label: "Game-improvement cavity",
    cls: "cat-gi",
    blurb: "cavity-back forgiveness for the short game",
  },
};

const wedgeMap = (() => {
  if (!wedges.hasLineups) return null;
  const W = 960;
  const H = 720;
  // Wide left/right pads carve out the two label gutters; the tall bottom pad
  // reserves a clear band below the plot for the lower quadrant captions.
  const PAD = { l: 225, r: 220, t: 30, b: 84 };
  const pw = W - PAD.l - PAD.r;
  const ph = H - PAD.t - PAD.b;

  const pts = wedges.spectrumLineups.flatMap((l: any) =>
    l.models.map((m: any) => ({ ...m, brand: l.brand })),
  );
  const X_MID = 45; // spectrum position separating cavity help from tour precision
  const Y_MID = 11; // bounce splitting low (firm turf) from high (soft turf)
  const B_MIN = 6;
  const B_MAX = 17;

  const toX = (pos: number) => PAD.l + (pos / 100) * pw;
  // Higher bounce sits higher on the plot.
  const toY = (bounce: number) =>
    PAD.t + ((B_MAX - bounce) / (B_MAX - B_MIN)) * ph;

  const dots = pts.map((p: any) => ({
    ...p,
    x: toX(p.position),
    y: toY(p.bounce),
    cls: WEDGE_CATS[p.category]?.cls ?? "cat-gi",
    title: `${p.brand} ${p.name}, ${WEDGE_CATS[p.category]?.label ?? p.category}, ${p.construction}, ${p.loft}° · ${p.bounce}° bounce, $${p.price}`,
    label: p.name.toLowerCase().startsWith(p.brand.toLowerCase())
      ? p.name
      : `${p.brand} ${p.name}`,
  }));

  const qcaps = [
    { t: "Max forgiveness, soft turf", a: "start", x: PAD.l + 10, y: PAD.t + 18 },
    { t: "Tour spin, soft turf", a: "end", x: W - PAD.r - 10, y: PAD.t + 18 },
    { t: "Forgiving, firm turf", a: "start", x: PAD.l + 10, y: H - PAD.b + 34 },
    { t: "Shot-making, firm turf", a: "end", x: W - PAD.r - 10, y: H - PAD.b + 34 },
  ];

  return {
    W, H, PAD,
    xMid: toX(X_MID),
    yMid: toY(Y_MID),
    right: W - PAD.r,
    bottom: H - PAD.b,
    dots: placeColumnLabels(dots, W, H, PAD, toX(X_MID)),
    qcaps,
  };
})();

// "Find yourself on the map", each profile points at the wedge region that
// matches a turf/technique combination, mirroring the quadrant captions.
const wedgeProfiles = [
  {
    tag: "Higher handicap · fat & thin chips",
    title: "The improver",
    body: "Cavity-back wedges add forgiveness and wide, high-bounce soles that skid through fat strikes instead of digging, the short-game safety net.",
    quadrant: "↖ Shop the top-left: forgiving cavity, plenty of bounce",
  },
  {
    tag: "Steep swing · lush turf & soft bunkers",
    title: "The digger",
    body: "A steep attack takes big divots, so you need bounce to keep the leading edge from burying. Tour heads with high-bounce soles still let you work the face.",
    quadrant: "↗ Shop the top-right: tour head, high bounce",
  },
  {
    tag: "Slower swing · wants help around greens",
    title: "The forgiving picker",
    body: "A shallow, sweeping swing on normal turf over-bounces a wide sole. A forgiving head with less bounce sits flusher behind the ball at address.",
    quadrant: "↙ Shop the bottom-left: forgiving, lower bounce",
  },
  {
    tag: "Shallow sweeper · firm turf, tight lies",
    title: "The shot-maker",
    body: "You pick it clean off tight lies and open the face for spin. Low-bounce tour blades and full-face heads sit flush and reward hands and face control.",
    quadrant: "↘ Shop the bottom-right: tour blade, low bounce",
  },
];

// ---- Mobile-fallback lineup lists ------------------------------------------
// Same spectrumLineups data as the desktop continuum/quadrant-map, reshaped
// for the stacked mobile list: each model optionally carries a `sub` line.
const driverMobileLineups = spectrumLineups.map((lineup: any) => ({
  brand: lineup.brand,
  models: lineup.models.map((model: any) => ({
    name: model.name,
    position: model.position,
  })),
}));
const ironMobileLineups = irons.spectrumLineups.map((lineup: any) => ({
  brand: lineup.brand,
  models: lineup.models.map((model: any) => ({
    name: model.name,
    position: model.position,
    sub: `${IRON_CATS[model.category]?.label ?? model.category} · 7-iron ${model.loft7}° · ${model.construction}`,
  })),
}));
const wedgeMobileLineups = wedges.spectrumLineups.map((lineup: any) => ({
  brand: lineup.brand,
  models: lineup.models.map((model: any) => ({
    name: model.name,
    position: model.position,
    sub: `${WEDGE_CATS[model.category]?.label ?? model.category} · ${model.loft}° · ${model.bounce}° bounce · ${model.grind}`,
  })),
}));
const ballMobileLineups = balls.spectrumLineups.map((lineup: any) => ({
  brand: lineup.brand,
  models: lineup.models.map((model: any) => ({
    name: model.name,
    position: model.position,
    sub: `${model.construction} · compression ~${model.compression}`,
  })),
}));
