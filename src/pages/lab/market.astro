---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabNav from "../../components/LabNav.astro";
import { loadMarket, loadBallMarket } from "../../lib/lab";
import "../../styles/lab.css";

const title = "Market Data — The Lab";
const description =
  "Where every 2026 driver sits between maximum forgiveness and pure distance, where every ball sits between low spin and max spin, and what it all actually costs today. Editorial market snapshots from OpenGolfLab.";

const {
  hasLineups,
  modelCount,
  brandCount,
  medianPrice,
  biggestDiscount,
  axisMaxRounded,
  axisTicks,
  pricingLineups,
  spectrumLineups,
} = loadMarket();

const balls = loadBallMarket();
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span class="pill lab-band-pill live lab-status">● Live now</span>
      <h1>Market Data</h1>
      <p class="lede" style="margin-top:1rem;">
        What's actually for sale, and what it actually costs. These are
        editorial snapshots we research and maintain ourselves — not
        community-sourced. That's the
        <a href="/lab/community">separate effort next door</a>.
      </p>
      {
        hasLineups && (
          <p class="lab-stat-line tnum">
            {modelCount} drivers · {brandCount} brands · median street price{" "}
            {`$${medianPrice}`}
            {balls.hasLineups && (
              <>
                {" "}· {balls.modelCount} balls · median {`$${balls.medianPrice}`}/dz
              </>
            )}
          </p>
        )
      }
    </div>
  </section>

  <LabNav />

  <div class="container lab-body">
    {
      hasLineups ? (
        <>
          {/* ---- Driver spectrum ---- */}
          <section class="lab-band">
            <div class="lab-band-head">
              <p class="eyebrow">Equipment</p>
              <h2 id="lineups">2026 Driver Lineup Spectrum</h2>
              <p class="text-muted" style="max-width:66ch;">
                A complete map of every major manufacturer's current driver
                lineup, plotted across a spectrum from maximum forgiveness to
                pure distance. Use this matrix to understand exactly where a
                club sits in a brand's ecosystem.
              </p>
            </div>

            <div class="continuum-wrap" role="region" aria-label="2026 driver continuum">
              <div class="continuum-header">
                <span>Max Forgiveness</span>
                <span class="text-dim">Balanced / Core</span>
                <span>Pure Distance</span>
              </div>

              <div class="continuum-body">
                {spectrumLineups.map((lineup: any) => (
                  <div class="continuum-row">
                    <div class="continuum-brand">
                      <strong>{lineup.brand}</strong>
                    </div>
                    <div class="continuum-track-area">
                      <div class="continuum-track-line" aria-hidden="true" />
                      {[0, 25, 50, 75, 100].map((tick) => (
                        <span class="continuum-gridline" style={`left:${tick}%`} aria-hidden="true" />
                      ))}
                      {lineup.models.map((model: any) => (
                        <div
                          class="continuum-node"
                          style={`left: ${model.position}%; --stagger: ${model.stagger};`}
                        >
                          <span class="continuum-node-dot" aria-hidden="true" />
                          <span class="continuum-node-label">{model.name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* Mobile-only fallback: stacked per-brand lists, no forced horizontal scroll. */}
            <div class="continuum-mobile">
              {spectrumLineups.map((lineup: any) => (
                <div class="continuum-mobile-brand">
                  <strong>{lineup.brand}</strong>
                  <ul>
                    {lineup.models.map((model: any) => (
                      <li>
                        <span>{model.name}</span>
                        <span class="continuum-mobile-pos tnum">{model.position}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <p class="lab-caption">
              Positions are editorial estimates from manufacturer positioning +
              published MOI; not yet community data.
            </p>

            {/* Which half of the spectrum is yours? Turns the map into a decision. */}
            <aside class="fit-nudge card">
              <p class="eyebrow">Which half are you shopping in?</p>
              <p class="fit-nudge-lead text-muted">
                The spectrum tells you where each head sits — your own dispersion
                tells you where <em>you</em> sit. Pull up your driver numbers in
                the <a href="/golf-sim-analytics">dispersion dashboard</a> (or
                any 30+ shot sample) and use this rule of thumb:
              </p>
              <ul class="fit-nudge-list">
                <li>
                  <span class="fit-nudge-range tnum">±25 yd or wider</span>
                  <span>
                    or a two-way miss → shop the <b>max-forgiveness half</b>.
                    Width is costing you more strokes than length is buying.
                  </span>
                </li>
                <li>
                  <span class="fit-nudge-range tnum">±18–25 yd</span>
                  <span>
                    with a one-way miss → the <b>balanced core</b>, biased
                    toward whichever end matches your miss.
                  </span>
                </li>
                <li>
                  <span class="fit-nudge-range tnum">under ±18 yd</span>
                  <span>
                    and chasing carry → you've earned the <b>distance end</b>.
                    You're the golfer those heads are actually built for.
                  </span>
                </li>
              </ul>
              <p class="fit-nudge-foot text-dim">
                The strokes math behind the rule is in{" "}
                <a href="/blog/how-many-strokes-is-dispersion-worth">
                  how many strokes is 10 yards of dispersion worth?
                </a>{" "}
                — and a 40-shot demo session beats any rule of thumb.
              </p>
            </aside>
          </section>

          {/* ---- Pricing ---- */}
          <section class="lab-band">
            <div class="lab-band-head">
              <p class="eyebrow">Pricing</p>
              <h2 id="pricing">Market Pricing</h2>
              <p class="text-muted" style="max-width:66ch;">
                Today's best retail prices vs. MSRP. Hollow dot = MSRP. Filled
                dot = lowest price found today, connected by a line — green
                marks a real discount. Click any row to shop.
              </p>
              <p class="lab-stat-line tnum">
                {modelCount} drivers · median street price ${medianPrice}
                {biggestDiscount && (
                  <>
                    {" "}· biggest discount: {biggestDiscount.name} −
                    {Math.round(biggestDiscount.pct)}%
                  </>
                )}
              </p>
            </div>

            <div class="price-chart-wrap" role="region" aria-label="Pricing dumbbell chart">
              <div class="price-chart-axis" aria-hidden="true">
                <div class="price-chart-axis-spacer" />
                <div class="price-chart-axis-ticks">
                  {axisTicks.map((t) => (
                    <span class="price-chart-axis-tick" style={`left:${(t / axisMaxRounded) * 100}%`}>${t}</span>
                  ))}
                </div>
              </div>

              <div class="price-chart-body">
                {pricingLineups.map((lineup: any) => (
                  <div class="price-chart-group">
                    <div class="price-chart-brand">{lineup.brand}</div>
                    <div class="price-chart-bars">
                      {lineup.models.map((model: any) => {
                        const msrpPct = (model.msrp / axisMaxRounded) * 100;
                        const pricePct = (model.price / axisMaxRounded) * 100;
                        const savings = model.msrp - model.price;
                        const hasDiscount = savings > 0;
                        return (
                          <a
                            href={model.dealerUrl || "#"}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="price-row"
                            class:list={[{ discounted: hasDiscount }]}
                          >
                            <span class="price-row-model">{model.name}</span>
                            <div class="price-row-track">
                              {axisTicks.map((t) => (
                                <span class="price-chart-gridline" style={`left:${(t / axisMaxRounded) * 100}%`} aria-hidden="true" />
                              ))}
                              <span
                                class="price-row-connector"
                                style={`left:${Math.min(msrpPct, pricePct)}%; width:${Math.abs(msrpPct - pricePct)}%;`}
                                aria-hidden="true"
                              />
                              <span class="price-row-dot msrp" style={`left:${msrpPct}%`} aria-hidden="true" />
                              <span
                                class="price-row-dot price"
                                class:list={[{ discount: hasDiscount }]}
                                style={`left:${pricePct}%`}
                                aria-hidden="true"
                              />
                            </div>
                            <span class="price-row-values tnum">
                              <span class="price-row-price">${model.price}</span>
                              {hasDiscount && <span class="price-row-msrp">${model.msrp}</span>}
                              <span class="price-row-dealer">{model.dealer || "—"}</span>
                            </span>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <p class="lab-caption">
              Prices are checked by hand and will drift — always confirm at the
              retailer. We take no commission on any link here.
            </p>
          </section>

          {/* ---- Golf ball spectrum ---- */}
          {balls.hasLineups && (
            <section class="lab-band">
              <div class="lab-band-head">
                <p class="eyebrow">Equipment</p>
                <h2 id="balls">2026 Golf Ball Spectrum</h2>
                <p class="text-muted" style="max-width:66ch;">
                  Every major ball mapped from soft-and-straight to maximum
                  spin. Construction and compression drive the placement — the
                  left end flies flatter and releases, the right end climbs,
                  stops, and costs more. Hover a ball for its construction.
                </p>
              </div>

              <div class="continuum-wrap" role="region" aria-label="2026 golf ball continuum">
                <div class="continuum-header">
                  <span>Low Spin / Soft</span>
                  <span class="text-dim">Balanced</span>
                  <span>Max Spin / Tour</span>
                </div>

                <div class="continuum-body">
                  {balls.spectrumLineups.map((lineup: any) => (
                    <div class="continuum-row">
                      <div class="continuum-brand">
                        <strong>{lineup.brand}</strong>
                      </div>
                      <div class="continuum-track-area">
                        <div class="continuum-track-line" aria-hidden="true" />
                        {[0, 25, 50, 75, 100].map((tick) => (
                          <span class="continuum-gridline" style={`left:${tick}%`} aria-hidden="true" />
                        ))}
                        {lineup.models.map((model: any) => (
                          <div
                            class="continuum-node"
                            style={`left: ${model.position}%; --stagger: ${model.stagger};`}
                            title={`${model.construction} · compression ~${model.compression}`}
                          >
                            <span class="continuum-node-dot" aria-hidden="true" />
                            <span class="continuum-node-label">{model.name}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Mobile-only fallback: stacked per-brand lists. */}
              <div class="continuum-mobile">
                {balls.spectrumLineups.map((lineup: any) => (
                  <div class="continuum-mobile-brand">
                    <strong>{lineup.brand}</strong>
                    <ul>
                      {lineup.models.map((model: any) => (
                        <li>
                          <span>
                            {model.name}
                            <span class="continuum-mobile-sub">{model.construction}</span>
                          </span>
                          <span class="continuum-mobile-pos tnum">{model.position}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>

              <p class="lab-caption">
                Positions are editorial estimates from construction, cover
                material, compression and published robot data — not yet
                community data. Real, crowd-measured ball comparisons are{" "}
                <a href="/roadmap">next on the roadmap</a>; whether your own
                monitor can even see these differences is{" "}
                <a href="/blog/does-the-ball-you-hit-into-your-screen-matter">
                  its own story
                </a>.
              </p>
            </section>
          )}

          {/* ---- Ball pricing ---- */}
          {balls.hasLineups && (
            <section class="lab-band">
              <div class="lab-band-head">
                <p class="eyebrow">Pricing</p>
                <h2 id="ball-pricing">Ball Pricing — per dozen</h2>
                <p class="text-muted" style="max-width:66ch;">
                  Today's best street price per dozen vs. MSRP. Hollow dot =
                  MSRP. Filled dot = lowest price found today — green marks a
                  real discount. Click any row to shop.
                </p>
                <p class="lab-stat-line tnum">
                  {balls.modelCount} balls · median ${balls.medianPrice}/dozen
                  {balls.biggestDiscount && (
                    <>
                      {" "}· biggest discount: {balls.biggestDiscount.name} −
                      {Math.round(balls.biggestDiscount.pct)}%
                    </>
                  )}
                </p>
              </div>

              <div class="price-chart-wrap" role="region" aria-label="Ball pricing dumbbell chart">
                <div class="price-chart-axis" aria-hidden="true">
                  <div class="price-chart-axis-spacer" />
                  <div class="price-chart-axis-ticks">
                    {balls.axisTicks.map((t: number) => (
                      <span class="price-chart-axis-tick" style={`left:${(t / balls.axisMaxRounded) * 100}%`}>${t}</span>
                    ))}
                  </div>
                </div>

                <div class="price-chart-body">
                  {balls.pricingLineups.map((lineup: any) => (
                    <div class="price-chart-group">
                      <div class="price-chart-brand">{lineup.brand}</div>
                      <div class="price-chart-bars">
                        {lineup.models.map((model: any) => {
                          const msrpPct = (model.msrp / balls.axisMaxRounded) * 100;
                          const pricePct = (model.price / balls.axisMaxRounded) * 100;
                          const savings = model.msrp - model.price;
                          const hasDiscount = savings > 0;
                          return (
                            <a
                              href={model.dealerUrl || "#"}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="price-row"
                              class:list={[{ discounted: hasDiscount }]}
                            >
                              <span class="price-row-model">{model.name}</span>
                              <div class="price-row-track">
                                {balls.axisTicks.map((t: number) => (
                                  <span class="price-chart-gridline" style={`left:${(t / balls.axisMaxRounded) * 100}%`} aria-hidden="true" />
                                ))}
                                <span
                                  class="price-row-connector"
                                  style={`left:${Math.min(msrpPct, pricePct)}%; width:${Math.abs(msrpPct - pricePct)}%;`}
                                  aria-hidden="true"
                                />
                                <span class="price-row-dot msrp" style={`left:${msrpPct}%`} aria-hidden="true" />
                                <span
                                  class="price-row-dot price"
                                  class:list={[{ discount: hasDiscount }]}
                                  style={`left:${pricePct}%`}
                                  aria-hidden="true"
                                />
                              </div>
                              <span class="price-row-values tnum">
                                <span class="price-row-price">${model.price}</span>
                                {hasDiscount && <span class="price-row-msrp">${model.msrp}</span>}
                                <span class="price-row-dealer">{model.dealer || "—"}</span>
                              </span>
                            </a>
                          );
                        })}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <p class="lab-caption">
                Single-dozen prices — bulk and subscription deals (looking at
                you, direct-to-consumer brands) can run lower. Checked by hand,
                will drift, no commission taken.
              </p>
            </section>
          )}
        </>
      ) : (
        <section class="lab-band">
          <p class="tier-empty">Market data isn't published yet.</p>
        </section>
      )
    }

    {/* ---- What's coming to this section ---- */}
    <section class="lab-band">
      <div class="lab-band-head">
        <span class="pill lab-band-pill progress">Next up</span>
        <h2>Coming to Market Data</h2>
        <p class="text-muted" style="max-width:66ch;">
          Drivers came first because that's where the marketing noise is
          loudest, and balls followed because it's the one piece of equipment
          you use on every shot. The same treatment is planned for the rest of
          the bag — see the <a href="/roadmap">full roadmap</a> for where this
          sits.
        </p>
      </div>

      <div class="lab-planned-grid">
        <div class="lab-planned">
          <div class="lab-planned-head">
            <h3>Irons</h3>
            <span class="pill lab-planned-pill">Planned</span>
          </div>
          <p>
            Player's, player's-distance and game-improvement lineups placed on a
            forgiveness-to-workability spectrum, with lofts called out so you can
            see through the loft-jacking.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .lab-planned-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--gap);
  }
  .tier-empty {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px dashed var(--border-strong);
    padding: 1rem 1.25rem;
    max-width: 560px;
  }

  /* ---- Continuum / spectrum ---- */
  .continuum-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.25rem 1.5rem 0.85rem;
    overflow-x: auto;
    max-width: 1000px;
  }
  .continuum-header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-left: 140px;
    margin-bottom: 1.1rem;
  }
  .continuum-body {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
    min-width: 560px;
  }
  .continuum-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .continuum-brand {
    width: 116px;
    flex-shrink: 0;
    color: var(--green);
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .continuum-track-area {
    flex-grow: 1;
    position: relative;
    height: 34px;
  }
  .continuum-track-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-strong);
    transform: translateY(-50%);
  }
  .continuum-gridline {
    position: absolute;
    top: -6px;
    bottom: -6px;
    width: 1px;
    background: var(--border);
    opacity: 0.6;
  }
  .continuum-node {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .continuum-node-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    border: 2px solid var(--bg-elevated);
  }
  .continuum-node-label {
    position: absolute;
    bottom: calc(100% + 6px + (var(--stagger, 0) * 16px));
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
    white-space: nowrap;
    background: var(--bg-elevated);
    padding: 0.1rem 0.35rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s ease;
  }
  .continuum-node:hover {
    z-index: 3;
  }
  .continuum-node:hover .continuum-node-label {
    color: var(--green);
  }
  /* Mobile-only stacked lists (no forced scroll) */
  .continuum-mobile {
    display: none;
  }
  .continuum-mobile-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  /* ---- "Which half are you shopping in?" nudge ---- */
  .fit-nudge {
    margin-top: 1.5rem;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .fit-nudge-lead {
    font-size: 0.95rem;
    max-width: 66ch;
  }
  .fit-nudge-list {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .fit-nudge-list li {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    font-size: 0.92rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    padding-top: 0.65rem;
  }
  .fit-nudge-list b {
    color: var(--text);
    font-weight: 600;
  }
  .fit-nudge-range {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--green);
    flex: 0 0 130px;
    white-space: nowrap;
  }
  .fit-nudge-foot {
    font-size: 0.85rem;
  }
  @media (max-width: 700px) {
    .fit-nudge-list li {
      flex-direction: column;
      gap: 0.25rem;
    }
    .fit-nudge-range {
      flex-basis: auto;
    }
  }

  @media (max-width: 700px) {
    .continuum-wrap {
      display: none;
    }
    .continuum-mobile {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .continuum-mobile-brand strong {
      color: var(--green);
      font-family: var(--font-head);
      font-weight: 600;
    }
    .continuum-mobile-brand ul {
      list-style: none;
      padding: 0;
      margin-top: 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .continuum-mobile-brand li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.4rem;
      font-size: 0.92rem;
    }
    .continuum-mobile-pos {
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 0.82rem;
    }
  }

  /* ---- Pricing dumbbell chart ---- */
  .price-chart-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 1.5rem 1.5rem 2rem;
    max-width: 1000px;
  }
  .price-chart-axis {
    display: flex;
    margin-bottom: 1.5rem;
  }
  .price-chart-axis-spacer {
    width: 160px;
    flex-shrink: 0;
  }
  .price-chart-axis-ticks {
    flex-grow: 1;
    position: relative;
    height: 1rem;
    padding-right: 150px;
  }
  .price-chart-axis-tick {
    position: absolute;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .price-chart-body {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .price-chart-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }
  .price-chart-brand {
    font-family: var(--font-head);
    font-size: 0.9rem;
    color: var(--green);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.25rem;
  }
  .price-chart-bars {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    text-decoration: none;
  }
  .price-row-model {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    width: 160px;
    flex-shrink: 0;
    text-align: right;
