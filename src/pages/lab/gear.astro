---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabNav from "../../components/LabNav.astro";
import { loadMarket, loadBallMarket, loadIronMarket } from "../../lib/lab";
import "../../styles/lab.css";

const title = "Gear Guide — The Lab";
const description =
  "What clubs and balls exist, what they're designed to do, and what they actually cost today. Every 2026 driver mapped from forgiveness to distance, every ball mapped by spin and compression, every iron lineup mapped from blades to max game improvement with the real 7-iron lofts. Editorial gear snapshots from OpenGolfLab.";

const {
  hasLineups,
  modelCount,
  brandCount,
  medianPrice,
  biggestDiscount,
  axisMaxRounded,
  axisTicks,
  pricingLineups,
  spectrumLineups,
} = loadMarket();

const balls = loadBallMarket();
const irons = loadIronMarket();

// ---- Shared quadrant-map label layout --------------------------------------
// Greedy label placement: try rings of positions around each dot (nearest
// first) and keep the first that doesn't hit another label, a dot, or the
// plot edge. Labels pushed far from their dot get a leader line. The quadrant
// captions' footprints are registered as obstacles so labels never land on
// top of them.
function placeQuadrantLabels(
  dots: any[],
  qcaps: any[],
  W: number,
  H: number,
  PAD: any,
) {
  const CHAR_W = 7;
  const LBL_H = 15;
  const boxes = dots.map((d: any) => ({
    x1: d.x - 9, y1: d.y - 9, x2: d.x + 9, y2: d.y + 9,
  }));
  for (const c of qcaps) {
    const w = c.t.length * 7.5;
    boxes.push({
      x1: (c.a === "start" ? c.x : c.x - w) - 4,
      y1: c.y - 15,
      x2: (c.a === "start" ? c.x + w : c.x) + 4,
      y2: c.y + 4,
    });
  }
  const hits = (a: any) =>
    boxes.some((b) => a.x1 < b.x2 && b.x1 < a.x2 && a.y1 < b.y2 && b.y1 < a.y2);
  // Near-ring offsets must clear the ±9 dot box (label boxes get ±2/-12+3
  // padding below), or every label falls through to the far rings.
  const CANDS: { dx: number; dy: number; anchor: string }[] = [
    { dx: 12, dy: 4, anchor: "start" },
    { dx: -12, dy: 4, anchor: "end" },
    { dx: 0, dy: -13, anchor: "middle" },
    { dx: 0, dy: 21, anchor: "middle" },
    { dx: 12, dy: -7, anchor: "start" },
    { dx: 12, dy: 15, anchor: "start" },
    { dx: -12, dy: -7, anchor: "end" },
    { dx: -12, dy: 15, anchor: "end" },
  ];
  // Wider rings for dense clusters.
  for (const r of [24, 36, 48, 60]) {
    CANDS.push(
      { dx: r, dy: 4, anchor: "start" },
      { dx: -r, dy: 4, anchor: "end" },
      { dx: 0, dy: -r, anchor: "middle" },
      { dx: 0, dy: r + 8, anchor: "middle" },
      { dx: r * 0.8, dy: -r * 0.6, anchor: "start" },
      { dx: r * 0.8, dy: r * 0.6 + 8, anchor: "start" },
      { dx: -r * 0.8, dy: -r * 0.6, anchor: "end" },
      { dx: -r * 0.8, dy: r * 0.6 + 8, anchor: "end" },
    );
  }
  return [...dots]
    .sort((a: any, b: any) => a.y - b.y || a.x - b.x)
    .map((d: any) => {
      const w = d.label.length * CHAR_W;
      let pick = CANDS[0];
      for (const c of CANDS) {
        const lx =
          c.anchor === "start" ? d.x + c.dx :
          c.anchor === "end" ? d.x + c.dx - w :
          d.x - w / 2;
        const box = { x1: lx - 2, y1: d.y + c.dy - LBL_H + 3, x2: lx + w + 2, y2: d.y + c.dy + 3 };
        if (box.x1 < 2 || box.x2 > W - 2 || box.y1 < 2 || box.y2 > H - PAD.b + 14) continue;
        if (!hits(box)) {
          pick = c;
          break;
        }
      }
      // Record the chosen box (fallback included) so later labels dodge it.
      const flx =
        pick.anchor === "start" ? d.x + pick.dx :
        pick.anchor === "end" ? d.x + pick.dx - w :
        d.x - w / 2;
      boxes.push({ x1: flx - 2, y1: d.y + pick.dy - LBL_H + 3, x2: flx + w + 2, y2: d.y + pick.dy + 3 });
      const far = Math.hypot(pick.dx, pick.dy - 4) > 22;
      // Leader line runs from the dot toward the near edge of the label.
      const leadX =
        pick.anchor === "start" ? d.x + pick.dx - 3 :
        pick.anchor === "end" ? d.x + pick.dx + 3 :
        d.x;
      const leadY = pick.dy > 0 ? d.y + pick.dy - LBL_H + 6 : d.y + pick.dy + 2;
      return { ...d, lbl: pick, far, leadX, leadY };
    });
}

// ---- Ball quadrant map ----------------------------------------------------
// One plot that carries the whole buying decision:
//   x — spin, decreasing left → right (spectrum position, reversed)
//   y — compression, increasing bottom → top
// So the firm, low-spin distance balls land top-right and the soft,
// straight-flying swing-saver balls land bottom-right.
const ballMap = (() => {
  if (!balls.hasLineups) return null;
  const W = 960;
  const H = 720;
  const PAD = { l: 40, r: 18, t: 30, b: 46 };
  const pw = W - PAD.l - PAD.r;
  const ph = H - PAD.t - PAD.b;

  const pts = balls.spectrumLineups.flatMap((l: any) =>
    l.models.map((m: any) => ({ ...m, brand: l.brand })),
  );
  const comps = pts.map((p: any) => p.compression);
  const cMin = Math.min(...comps) - 5;
  const cMax = Math.max(...comps) + 5;
  const X_MID = 50; // spectrum position that splits low spin from tour spin
  const Y_MID = 75; // compression above which a ball plays firm / fast-swing

  const toX = (pos: number) => PAD.l + ((100 - pos) / 100) * pw;
  // Piecewise y-scale: most balls crowd the firm (high-compression) band, so
  // the region above Y_MID gets more than its linear share of the height.
  const TOP_FRAC = 0.6;
  const topPh = ph * TOP_FRAC;
  const toY = (comp: number) =>
    comp >= Y_MID
      ? PAD.t + ((cMax - comp) / (cMax - Y_MID)) * topPh
      : PAD.t + topPh + ((Y_MID - comp) / (Y_MID - cMin)) * (ph - topPh);

  // Generic model names (Vice "Pro", Maxfli "Tour", …) get their brand
  // prefixed so two dots never carry the same label.
  const counts: Record<string, number> = {};
  for (const p of pts) counts[p.name] = (counts[p.name] ?? 0) + 1;
  const GENERIC = new Set(["Tour", "Tour X", "Pro", "Pro Plus", "Pro Soft"]);
  const dots = pts.map((p: any) => ({
    ...p,
    x: toX(p.position),
    y: toY(p.compression),
    premium: /urethane/i.test(p.construction),
    label: counts[p.name] > 1 || GENERIC.has(p.name) ? `${p.brand} ${p.name}` : p.name,
  }));

  const qcaps = [
    { t: "Fast swing, tour spin", a: "start", x: PAD.l + 10, y: PAD.t + 18 },
    { t: "Fast swing, low spin", a: "end", x: W - PAD.r - 10, y: PAD.t + 18 },
    { t: "Slower swing, soft with spin", a: "start", x: PAD.l + 10, y: H - PAD.b - 6 },
    { t: "Slower swing, straight and soft", a: "end", x: W - PAD.r - 10, y: H - PAD.b - 6 },
  ];
  const labeled = placeQuadrantLabels(dots, qcaps, W, H, PAD);

  return {
    W, H, PAD,
    xMid: toX(X_MID),
    yMid: toY(Y_MID),
    right: W - PAD.r,
    bottom: H - PAD.b,
    dots: labeled,
    qcaps,
  };
})();

// "Find yourself on the map" — each player profile points at the region of
// the map they should shop, matching the quadrant captions on the plot.
const ballProfiles = [
  {
    tag: "105+ mph driver",
    title: "The speed player",
    body: "You compress everything. A firm tour ball turns that speed into carry and still bites on the greens.",
    quadrant: "↖ Shop the top-left: fast swing, tour spin",
  },
  {
    tag: "Fast, but ballooning",
    title: "The spin fighter",
    body: "Plenty of speed, too much height and curve. Firm and low-spin flattens the flight and buys roll.",
    quadrant: "↗ Shop the top-right: fast swing, low spin",
  },
  {
    tag: "85–105 mph driver",
    title: "The all-rounder",
    body: "Most golfers. Mid-compression urethane near the middle of the map keeps greenside spin without costing ball speed.",
    quadrant: "◎ Shop the center, either side of the crosshair",
  },
  {
    tag: "Under 85 mph · seniors · slice fighters",
    title: "The smooth swinger",
    body: "Soft, low-spin balls launch higher, curve less, and feel better at lower speeds — less backspin means less sidespin too.",
    quadrant: "↘ Shop the bottom-right: slower swing, straight and soft",
  },
];

// ---- Iron quadrant map ------------------------------------------------------
// One plot that carries the whole buying decision:
//   x — head design, max forgiveness left → compact precision right
//   y — stamped 7-iron loft, stronger (more built-in distance) toward the top
// So the juiced game-improvement sets land top-left, hollow-body players
// distance irons top-right, blades and traditional cavity backs bottom-right,
// and the honest-lofted launch helpers bottom-left.
const IRON_CATS: Record<string, { label: string; cls: string; blurb: string }> = {
  "blade": {
    label: "Muscle back / blade",
    cls: "cat-blade",
    blurb: "pure feel and workability, zero help",
  },
  "players-cb": {
    label: "Players cavity back",
    cls: "cat-pcb",
    blurb: "feel first, with a small safety net",
  },
  "players-distance": {
    label: "Players distance",
    cls: "cat-pd",
    blurb: "compact head hiding a hot face",
  },
  "game-improvement": {
    label: "Game improvement",
    cls: "cat-gi",
    blurb: "distance and help for most golfers",
  },
  "max-gi": {
    label: "Max game improvement",
    cls: "cat-sgi",
    blurb: "everything aimed at forgiveness",
  },
};

const ironMap = (() => {
  if (!irons.hasLineups) return null;
  const W = 960;
  const H = 760;
  const PAD = { l: 40, r: 18, t: 30, b: 46 };
  const pw = W - PAD.l - PAD.r;
  const ph = H - PAD.t - PAD.b;

  const pts = irons.spectrumLineups.flatMap((l: any) =>
    l.models.map((m: any) => ({ ...m, brand: l.brand })),
  );
  const X_MID = 45; // spectrum position separating help-first from precision-first heads
  const Y_MID = 30.75; // 7-iron loft splitting juiced lofts (above) from traditional (below)
  const L_MIN = 26.5;
  const L_MAX = 35.5;

  // Piecewise x-scale: the game-improvement half of the market is crowded, so
  // the region left of X_MID gets more than its linear share of the width.
  const LEFT_FRAC = 0.55;
  const leftPw = pw * LEFT_FRAC;
  const toX = (pos: number) =>
    pos <= X_MID
      ? PAD.l + (pos / X_MID) * leftPw
      : PAD.l + leftPw + ((pos - X_MID) / (100 - X_MID)) * (pw - leftPw);
  // Stronger (numerically lower) loft = more built-in distance = higher up.
  const toY = (loft: number) => PAD.t + ((loft - L_MIN) / (L_MAX - L_MIN)) * ph;

  // Any model name shared across brands gets its brand prefixed so two dots
  // never carry the same label.
  const counts: Record<string, number> = {};
  for (const p of pts) counts[p.name] = (counts[p.name] ?? 0) + 1;
  const dots = pts.map((p: any) => ({
    ...p,
    x: toX(p.position),
    y: toY(p.loft7),
    cls: IRON_CATS[p.category]?.cls ?? "cat-gi",
    label: counts[p.name] > 1 ? `${p.brand} ${p.name}` : p.name,
  }));

  const qcaps = [
    { t: "Max help, juiced lofts", a: "start", x: PAD.l + 10, y: PAD.t + 18 },
    { t: "Compact looks, hidden speed", a: "end", x: W - PAD.r - 10, y: PAD.t + 18 },
    { t: "Forgiving, honest lofts", a: "start", x: PAD.l + 10, y: H - PAD.b - 6 },
    { t: "Feel, flight control, workability", a: "end", x: W - PAD.r - 10, y: H - PAD.b - 6 },
  ];

  return {
    W, H, PAD,
    xMid: toX(X_MID),
    yMid: toY(Y_MID),
    right: W - PAD.r,
    bottom: H - PAD.b,
    dots: placeQuadrantLabels(dots, qcaps, W, H, PAD),
    qcaps,
  };
})();

// "Find yourself on the map" — each player profile points at the region of
// the iron map they should shop, matching the quadrant captions on the plot.
const ironProfiles = [
  {
    tag: "20+ handicap · learning contact",
    title: "The improver",
    body: "Mishits are your normal shot, so buy forgiveness first: wide soles, big faces and strong lofts that turn thin strikes into playable ones.",
    quadrant: "↖ Shop the top-left: max help, juiced lofts",
  },
  {
    tag: "Mid handicap · chasing carry",
    title: "The distance shopper",
    body: "Hollow-body players distance irons hide a hot, flexing face in a compact head — speed on mishits without the shovel look at address.",
    quadrant: "↗ Shop the top-right: compact looks, hidden speed",
  },
  {
    tag: "Slower swing · ball won't climb",
    title: "The launch seeker",
    body: "Stronger lofts make a low-flight problem worse. Lightweight builds and weaker high-launch lofts buy you height — and height is carry.",
    quadrant: "↙ Shop the bottom-left: forgiving, honest lofts",
  },
  {
    tag: "Single digits · flights the ball",
    title: "The ball-striker",
    body: "You trade distance help for precision: traditional lofts, thin toplines, and heads that move the ball both ways on demand.",
    quadrant: "↘ Shop the bottom-right: feel and workability",
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span class="pill lab-band-pill live lab-status">● Live now</span>
      <h1>Gear Guide</h1>
      <p class="lede" style="margin-top:1rem;">
        What clubs and balls exist? What are they designed to do? And what do
        they actually cost today? Editorial snapshots we research and maintain
        ourselves — the community-measured numbers are the
        <a href="/lab/community">separate effort next door</a>.
      </p>
      {
        hasLineups && (
          <p class="lab-stat-line tnum">
            {modelCount} drivers · {brandCount} brands · median street price{" "}
            {`$${medianPrice}`}
            {balls.hasLineups && (
              <>
                {" "}· {balls.modelCount} balls · median {`$${balls.medianPrice}`}/dz
              </>
            )}
            {irons.hasLineups && (
              <>
                {" "}· {irons.modelCount} iron sets · median {`$${irons.medianPrice}`}
              </>
            )}
          </p>
        )
      }
    </div>
  </section>

  <LabNav />

  <div class="container lab-body">
    {
      hasLineups ? (
        <>
          {/* ---- Driver spectrum ---- */}
          <section class="lab-band">
            <div class="lab-band-head">
              <p class="eyebrow">Equipment</p>
              <h2 id="lineups">2026 Driver Lineup Spectrum</h2>
              <p class="text-muted" style="max-width:66ch;">
                A complete map of every major manufacturer's current driver
                lineup, plotted across a spectrum from maximum forgiveness to
                pure distance. Use this matrix to understand exactly where a
                club sits in a brand's ecosystem.
              </p>
            </div>

            <div class="continuum-wrap" role="region" aria-label="2026 driver continuum">
              <div class="continuum-header">
                <span>Max Forgiveness</span>
                <span class="text-dim">Balanced / Core</span>
                <span>Pure Distance</span>
              </div>

              <div class="continuum-body">
                {spectrumLineups.map((lineup: any) => (
                  <div class="continuum-row">
                    <div class="continuum-brand">
                      <strong>{lineup.brand}</strong>
                    </div>
                    <div class="continuum-track-area">
                      <div class="continuum-track-line" aria-hidden="true" />
                      {[0, 25, 50, 75, 100].map((tick) => (
                        <span class="continuum-gridline" style={`left:${tick}%`} aria-hidden="true" />
                      ))}
                      {lineup.models.map((model: any) => (
                        <div
                          class="continuum-node"
                          style={`left: ${model.position}%; --stagger: ${model.stagger};`}
                        >
                          <span class="continuum-node-dot" aria-hidden="true" />
                          <span class="continuum-node-label">{model.name}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* Mobile-only fallback: stacked per-brand lists, no forced horizontal scroll. */}
            <div class="continuum-mobile">
              {spectrumLineups.map((lineup: any) => (
                <div class="continuum-mobile-brand">
                  <strong>{lineup.brand}</strong>
                  <ul>
                    {lineup.models.map((model: any) => (
                      <li>
                        <span>{model.name}</span>
                        <span class="continuum-mobile-pos tnum">{model.position}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <p class="lab-caption">
              Positions are editorial estimates from manufacturer positioning +
              published MOI; not yet community data.
            </p>

            {/* Which half of the spectrum is yours? Turns the map into a decision. */}
            <aside class="fit-nudge card">
              <p class="eyebrow">Which half are you shopping in?</p>
              <p class="fit-nudge-lead text-muted">
                The spectrum tells you where each head sits — your own dispersion
                tells you where <em>you</em> sit. Pull up your driver numbers in
                the <a href="/golf-sim-analytics">dispersion dashboard</a> (or
                any 30+ shot sample) and use this rule of thumb:
              </p>
              <ul class="fit-nudge-list">
                <li>
                  <span class="fit-nudge-range tnum">±25 yd or wider</span>
                  <span>
                    or a two-way miss → shop the <b>max-forgiveness half</b>.
                    Width is costing you more strokes than length is buying.
                  </span>
                </li>
                <li>
                  <span class="fit-nudge-range tnum">±18–25 yd</span>
                  <span>
                    with a one-way miss → the <b>balanced core</b>, biased
                    toward whichever end matches your miss.
                  </span>
                </li>
                <li>
                  <span class="fit-nudge-range tnum">under ±18 yd</span>
                  <span>
                    and chasing carry → you've earned the <b>distance end</b>.
                    You're the golfer those heads are actually built for.
                  </span>
                </li>
              </ul>
              <p class="fit-nudge-foot text-dim">
                The strokes math behind the rule gets its own write-up soon —
                and a 40-shot demo session beats any rule of thumb.
              </p>
            </aside>
          </section>

          {/* ---- Pricing ---- */}
          <section class="lab-band">
            <div class="lab-band-head">
              <p class="eyebrow">Pricing</p>
              <h2 id="pricing">Driver Pricing</h2>
              <p class="text-muted" style="max-width:66ch;">
                Today's best retail prices vs. MSRP. Hollow dot = MSRP. Filled
                dot = lowest price found today, connected by a line — green
                marks a real discount. Click any row to shop.
              </p>
              <p class="lab-stat-line tnum">
                {modelCount} drivers · median street price ${medianPrice}
                {biggestDiscount && (
                  <>
                    {" "}· biggest discount: {biggestDiscount.name} −
                    {Math.round(biggestDiscount.pct)}%
                  </>
                )}
              </p>
            </div>

            <div class="price-chart-wrap" role="region" aria-label="Pricing dumbbell chart">
              <div class="price-chart-axis" aria-hidden="true">
                <div class="price-chart-axis-spacer" />
                <div class="price-chart-axis-ticks">
                  {axisTicks.map((t) => (
                    <span class="price-chart-axis-tick" style={`left:${(t / axisMaxRounded) * 100}%`}>${t}</span>
                  ))}
                </div>
              </div>

              <div class="price-chart-body">
                {pricingLineups.map((lineup: any) => (
                  <div class="price-chart-group">
                    <div class="price-chart-brand">{lineup.brand}</div>
                    <div class="price-chart-bars">
                      {lineup.models.map((model: any) => {
                        const msrpPct = (model.msrp / axisMaxRounded) * 100;
                        const pricePct = (model.price / axisMaxRounded) * 100;
                        const savings = model.msrp - model.price;
                        const hasDiscount = savings > 0;
                        return (
                          <a
                            href={model.dealerUrl || "#"}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="price-row"
                            class:list={[{ discounted: hasDiscount }]}
                          >
                            <span class="price-row-model">{model.name}</span>
                            <div class="price-row-track">
                              {axisTicks.map((t) => (
                                <span class="price-chart-gridline" style={`left:${(t / axisMaxRounded) * 100}%`} aria-hidden="true" />
                              ))}
                              <span
                                class="price-row-connector"
                                style={`left:${Math.min(msrpPct, pricePct)}%; width:${Math.abs(msrpPct - pricePct)}%;`}
                                aria-hidden="true"
                              />
                              <span class="price-row-dot msrp" style={`left:${msrpPct}%`} aria-hidden="true" />
                              <span
                                class="price-row-dot price"
                                class:list={[{ discount: hasDiscount }]}
                                style={`left:${pricePct}%`}
                                aria-hidden="true"
                              />
                            </div>
                            <span class="price-row-values tnum">
                              <span class="price-row-price">${model.price}</span>
                              {hasDiscount && <span class="price-row-msrp">${model.msrp}</span>}
                              <span class="price-row-dealer">{model.dealer || "—"}</span>
                            </span>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <p class="lab-caption">
              Prices are checked by hand and will drift — always confirm at the
              retailer. We take no commission on any link here.
            </p>
          </section>

          {/* ---- Golf ball map (quadrant plot) ---- */}
          {balls.hasLineups && ballMap && (
            <section class="lab-band">
              <div class="lab-band-head">
                <p class="eyebrow">Equipment</p>
                <h2 id="balls">2026 Golf Ball Map</h2>
                <p class="text-muted" style="max-width:66ch;">
                  Every major ball on the two axes that actually decide the
                  fit: how much it spins (right = less) and how firm it is
                  (up = firmer, built for faster swings). Find your quadrant
                  below, then shop the dots inside it. Hover any ball for its
                  construction.
                </p>
              </div>

              <div class="ballmap-wrap" role="region" aria-label="2026 golf ball map">
                <svg
                  viewBox={`0 0 ${ballMap.W} ${ballMap.H}`}
                  class="ballmap"
                  role="img"
                  aria-label="Scatter plot of golf balls with spin decreasing left to right and compression increasing bottom to top. Firm low-spin distance balls sit top right; soft straight-flying balls sit bottom right; firm tour balls sit top left."
                >
                  {/* midlines */}
                  <line class="ballmap-mid" x1={ballMap.xMid} y1={ballMap.PAD.t} x2={ballMap.xMid} y2={ballMap.bottom} />
                  <line class="ballmap-mid" x1={ballMap.PAD.l} y1={ballMap.yMid} x2={ballMap.right} y2={ballMap.yMid} />

                  {/* quadrant labels */}
                  {ballMap.qcaps.map((c: any) => (
                    <text class="ballmap-q" text-anchor={c.a} x={c.x} y={c.y}>{c.t}</text>
                  ))}

                  {/* axis captions: one per axis, arrows point along the scale */}
                  <text
                    class="ballmap-axis"
                    text-anchor="middle"
