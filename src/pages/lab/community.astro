---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabNav from "../../components/LabNav.astro";
import CommunityExplorer from "../../components/CommunityExplorer.astro";
import { loadCommunity } from "../../lib/lab";
import "../../styles/lab.css";

const title = "Community Data, The Lab";
const description =
  "Crowd-sourced launch and spin norms, driver dispersion and club gapping, aggregated from anonymized, opt-in GSPro simulator sessions. One golfer, one vote.";

const {
  tierViews,
  hasCommunityData,
  defaultTierKey,
  generatedDate,
  minContributors,
  totalContributors,
  totalShots,
  feed,
} = loadCommunity();
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span
        class:list={[
          "pill",
          "lab-band-pill",
          "lab-status",
          hasCommunityData ? "live" : "progress",
        ]}
      >
        {hasCommunityData ? "● Live now" : "◐ In progress"}
      </span>
      <h1>Community Data</h1>
      <p class="lede" style="margin-top:1rem;">
        Real ball comparisons, gapping by handicap, and launch and spin norms,
        built from anonymized, opt-in sessions. Every golfer counts once per
        club, so a marathon range session can't outvote anyone.
      </p>
      {
        hasCommunityData && (
          <p class="lab-stat-line tnum">
            {totalContributors} golfers · {totalShots.toLocaleString()} shots
            {generatedDate && <> · updated {generatedDate}</>}
          </p>
        )
      }
      <div class="hero-cta" style="margin-top:1.6rem;">
        <a href="/download" class="btn btn-primary">Contribute your sessions</a>
        <a href="/privacy" class="btn btn-secondary">What gets shared</a>
      </div>
    </div>
  </section>

  <LabNav />

  <div class="container lab-body">
    <CommunityExplorer />

    <section class="lab-band">
      {
        hasCommunityData ? (
          <div class="tiers">
            {tierViews.map((t: any) => (
              <input
                type="radio"
                name="tier"
                id={`tier-${t.key}`}
                class="tier-radio"
                checked={t.key === defaultTierKey}
              />
            ))}

            <div class="tier-labels" role="group" aria-label="Data-quality tier">
              {tierViews.map((t: any) => (
                <label for={`tier-${t.key}`} class="tier-label">
                  {t.label}
                  <span class="tier-count tnum">{t.contributors}</span>
                </label>
              ))}
            </div>

            {tierViews.map((t: any) => (
              <div class:list={["tier-panel", `panel-${t.key}`]}>
                {t.clubs.length ? (
                  <div class="tier-inner">
                    <p class="tier-blurb">
                      {t.blurb}{" "}
                      <span class="text-dim">
                        · {t.contributors} contributors · {t.shots.toLocaleString()} shots
                      </span>
                    </p>

                    <div class="norms-wrap">
                      <table class="norms">
                        <thead>
                          <tr>
                            <th>Club</th>
                            <th>Carry</th>
                            <th>Ball</th>
                            <th>Launch</th>
                            <th>Spin</th>
                            <th>Golfers</th>
                          </tr>
                        </thead>
                        <tbody>
                          {t.clubs.map((c: any) => (
                            <tr>
                              <td class="norms-club">{c.club}</td>
                              <td>
                                <span class="norms-big tnum">
                                  {c.carry?.med}
                                  <span class="norms-unit">yd</span>
                                </span>
                                <span class="norms-range tnum">
                                  {c.carry?.p10}–{c.carry?.p90}
                                </span>
                              </td>
                              <td class="tnum">{c.ball ?? "—"}</td>
                              <td class="tnum">{c.launch ?? "—"}</td>
                              <td>
                                {c.spin?.value != null ? (
                                  <span class="tnum">{c.spin.value}</span>
                                ) : (
                                  <span class="lock" title="Spin publishes at the Verified tier and up: measured, not modeled.">
                                    Verified+
                                  </span>
                                )}
                              </td>
                              <td class="tnum norms-n">{c.contributors}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>

                    {t.ellipse && (
                      <div class="disp">
                        <div class="disp-title">Driver: typical dispersion</div>
                        <svg viewBox="0 0 220 176" class="disp-svg" role="img"
                          aria-label={`Typical driver dispersion, about ${Math.round(t.ellipse.lateral * 2)} yards wide and ${Math.round(t.ellipse.depth * 2)} yards deep`}>
                          <line x1="110" y1="12" x2="110" y2="164" class="disp-axis" />
                          <line x1="18" y1="88" x2="202" y2="88" class="disp-axis" />
                          <ellipse cx={t.ellipse.cx} cy={t.ellipse.cy} rx={t.ellipse.rx} ry={t.ellipse.ry} class="disp-ell" />
                          <circle cx={t.ellipse.cx} cy={t.ellipse.cy} r="2.5" class="disp-center" />
                        </svg>
                        <div class="disp-legend">
                          <span>± {t.ellipse.lateral} yd side</span>
                          <span>± {t.ellipse.depth} yd depth</span>
                          {t.ellipse.bias !== 0 && (
                            <span>{t.ellipse.bias > 0 ? "right" : "left"} bias {Math.abs(t.ellipse.bias)} yd</span>
                          )}
                        </div>
                      </div>
                    )}
                  </div>
                ) : (
                  <p class="tier-empty">
                    Not enough {t.label !== "All" ? t.label.toLowerCase() + "-tier " : ""}data
                    yet to publish. It takes {minContributors} golfers per club. Try the All tab.
                  </p>
                )}
              </div>
            ))}

            <p class="lab-caption">
              Each number is the typical golfer's typical shot. Every
              contributor counts once, so one marathon session can't skew a
              result. The small range under each carry shows where most golfers
              (the middle 80%) land.{generatedDate && <> Updated {generatedDate}.</>}
            </p>
          </div>
        ) : (
          <>
            <div class="lab-band-head">
              <h2>Where this stands</h2>
              <p class="text-muted" style="max-width:66ch;">
                The pipeline is built and tested end to end. What's left is the
                part only you can supply: enough opt-in sessions to publish a
                number honestly. Nothing appears here until at least{" "}
                {minContributors} golfers have contributed a given club.
              </p>
            </div>
            <ul class="build-status">
              <li class="done"><span class="build-mark">✓</span> Capture pipeline</li>
              <li class="done"><span class="build-mark">✓</span> Data format v1.1</li>
              <li class="done"><span class="build-mark">✓</span> Aggregation + QA</li>
              <li class="active"><span class="build-mark">◐</span> First dataset</li>
            </ul>
            <div class="card empty-cta">
              <h3>Be one of the first {minContributors}</h3>
              <p class="text-muted">
                Install the app, tick the contribute box, and play. That's the
                whole ask, no account, no name, no scores. The moment a club
                clears the threshold, its numbers appear on this page for
                everyone.
              </p>
              <div class="hero-cta" style="margin-top:1.1rem;">
                <a href="/download" class="btn btn-primary">Get the app</a>
                <a href="/privacy" class="btn btn-secondary">See what gets shared</a>
              </div>
            </div>
          </>
        )
      }
    </section>

    {/* ---- Contributions feed (the live board) ---- */}
    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">Live feed</p>
        <h2>Recent contributions</h2>
        <p class="text-muted" style="max-width:66ch;">
          The last {feed.items.length > 0 ? feed.items.length : "few"} sessions
          people chose to share, most recent first. Just a name someone picked,
          the date, and what they hit, nothing else about a contributor is shown
          or stored.{" "}
          {feed.generatedDate && (
            <>Fresh as of the last site build, {feed.generatedDate}.</>
          )}
        </p>
      </div>

      {
        feed.hasFeed ? (
          <ol class="feed" role="list">
            {feed.items.map((it: any) => (
              <li class="feed-row">
                <div class="feed-main">
                  <span class="feed-name">{it.displayName}</span>
                  <span class="feed-date tnum">{it.dateLabel}</span>
                </div>
                <div class="feed-meta">
                  <span class="feed-shots tnum">
                    {it.shots.toLocaleString()} shot{it.shots === 1 ? "" : "s"}
                  </span>
                  <span class="feed-dot" aria-hidden="true">·</span>
                  <span class="feed-monitor">{it.launchMonitor}</span>
                </div>
                <div class="feed-clubs">
                  {it.clubs.map((club: string) => (
                    <span class="feed-club tnum">{club}</span>
                  ))}
                </div>
              </li>
            ))}
          </ol>
        ) : (
          <div class="card feed-empty">
            <p class="text-muted" style="max-width:60ch;">
              No shared sessions yet. When someone contributes, their chosen name
              and what they hit show up here, and you can be the first.
            </p>
            <div class="hero-cta" style="margin-top:1.1rem;">
              <a href="/download" class="btn btn-primary">Contribute your sessions</a>
            </div>
          </div>
        )
      }
    </section>

    {/* ---- Method (details live on /lab#methodology) ---- */}
    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">Method</p>
        <h2>Why you can trust these numbers</h2>
        <p class="text-muted" style="max-width:66ch;">
          Every value on this page comes out of a six-stage pipeline, consent
          gate, in-app anonymization, quality screening, one golfer one vote,
          robust medians, and a publish threshold, with every rule versioned
          and enforced in code anyone can read. The
          <a href="/lab#methodology"> full methodology</a> spells out each
          stage, the trust tiers, and the limits we publish alongside the data.
        </p>
      </div>
    </section>

    {/* ---- What's coming to this section ---- */}
    <section class="lab-band">
      <div class="lab-band-head">
        <span class="pill lab-band-pill progress">Next up</span>
        <h2>Coming to Community Data</h2>
        <p class="text-muted" style="max-width:66ch;">
          The aggregator already computes more than this page shows. These land
          as the contributor count supports them, see the
          <a href="/lab#roadmap"> full roadmap</a>.
        </p>
      </div>
      <div class="lab-planned-grid">
        <div class="lab-planned">
          <div class="lab-planned-head">
            <h3>Ball comparisons</h3>
            <span class="pill lab-planned-pill">Planned</span>
          </div>
          <p>
            The question that started this project: what does a premium ball
            actually do for your game, measured across thousands of real shots
            instead of a robot test and a marketing budget?
          </p>
        </div>
        <div class="lab-planned">
          <div class="lab-planned-head">
            <h3>Gapping by handicap</h3>
            <span class="pill lab-planned-pill">Planned</span>
          </div>
          <p>
            What real distance gaps look like at your level, so you can tell a
            genuine hole in your set from a number you read in a magazine.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .lab-planned-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--gap);
  }

  /* ---- Contributions feed ---- */
  .feed {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .feed-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas: "main meta" "clubs clubs";
    gap: 0.35rem 1rem;
    padding: 0.9rem 1.1rem;
  }
  .feed-row + .feed-row {
    border-top: 1px solid var(--border);
  }
  .feed-main {
    grid-area: main;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    min-width: 0;
  }
  .feed-name {
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .feed-date {
    color: var(--text-dim);
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .feed-meta {
    grid-area: meta;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-dim);
    font-size: 0.85rem;
    white-space: nowrap;
  }
  .feed-shots {
    color: var(--text-muted);
  }
  .feed-dot {
    color: var(--border-strong);
  }
  .feed-clubs {
    grid-area: clubs;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .feed-club {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1;
    padding: 0.25rem 0.4rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }
  .feed-empty {
    max-width: 620px;
  }
  @media (max-width: 540px) {
    .feed-row {
      grid-template-columns: 1fr;
      grid-template-areas: "main" "meta" "clubs";
    }
    .feed-meta {
      justify-content: flex-start;
    }
  }
  .empty-cta {
    max-width: 620px;
  }
  .empty-cta h3 {
    margin-bottom: 0.5rem;
  }

  /* ---- Community tiers (CSS-only tabs; no client JS) ---- */
  .tiers {
    position: relative;
  }
  .tier-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .tier-labels {
    display: inline-flex;
    gap: 0.25rem;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 0.25rem;
    margin-bottom: 1.5rem;
  }
  .tier-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .tier-label:hover {
    color: var(--text-muted);
  }
  .tier-count {
    font-size: 0.78rem;
    color: var(--text-dim);
    background: var(--bg-elevated);
    padding: 0.05rem 0.4rem;
    border-radius: 999px;
  }
  /* active tab (driven by the checked radio) */
  #tier-all:checked ~ .tier-labels label[for="tier-all"],
  #tier-verified:checked ~ .tier-labels label[for="tier-verified"],
  #tier-reference:checked ~ .tier-labels label[for="tier-reference"] {
    color: var(--green-ink);
    background: var(--green);
  }
  #tier-all:checked ~ .tier-labels label[for="tier-all"] .tier-count,
  #tier-verified:checked ~ .tier-labels label[for="tier-verified"] .tier-count,
  #tier-reference:checked ~ .tier-labels label[for="tier-reference"] .tier-count {
    color: var(--green-ink);
    background: rgba(20, 19, 17, 0.16);
  }
  .tier-radio:focus-visible ~ .tier-labels {
    outline: 2px solid var(--green);
    outline-offset: 2px;
  }
  .tier-panel {
    display: none;
  }
  #tier-all:checked ~ .panel-all,
  #tier-verified:checked ~ .panel-verified,
  #tier-reference:checked ~ .panel-reference {
    display: block;
  }
  .tier-blurb {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin-bottom: 1.1rem;
  }
  .tier-empty {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    border: 1px dashed var(--border-strong);
    padding: 1rem 1.25rem;
    max-width: 560px;
  }

  /* norms table */
  .norms-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    background: var(--surface);
    max-width: 760px;
  }
  .norms {
    width: 100%;
    border-collapse: collapse;
    min-width: 460px;
  }
  .norms th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 600;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .norms td {
    padding: 0.55rem 0.9rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.9rem;
    vertical-align: baseline;
  }
  .norms tr:last-child td {
    border-bottom: none;
  }
  .norms-club {
    color: var(--green);
    font-family: var(--font-head);
    font-weight: 600;
  }
  .norms-big {
    color: var(--text);
    font-weight: 600;
  }
  .norms-unit {
    color: var(--text-dim);
    font-size: 0.78rem;
    margin-left: 0.15rem;
  }
  .norms-range {
    display: block;
    color: var(--text-dim);
    font-size: 0.78rem;
  }
  .norms-n {
    color: var(--text-dim);
  }
  .lock {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--amber);
    border: 1px solid var(--amber);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
    white-space: nowrap;
  }

  /* driver dispersion ellipse */
  .disp {
    margin-top: 1.75rem;
    max-width: 260px;
  }
  .disp-title {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }
  .disp-svg {
    width: 100%;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .disp-axis {
    stroke: var(--border-strong);
    stroke-width: 1;
  }
  .disp-ell {
    fill: var(--green-tint);
    stroke: var(--green);
    stroke-width: 1.5;
  }
  .disp-center {
    fill: var(--green);
  }
  .disp-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
