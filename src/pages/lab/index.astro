---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LabNav from "../../components/LabNav.astro";
import { GITHUB_URL, GITHUB_WATCH_URL } from "../../consts";
import { loadCommunity } from "../../lib/lab";
import "../../styles/lab.css";

const title = "The Lab";
const description =
  "The OpenGolfLab hub for GSPro-driven community analytics, the vision, methodology and roadmap for open, crowd-sourced golf analytics: real-world ball comparisons, gapping by handicap, and launch/spin norms built from anonymized GSPro sessions.";

const { minContributors } = loadCommunity();

// The plan in three acts, the old /lab/roadmap page, distilled into a story.
// Deliberately no dates: this is a free project built in spare time; a missed
// date is a broken promise, an ordered list is not.
const acts = [
  {
    mark: "✓",
    state: "done",
    stateLabel: "Shipped",
    title: "Build the instruments",
    body: "Golf Sim Analytics captures every GSPro shot automatically, free. The Gear Guide maps every major driver, iron, wedge and ball at today's prices. And the contribution pipeline, opt-in only, anonymized on your machine, every shot screened, is built and tested end to end.",
  },
  {
    mark: "◐",
    state: "now",
    stateLabel: "Happening now",
    title: "Collect the first dataset",
    body: "Everything upstream works. What's left is contributors: no club publishes until enough golfers have submitted it, so the numbers are worth trusting on day one. Every opt-in session moves the bar.",
  },
  {
    mark: "○",
    state: "next",
    stateLabel: "What it unlocks",
    title: "Answer what nobody else can",
    body: "Once the dataset clears its thresholds, the questions that started this project get real answers:",
  },
];

// Act III payoffs, the reason to get excited.
const payoffs = [
  {
    name: "Ball comparisons",
    detail:
      "What a premium ball actually does for your game, measured across thousands of real shots, not a robot and a marketing budget. The question that started this project.",
  },
  {
    name: "Gapping by handicap",
    detail:
      "What real distance gaps look like at your level, so you can tell a genuine hole in your set from a magazine number.",
  },
  {
    name: "Norms by swing speed",
    detail:
      "Launch, spin and dispersion norms sliced by driver speed, a 95 mph twelve and a 108 mph twelve need different answers.",
  },
  {
    name: "Old club vs. new",
    detail:
      "What does a 2020 driver actually give up to a 2026? Real golfers and real shots, instead of robot tests.",
  },
  {
    name: "Launch monitors, compared",
    detail:
      "Systematic spin and carry differences between devices, quantified from golfers who log shots on more than one unit, instead of argued about forever.",
  },
  {
    name: "An open public dataset",
    detail:
      "The anonymized aggregate, published for anyone to analyze and cite: versioned, documented, and free. The 'open' in the name, made literal.",
  },
];

// ---- Methodology (merged from the old /lab/methodology page) ---------------
// The pipeline, stage by stage, told the way you'd explain it to a friend —
// the enforcement details stay, the jargon doesn't. The narrative version is
// the "How it works" band above; the privacy details live on /privacy.
const stages = [
  {
    n: "01",
    title: "You play, the app records",
    body: `Golf Sim Analytics captures every GSPro shot automatically while you play, range sessions and full rounds alike. It all lives on your machine, and the app is fully useful without ever sharing a thing.`,
  },
  {
    n: "02",
    title: "Sending your data is your call",
    body: `Sharing is off until you switch it on, and the app literally cannot export without that recorded choice (consent policy v1.0); there is no code path around it. Change your mind and future exports stop on the spot.`,
  },
  {
    n: "03",
    title: "Your name stays home",
    body: `The bundle is built on your PC before anything is sent, anonymization is not a server-side promise. Shot metrics only (data format v1.1): names, file paths and timestamps are stripped out by construction, and a random id exists just so the same submission can't be counted twice.`,
    link: { href: "/privacy", label: "Exactly what's in a bundle →" },
  },
  {
    n: "04",
    title: "Every shot gets screened",
    body: `A submission has to carry real measurements (ball speed, launch angle, spin and carry, per club) or it never enters the pool. Then the implausible stuff is dropped before it can touch a published number: the 280-yard "7-iron", the wedge spinning like a driver, shots logged under the wrong club.`,
  },
  {
    n: "05",
    title: "Every golfer counts once",
    body: `Before pooling, each contributor is boiled down to one summary per club. What we publish is the middle of the crowd: the median, with the 10th–90th percentile range around it. A golfer who uploads every night and one who shares a single session move the result exactly the same amount, so enthusiasm can't tilt a benchmark, and neither can one perfect drive or one cold top.`,
  },
  {
    n: "06",
    title: "Benchmarks wait for a crowd",
    body: `Nothing publishes until at least ${minContributors} golfers have contributed it. Below that, the number simply doesn't exist publicly; we'd rather show nothing than sway your opinion (or your wallet) with a thin sample. As the pool grows, so do the views: club and ball benchmarks first, then launch monitor, age and handicap cuts.`,
  },
];

// Trust tiers: how declared hardware and track record gate what publishes.
const tiers = [
  {
    name: "All",
    who: "Every contribution that clears validation and screening.",
    adds: "Carry, launch and dispersion norms from the widest pool.",
  },
  {
    name: "Verified",
    who: "Contributors on spin-measuring hardware (camera units and high-end radar), with a consistent submission history.",
    adds: "Spin publishes here and above, measured, not modeled.",
  },
  {
    name: "Reference",
    who: "A curated core of vetted, long-running contributors.",
    adds: "The benchmark cut: highest-confidence numbers, smallest pool.",
  },
];

// Honest limits. Publishing these is part of the method.
const limits = [
  {
    title: "Instruments are self-declared",
    body: "The app can't inspect your launch monitor. A declared model is spoofable, which is why it only gates a contribution's ceiling tier, never its acceptance, and why the spin-measuring allowlist is kept deliberately conservative.",
  },
  {
    title: "It's simulator golf",
    body: "Sessions come from indoor bays: mats, controlled air, GSPro's flight model for anything past impact. Carry and launch measurements transfer well; total distance and rollout are model outputs, and the numbers are read accordingly.",
  },
  {
    title: "The crowd is self-selected",
    body: "Sim owners skew more equipment-invested than golf at large. Norms describe this population honestly; they are not a census of all golfers.",
  },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-tight lab-hero">
    <div class="grid-bg"></div>
    <div class="container lab-hero-inner">
      <span class="pill lab-status">◐ Community dataset in progress</span>
      <h1>The Lab</h1>
      <p class="lede" style="margin-top:1rem;">
        Every shot from your launch monitor tells a story about your game, but
        the bigger picture requires a crowd. The Lab is GSPro-driven community
        analytics: anonymized simulator sessions aggregated to build what no
        individual can, community-driven
        ball and club comparisons, true gapping by handicap, and launch and spin
        norms to help you find the absolute best equipment for your game.
      </p>
      <div class="hero-cta" style="margin-top:1.6rem;">
        <a href="/download" class="btn btn-primary">Get the app</a>
        <a href={GITHUB_WATCH_URL} class="btn btn-secondary" rel="noopener">
          Watch the repo
        </a>
      </div>
      <p class="lab-noemail">
        No newsletter, no sign-up. Watch the
        <a href={GITHUB_URL} rel="noopener">GitHub repo</a> or follow the
        <a href="/blog">blog</a> and you'll know the moment data goes live.
      </p>
    </div>
  </section>

  <LabNav />

  <div class="container lab-body">
    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">How it works</p>
        <h2>From your bay to the dataset</h2>
      </div>
      <ol class="lab-flow">
        <li>
          <span class="lab-flow-n tnum">01</span>
          <h3>You play</h3>
          <p>
            <a href="/golf-sim-analytics">Golf Sim Analytics</a> captures every
            GSPro session automatically. Everything stays on your machine by
            default, the app is fully useful without ever contributing.
          </p>
        </li>
        <li>
          <span class="lab-flow-n tnum">02</span>
          <h3>You opt in</h3>
          <p>
            If you choose to, the app exports an anonymized bundle: ball and
            club metrics plus your launch monitor model. No name, no account, no
            course, no scores. See <a href="/privacy">data &amp; privacy</a>.
          </p>
        </li>
        <li>
          <span class="lab-flow-n tnum">03</span>
          <h3>We aggregate</h3>
          <p>
            Screening drops mislabeled and implausible shots. Each golfer
            counts once, one summary per club, then results publish as
            medians with 10th–90th percentile ranges, so no single big
            session can move a number. The exact rules are in the
            <a href="#methodology"> methodology</a>.
          </p>
        </li>
        <li>
          <span class="lab-flow-n tnum">04</span>
          <h3>Everyone gets it back</h3>
          <p>
            Results publish here, free and open, split into quality tiers so you
            can decide how much trust a number has earned.
          </p>
        </li>
      </ol>
    </section>

    <section class="lab-band" id="methodology">
      <div class="lab-band-head">
        <p class="eyebrow">Methodology</p>
        <h2>Six stages, from your bay to a benchmark</h2>
        <p class="text-muted" style="max-width:66ch;">
          Crowd-sourced data is easy to do badly, so every rule here is
          specific, versioned, and enforced in code anyone can read. Nothing
          in this section is aspirational, each stage exists in the shipped
          pipeline today.
        </p>
      </div>
      <ol class="stages">
        {
          stages.map((s) => (
            <li class="stage">
              <span class="stage-n tnum">{s.n}</span>
              <div class="stage-body">
                <h3>{s.title}</h3>
                <p>{s.body}</p>
                {s.link && <a class="stage-link" href={s.link.href}>{s.link.label}</a>}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">Trust tiers</p>
        <h2>Hardware gates trust, never acceptance</h2>
        <p class="text-muted" style="max-width:66ch;">
          Every accepted contribution counts somewhere. What a declared launch
          monitor changes is how far up the trust ladder its numbers can
          publish.
        </p>
      </div>
      <div class="tiers-table" role="table" aria-label="Trust tiers">
        <div class="tiers-row tiers-head" role="row">
          <span role="columnheader">Tier</span>
          <span role="columnheader">Who's in it</span>
          <span role="columnheader">What it adds</span>
        </div>
        {
          tiers.map((t) => (
            <div class="tiers-row" role="row">
              <span class="tier-name" role="cell">{t.name}</span>
              <span role="cell">{t.who}</span>
              <span role="cell">{t.adds}</span>
            </div>
          ))
        }
      </div>
      <p class="tiers-note text-muted">
        Spin is the tier system's sharpest edge: some monitors estimate spin
        rather than measure it, so spin values publish only from the Verified
        tier up. The allowlist of spin-measuring hardware is maintained in the
        open and errs toward exclusion.
      </p>
    </section>

    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">Change control</p>
        <h2>Versioned, dated, regenerated</h2>
        <p class="text-muted" style="max-width:66ch;">
          The data format (v1.1) and consent policy (v1.0) are explicitly
          versioned, if either changes, the version bumps, the in-app consent
          screen and <a href="/privacy">privacy page</a> update to match, and
          the change applies going forward only. Published aggregates carry
          their generation date, and the whole dataset is regenerated rather
          than patched, so a published number is always reproducible from the
          rules that made it.
        </p>
      </div>
    </section>

    <section class="lab-band">
      <div class="lab-band-head">
        <p class="eyebrow">Known limits</p>
        <h2>What this data can't claim</h2>
        <p class="text-muted" style="max-width:66ch;">
          Publishing the limits is part of the method. Three we consider
          structural:
        </p>
      </div>
      <div class="limits">
        {
          limits.map((l) => (
            <div class="limit card">
              <h3>{l.title}</h3>
              <p>{l.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="lab-band" id="roadmap">
      <div class="lab-band-head">
        <p class="eyebrow">The plan</p>
        <h2>Where this is headed</h2>
        <p class="text-muted" style="max-width:66ch;">
          No dates, this is a free project built in spare time, and a missed
          date is a broken promise. Order is a real signal; timing isn't.
        </p>
      </div>

      <ol class="acts">
        {
          acts.map((a) => (
            <li class:list={["act", `is-${a.state}`]}>
              <span class="act-mark" aria-hidden="true">{a.mark}</span>
              <div class="act-body">
                <p class="act-state">{a.stateLabel}</p>
                <h3>{a.title}</h3>
                <p class="act-detail">{a.body}</p>
                {a.state === "next" && (
                  <ul class="payoffs">
                    {payoffs.map((p) => (
                      <li class="card payoff">
                        <h4>{p.name}</h4>
                        <p>{p.detail}</p>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          ))
        }
      </ol>

      <p class="exploring text-muted">
        Further out, ideas we like but haven't committed to: handicap tracking
        and a voice caddy. <a href={GITHUB_URL} rel="noopener">Open an issue</a>
        if one matters to you, that's how it moves up.
      </p>
    </section>

    <section class="lab-band lab-band-cta">
      <div class="card lab-cta-card">
        <h2>Help shape what comes next</h2>
        <p class="text-muted" style="margin-top:0.5rem;max-width:56ch;">
          The Lab is built in the open, and this plan is shaped by what people
          actually ask for. Feature requests, opinions on what data to collect,
          and privacy scrutiny are all equally welcome.
        </p>
        <div class="hero-cta" style="margin-top:1.2rem;">
          <a href={GITHUB_URL} class="btn btn-primary" rel="noopener">
            Open on GitHub
          </a>
          <a href="/download" class="btn btn-secondary">Get the app</a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ---- How it works ---- */
  .lab-flow {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: var(--gap);
    counter-reset: flow;
  }
  .lab-flow li {
    border-top: 1px solid var(--border-strong);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lab-flow-n {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .lab-flow h3 {
    font-size: 1.05rem;
  }
  .lab-flow p {
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  /* ---- The plan: three acts ---- */
  .acts {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .act {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.9rem;
    padding-block: 1.4rem;
  }
  .act + .act {
    border-top: 1px solid var(--border);
  }
  .act-mark {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    line-height: 1.4;
    text-align: center;
  }
  .is-done .act-mark {
    color: var(--green);
  }
  .is-now .act-mark {
    color: var(--amber);
  }
  .is-next .act-mark {
    color: var(--text-dim);
  }
  .act-state {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.25rem;
  }
  .is-done .act-state {
    color: var(--green);
  }
  .is-now .act-state {
    color: var(--amber);
  }
  .act h3 {
    font-size: 1.3rem;
  }
  .act-detail {
    margin-top: 0.45rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 66ch;
  }

  .payoffs {
    list-style: none;
    padding: 0;
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }
  .payoff h4 {
    font-size: 1.02rem;
  }
  .payoff p {
    margin-top: 0.35rem;
    color: var(--text-dim);
    font-size: 0.88rem;
  }

  .exploring {
    margin-top: 1.4rem;
    font-size: 0.9rem;
  }

  /* ---- Methodology: pipeline stages ---- */
  .stages {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .stage {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.9rem;
    padding-block: 1.15rem;
  }
  .stage + .stage {
    border-top: 1px solid var(--border);
  }
  .stage-n {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--green);
    letter-spacing: 0.1em;
    padding-top: 0.2rem;
  }
  .stage h3 {
    font-size: 1.15rem;
  }
  .stage p {
    margin-top: 0.4rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 68ch;
  }
  .stage-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--green);
  }

  /* ---- Methodology: trust tiers table ---- */
  .tiers-table {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .tiers-row {
    display: grid;
    grid-template-columns: 7rem 1.4fr 1fr;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    font-size: 0.92rem;
    color: var(--text-muted);
    background: var(--surface);
  }
  .tiers-row + .tiers-row {
    border-top: 1px solid var(--border);
  }
  .tiers-head {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--bg-elevated);
  }
  .tier-name {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--green);
  }
  .tiers-note {
    margin-top: 1rem;
    font-size: 0.9rem;
    max-width: 68ch;
  }

  /* ---- Methodology: known limits ---- */
  .limits {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .limit h3 {
    font-size: 1.05rem;
  }
  .limit p {
    margin-top: 0.4rem;
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .limits {
      grid-template-columns: 1fr;
    }
    .tiers-row {
      grid-template-columns: 5rem 1fr;
    }
    .tiers-row span[role="cell"]:last-child,
    .tiers-head span:last-child {
      grid-column: 2;
    }
  }

  @media (max-width: 700px) {
    .payoffs {
      grid-template-columns: 1fr;
    }
  }
</style>
