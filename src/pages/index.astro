---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PRODUCT_NAME } from "../consts";

const problems = [
  {
    title: "Sample sizes of a dozen",
    body: "Most “definitive” ball and club reviews rest on a handful of shots from one or two testers on one launch monitor. That's not data — it's an anecdote with a chart.",
  },
  {
    title: "Everyone tests differently",
    body: "Different balls, different swings, different conditions, different software. Two reviews reach opposite conclusions because they never measured the same way.",
  },
  {
    title: "Conclusions dressed as truth",
    body: "Limited tests get published as gospel, and golfers buy equipment based on numbers that would never survive a real sample.",
  },
];

const framework = [
  {
    n: "01",
    title: "One standardized method",
    body: "A shared, documented protocol for how a test is run and what gets recorded — so every contribution is measured the same way.",
  },
  {
    n: "02",
    title: "Thousands of shots, many players",
    body: "Instead of one tester's dozen swings, aggregate data from a whole community across skill levels, swings and setups.",
  },
  {
    n: "03",
    title: "Comparisons you can trust",
    body: "Real distributions — ball performance, club gapping by handicap, launch and spin norms — with the sample size to back them up.",
  },
];
---

<BaseLayout>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <img
        src="/images/course_bg.jpg"
        alt=""
        width="2400"
        height="1350"
        fetchpriority="high"
      />
      <div class="hero-scrim"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="container hero-inner">
      <span class="pill hero-openpill">◆ Open &amp; free · community-powered</span>
      <h1 class="hero-title">Golf equipment testing, done in the open.</h1>
      <p class="lede hero-lede">
        Every ball and club “review” you've read is built on a handful of shots.
        OpenGolfLab is a free, community effort to fix that — crowd-sourcing
        thousands of standardized tests so golfers can finally compare gear on
        real data, not anecdotes.
      </p>

      <div class="hero-cta">
        <a href="/lab" class="btn btn-primary btn-lg">See the mission</a>
        <a href="/golf-sim-analytics" class="btn btn-secondary btn-lg">Get the app</a>
      </div>

      <div class="hero-chips" role="list" aria-label="What makes the data trustworthy">
        <span class="stat-chip" role="listitem"><span class="label">Method</span><b>Standardized</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Sample</span><b>Crowd-sourced</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Cost</span><b>Free</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Data</span><b>Open</b></span>
      </div>
    </div>
  </section>

  <!-- ========================= THE PROBLEM ========================= -->
  <section class="section" id="why">
    <div class="container">
      <p class="eyebrow">Why this exists</p>
      <h2 class="mission-h">The way golf gear gets tested is broken</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:64ch;">
        Picking a ball or a driver should be an evidence-based decision. Instead,
        the “evidence” is usually a tiny, one-off test that gets treated as the
        final word. Three problems show up everywhere:
      </p>

      <div class="problem-grid">
        {
          problems.map((p) => (
            <article class="card problem">
              <span class="problem-tag" aria-hidden="true">Problem</span>
              <h3>{p.title}</h3>
              <p class="text-muted">{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================= THE SOLUTION ========================= -->
  <section class="section solution" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">The fix</p>
      <h2 class="mission-h">Crowd-source the tests. Standardize the method.</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:64ch;">
        One tester can't produce trustworthy comparisons. A community can — but
        only if everyone measures the same way. That's the whole idea behind
        OpenGolfLab: a robust intercomparison framework so thousands of
        contributions add up to something real.
      </p>

      <ol class="framework">
        {
          framework.map((f) => (
            <li class="step card">
              <span class="step-n tnum">{f.n}</span>
              <h3>{f.title}</h3>
              <p class="text-muted">{f.body}</p>
            </li>
          ))
        }
      </ol>

      <p class="framework-foot text-muted">
        The community analytics hub — real ball comparisons, gapping by handicap,
        launch &amp; spin norms — lives in <a href="/lab">the Lab</a>.
      </p>
    </div>
  </section>

  <!-- ==================== THE TOOL (APP) ==================== -->
  <section class="section">
    <div class="container">
      <div class="tool card">
        <div class="tool-copy">
          <p class="eyebrow">How you contribute</p>
          <h2>{PRODUCT_NAME} is the instrument</h2>
          <p class="text-muted" style="margin-top:0.85rem;max-width:52ch;">
            You can't crowd-source data without a consistent way to capture it.
            Golf Sim Analytics is our free Windows app for GSPro that records
            every shot automatically — carry, ball speed, launch, spin, smash —
            and turns it into 15 interactive dashboards. Practice better today,
            and (opt-in) help build the shared dataset tomorrow.
          </p>
          <ul class="tool-points">
            <li>Zero-click capture from GSPro — no import step</li>
            <li>15 dashboards, deep per-shot metrics, Tour &amp; handicap benchmarks</li>
            <li>Local-first &amp; private — your raw data never leaves your machine</li>
          </ul>
          <div class="hero-cta">
            <a href="/golf-sim-analytics" class="btn btn-primary">Explore the app</a>
            <a href="/download" class="btn btn-secondary">Download for Windows</a>
          </div>
        </div>
        <div class="tool-shot">
          <img
            src="/images/screenshots/dispersion.jpg"
            alt="Golf Sim Analytics dispersion dashboard plotting shot landing positions by club against an ideal target ellipse."
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== OPEN & FREE CALLOUT ==================== -->
  <section class="section-tight">
    <div class="container">
      <div class="openfree">
        <div class="grid-bg" style="opacity:0.6"></div>
        <div class="openfree-inner">
          <h2>Open source. Free forever. No catch.</h2>
          <p class="lede mx-auto" style="text-align:center;margin-top:0.8rem;">
            The app is free, the data will be open, and the whole project is
            built in public on GitHub. No paywalls, no accounts, no selling your
            swing. If OpenGolfLab is useful to you, a coffee keeps it caffeinated
            — but nothing here is ever locked away.
          </p>
          <div class="hero-cta" style="justify-content:center;">
            <a href="/lab" class="btn btn-primary">Join the effort</a>
            <a href="/blog" class="btn btn-secondary">Follow the blog</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  /* Scrim keeps text at WCAG AA over any photo. */
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(13, 17, 23, 0.72) 0%, rgba(13, 17, 23, 0.86) 60%, var(--bg) 100%),
      radial-gradient(120% 90% at 50% -10%, rgba(61, 220, 132, 0.12), transparent 55%);
  }
  .hero .grid-bg {
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 11vw, 8rem) clamp(3rem, 7vw, 5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-openpill {
    color: var(--green);
    border-color: var(--green-dim);
    background: rgba(13, 17, 23, 0.5);
    margin-bottom: 1.2rem;
  }
  .hero-title {
    max-width: 18ch;
    background: linear-gradient(180deg, #ffffff 0%, #cdd8e2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    margin-top: 1.2rem;
    text-align: center;
    color: #cbd5e0;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
    justify-content: center;
  }
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 2rem;
  }

  /* ---- Shared section headings ---- */
  .mission-h {
    max-width: 22ch;
  }

  /* ---- Problem grid ---- */
  .problem-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .problem {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .problem-tag {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
    margin-bottom: 0.7rem;
  }
  .problem h3 {
    font-size: 1.12rem;
  }

  /* ---- Framework steps ---- */
  .framework {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .step-n {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .step h3 {
    margin-top: 0.6rem;
    font-size: 1.2rem;
  }
  .step p {
    margin-top: 0.4rem;
  }
  .framework-foot {
    margin-top: 1.5rem;
    font-size: 0.98rem;
  }

  /* ---- Tool (app) split ---- */
  .tool {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .tool-copy {
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }
  .tool-points {
    margin: 1.2rem 0 1.6rem;
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .tool-points li {
    position: relative;
    padding-left: 1.7rem;
    color: var(--text-muted);
  }
  .tool-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--green);
    box-shadow: 0 0 10px var(--green-glow);
  }
  .tool-shot {
    position: relative;
    border-left: 1px solid var(--border);
    min-height: 260px;
    background: var(--bg-elevated);
  }
  .tool-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---- Open & free callout ---- */
  .openfree {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .openfree-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .problem-grid,
    .framework {
      grid-template-columns: 1fr;
    }
    .tool {
      grid-template-columns: 1fr;
    }
    .tool-shot {
      border-left: none;
      border-top: 1px solid var(--border);
      min-height: 220px;
      order: -1;
    }
  }
</style>
