---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PRODUCT_NAME } from "../consts";

// One positive trio — replaces the old "problems" + "framework" sections.
const ideas = [
  {
    n: "01",
    title: "More shots, more signal",
    body: "Any single test is limited by how many shots one person can hit. Pool thousands across a community and the patterns become something you can actually trust.",
  },
  {
    n: "02",
    title: "One shared method",
    body: "Everyone measures the same way, following one open, documented protocol — so contributions add up to comparisons that are truly apples-to-apples.",
  },
  {
    n: "03",
    title: "Open results, for everyone",
    body: "Real ball comparisons, club gapping by handicap, launch and spin norms — free and open for any golfer to use.",
  },
];
---

<BaseLayout>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <img
        src="/images/course_bg.jpg"
        alt=""
        width="2400"
        height="1350"
        fetchpriority="high"
      />
      <div class="hero-scrim"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="container hero-inner">
      <span class="pill hero-openpill">◆ Open &amp; free · community-powered</span>
      <h1 class="hero-title">Better gear decisions, together.</h1>
      <p class="lede hero-lede">
        Most equipment tests are small by necessity — one tester, a handful of
        shots. Pooled across a community and measured the same way, that data
        can go a lot further. OpenGolfLab is a free, open effort to help make
        that happen.
      </p>

      <div class="hero-cta">
        <a href="/lab" class="btn btn-primary btn-lg">See the mission</a>
        <a href="/golf-sim-analytics" class="btn btn-secondary btn-lg">Get the app</a>
      </div>

      <div class="hero-chips" role="list" aria-label="What shapes the data">
        <span class="stat-chip" role="listitem"><span class="label">Method</span><b>Standardized</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Sample</span><b>Crowd-sourced</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Cost</span><b>Free</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Data</span><b>Open</b></span>
      </div>
    </div>
  </section>

  <!-- ========================= THE IDEA ========================= -->
  <section class="section" id="why">
    <div class="container">
      <p class="eyebrow">Why this exists</p>
      <h2 class="mission-h">Great gear decisions deserve more data</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:64ch;">
        Choosing a ball or a driver should lean on real evidence. The more shots,
        players and consistency behind a comparison, the more you can trust it —
        and that's exactly the kind of thing a community can build together.
      </p>

      <ol class="idea-grid">
        {
          ideas.map((it) => (
            <li class="card idea">
              <span class="idea-n tnum">{it.n}</span>
              <h3>{it.title}</h3>
              <p class="text-muted">{it.body}</p>
            </li>
          ))
        }
      </ol>

      <p class="idea-foot text-muted">
        The community analytics hub — comparisons, gapping by handicap, launch
        &amp; spin norms — is taking shape in <a href="/lab">the Lab</a>.
      </p>
    </div>
  </section>

  <!-- ==================== THE TOOL (APP) ==================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="tool card">
        <div class="tool-copy">
          <p class="eyebrow">How you can help</p>
          <h2>{PRODUCT_NAME} is the instrument</h2>
          <p class="text-muted" style="margin-top:0.85rem;max-width:52ch;">
            Consistent data needs a consistent way to capture it. Our free
            Windows app for GSPro records every shot automatically and turns it
            into 15 dashboards — so you get sharper practice today, and (only if
            you opt in) can help build the shared dataset tomorrow.
          </p>
          <div class="hero-cta">
            <a href="/golf-sim-analytics" class="btn btn-primary">Explore the app</a>
            <a href="/download" class="btn btn-secondary">Download for Windows</a>
          </div>
        </div>
        <div class="tool-shot">
          <img
            src="/images/screenshots/dispersion.jpg"
            alt="Golf Sim Analytics dispersion dashboard plotting shot landing positions by club against an ideal target ellipse."
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== OPEN & FREE CALLOUT ==================== -->
  <section class="section-tight">
    <div class="container">
      <div class="openfree">
        <div class="grid-bg" style="opacity:0.6"></div>
        <div class="openfree-inner">
          <h2>Open source. Free forever. No catch.</h2>
          <p class="lede mx-auto" style="text-align:center;margin-top:0.8rem;">
            The app is free, the data will be open, and the whole project is
            built in public on GitHub. No paywalls, no accounts, no selling your
            swing. If OpenGolfLab is useful to you, a coffee keeps it caffeinated
            — but nothing here is ever locked away.
          </p>
          <div class="hero-cta" style="justify-content:center;">
            <a href="/lab" class="btn btn-primary">Follow the effort</a>
            <a href="/blog" class="btn btn-secondary">Read the blog</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(13, 17, 23, 0.72) 0%, rgba(13, 17, 23, 0.86) 60%, var(--bg) 100%),
      radial-gradient(120% 90% at 50% -10%, rgba(61, 220, 132, 0.12), transparent 55%);
  }
  .hero .grid-bg {
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 11vw, 8rem) clamp(3rem, 7vw, 5rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-openpill {
    color: var(--green);
    border-color: var(--green-dim);
    background: rgba(13, 17, 23, 0.5);
    margin-bottom: 1.2rem;
  }
  .hero-title {
    max-width: 20ch;
    background: linear-gradient(180deg, #ffffff 0%, #cdd8e2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    margin-top: 1.2rem;
    text-align: center;
    color: #cbd5e0;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
    justify-content: center;
  }
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .mission-h {
    max-width: 22ch;
  }

  /* ---- Idea trio ---- */
  .idea-grid {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .idea {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .idea-n {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .idea h3 {
    margin-top: 0.5rem;
    font-size: 1.2rem;
  }
  .idea-foot {
    margin-top: 1.5rem;
    font-size: 0.98rem;
  }

  /* ---- Tool (app) split ---- */
  .tool {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .tool-copy {
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }
  .tool-shot {
    position: relative;
    border-left: 1px solid var(--border);
    min-height: 260px;
    background: var(--bg-elevated);
  }
  .tool-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ---- Open & free callout ---- */
  .openfree {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .openfree-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 900px) {
    .idea-grid {
      grid-template-columns: 1fr;
    }
    .tool {
      grid-template-columns: 1fr;
    }
    .tool-shot {
      border-left: none;
      border-top: 1px solid var(--border);
      min-height: 220px;
      order: -1;
    }
  }
</style>
