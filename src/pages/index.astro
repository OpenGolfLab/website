---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import { PRODUCT_NAME, KOFI_URL, GITHUB_URL } from "../consts";

// Real counts, computed at build from the driver lineup dataset — no slogans.
let lineupsData: any = null;
try {
  const rp = path.resolve("public/data/driver-lineups.json");
  if (fs.existsSync(rp)) lineupsData = JSON.parse(fs.readFileSync(rp, "utf-8"));
} catch {
  lineupsData = null;
}
const lineups = lineupsData?.lineups ?? [];
const driverCount = lineups.reduce((n: number, l: any) => n + (l.models?.length ?? 0), 0);
const brandCount = lineups.length;

// One positive trio — replaces the old "problems" + "framework" sections.
const ideas = [
  {
    n: "01",
    title: "More shots, more signal",
    body: "Any single test is limited by how many shots one person can hit. Pool thousands across a community and the patterns become something you can actually trust.",
  },
  {
    n: "02",
    title: "One shared method",
    body: "Everyone measures the same way, following one open, documented protocol — so contributions add up to comparisons that are truly apples-to-apples.",
  },
  {
    n: "03",
    title: "Open results, for everyone",
    body: "Real ball comparisons, club gapping by handicap, launch and spin norms — free and open for any golfer to use.",
  },
];
---

<BaseLayout>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <picture>
        <source media="(max-width: 760px)" srcset="/images/course_bg-mobile.jpg" />
        <img
          src="/images/course_bg.jpg"
          alt=""
          width="2400"
          height="1350"
          fetchpriority="high"
        />
      </picture>
      <div class="hero-scrim"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="container hero-inner">
      <span class="pill hero-openpill">◆ Open &amp; free · community-powered</span>
      <h1 class="hero-title">The Open Engine for Golf Analytics</h1>
      <p class="lede hero-lede">
        Harnessing the power of the sim community so you can stop guessing on
        your gear purchases.
      </p>

      <div class="hero-cta">
        <a href="/download" class="btn btn-primary btn-lg">Download the free app</a>
        <a href="/lab" class="btn btn-secondary btn-lg">Preview the Lab ↗</a>
      </div>

      <div class="hero-chips" role="list" aria-label="At a glance">
        <span class="stat-chip" role="listitem"><span class="label">Dashboards</span><b>15</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Drivers tracked</span><b>{driverCount}</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Brands</span><b>{brandCount}</b></span>
        <span class="stat-chip" role="listitem"><span class="label">Price</span><b>$0</b></span>
      </div>
    </div>
  </section>

  <!-- ========================= THE IDEA ========================= -->
  <section class="section" id="why">
    <div class="container">
      <p class="eyebrow">Why this exists</p>
      <h2 class="mission-h">Great gear decisions deserve more data</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:64ch;">
        One golfer's test is an anecdote. A community testing the same way is
        evidence.
      </p>

      <ol class="idea-grid">
        {
          ideas.map((it) => (
            <li class="card idea">
              <span class="idea-n tnum">{it.n}</span>
              <h3>{it.title}</h3>
              <p class="text-muted">{it.body}</p>
            </li>
          ))
        }
      </ol>

      <p class="idea-foot text-muted">
        The community analytics hub — comparisons, gapping by handicap, launch
        &amp; spin norms — is taking shape in <a href="/lab">the Lab</a>.
      </p>
    </div>
  </section>

  <!-- ==================== THE TOOL (APP) ==================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="tool card">
        <div class="tool-copy">
          <p class="eyebrow">The instrument</p>
          <h2>{PRODUCT_NAME} is the instrument</h2>
          <p class="text-muted" style="margin-top:0.85rem;max-width:52ch;">
            {PRODUCT_NAME} — our free GSPro companion — captures every shot
            automatically and turns it into 15 dashboards, so you get sharper
            practice today and (only if you opt in) help build the shared
            dataset tomorrow.
          </p>
          <div class="hero-cta">
            <a href="/golf-sim-analytics" class="btn btn-primary">Explore the app</a>
            <a href="/download" class="btn btn-secondary">Download for Windows</a>
          </div>
        </div>
        <div class="tool-shot">
          <img
            src="/images/screenshots/dispersion.jpg"
            alt="Golf Sim Analytics dispersion dashboard plotting shot landing positions by club against an ideal target ellipse."
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== OPEN & FREE CALLOUT ==================== -->
  <section class="section-tight">
    <div class="container">
      <div class="openfree">
        <div class="grid-bg" style="opacity:0.6"></div>
        <div class="openfree-inner">
          <h2>Independent and community-driven.</h2>
          <p class="lede mx-auto" style="text-align:center;margin-top:0.8rem;">
            OpenGolfLab is built in the open, by golfers for golfers — the data
            belongs to the community, not to any single brand. Fueling the Lab
            keeps it running, and every shot you choose to contribute makes the
            picture sharper for everyone.
          </p>
          <div class="hero-cta" style="justify-content:center;">
            <a href={KOFI_URL} class="btn btn-coffee" rel="noopener" target="_blank">Fuel the Lab</a>
            <a href={GITHUB_URL} class="btn btn-secondary" rel="noopener" target="_blank">Watch on GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, var(--bg-translucent) 0%, rgba(20, 19, 17, 0.86) 60%, var(--bg) 100%),
      radial-gradient(120% 90% at 50% -10%, var(--green-tint), transparent 55%);
  }
  .hero .grid-bg {
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2.25rem, 5vw, 3.75rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-openpill {
    color: var(--green);
    border-color: var(--green-dim);
    background: rgba(20, 19, 17, 0.5);
    margin-bottom: 1.2rem;
  }
  .hero-title {
    max-width: 20ch;
    background: linear-gradient(180deg, #ffffff 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    margin-top: 1.2rem;
    text-align: center;
    color: var(--text-muted);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
    justify-content: center;
  }
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .mission-h {
    max-width: 22ch;
  }

  /* ---- Idea trio ---- */
  .idea-grid {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .idea {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .idea-n {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .idea h3 {
    margin-top: 0.5rem;
    font-size: 1.2rem;
  }
  .idea-foot {
    margin-top: 1.5rem;
    font-size: 0.98rem;
  }

  /* ---- Tool (app) split ---- */
  .tool {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .tool-copy {
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
  .tool-shot {
    position: relative;
    border-left: 1px solid var(--border);
    min-height: 260px;
    background: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Show the full screenshot at its natural shape — no cropping. */
  .tool-shot img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* ---- Open & free callout ---- */
  .openfree {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.75rem);
    text-align: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .openfree-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 900px) {
    .idea-grid {
      grid-template-columns: 1fr;
    }
    .tool {
      grid-template-columns: 1fr;
    }
    .tool-shot {
      border-left: none;
      border-top: 1px solid var(--border);
      min-height: 220px;
      order: -1;
    }
  }
</style>
