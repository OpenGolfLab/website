---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PRODUCT_NAME, KOFI_URL, GITHUB_URL } from "../consts";
import { loadMarket, loadBallMarket, loadCommunity } from "../lib/lab";

// Real counts, computed at build from the lineup datasets. No slogans.
const market = loadMarket();
const balls = loadBallMarket();
const community = loadCommunity();

// The Lab's two pillars, promoted from the Lab overview to the homepage.
// Order matters: Community Data feeds the Gear Guide, so it renders first
// with an arrow between them. Same honest live/in-progress states.
const labTiles = [
  {
    href: "/lab/community",
    eyebrow: "Measured",
    label: "Community Data",
    live: community.hasCommunityData,
    liveText: community.hasCommunityData
      ? `${community.totalContributors} golfers · ${community.totalShots.toLocaleString()} shots`
      : "Collecting first dataset",
    blurb:
      "Anonymized, opt-in GSPro sessions aggregated into numbers no single golfer can produce alone. One golfer, one vote, so a big session can't skew a result.",
    covers: [
      "Launch & spin norms by club",
      "Driver dispersion",
      "Quality tiers",
    ],
  },
  {
    href: "/gear",
    eyebrow: "Where it pays off",
    label: "Gear Guide",
    live: market.hasLineups,
    liveText: market.hasLineups
      ? `${market.modelCount} drivers · ${balls.hasLineups ? `${balls.modelCount} balls · ` : ""}irons · wedges`
      : "Not published yet",
    blurb:
      "Where every driver, iron, wedge and ball sits (forgiveness to distance, soft to max spin) and what it actually costs today. Researched specs and live street prices now, sharpened by community numbers as the dataset grows.",
    covers: [
      "Driver lineup spectrum",
      "Iron & wedge maps",
      ...(balls.hasLineups ? ["Golf ball map"] : []),
      "Street price vs. MSRP",
    ],
  },
];

// The flywheel trio: individual value → comparative value → collective value,
// in that order. Replaces the old method-first trio; the method still lives
// on /lab#methodology where the detail belongs.
const ideas = [
  {
    n: "01",
    title: "Contribute your shots",
    body: "The app captures every GSPro shot automatically, and sharing is a single opt-in. No account, no name, no manual entry, your sessions just count.",
  },
  {
    n: "02",
    title: "Unlock your benchmarks",
    body: "See where you actually stack up: your carry, dispersion and strike quality against golfers at your swing speed, not a tour pro's table.",
  },
  {
    n: "03",
    title: "Every shot sharpens the answer",
    body: "Ball comparisons, gapping by handicap, launch and spin norms, free and open for every golfer, and a little sharper with every session shared.",
  },
];
---

<BaseLayout>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <picture>
        <source media="(max-width: 760px)" srcset="/images/course_bg-mobile.jpg" />
        <img
          src="/images/course_bg.jpg"
          alt=""
          width="2400"
          height="1350"
          fetchpriority="high"
        />
      </picture>
      <div class="hero-scrim"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="container hero-inner">
      <span class="pill hero-openpill">◆ GSPro-driven community analytics · free &amp; open</span>
      <h1 class="hero-title">Your sim is the lab. Your swings are the data.</h1>
      <p class="lede hero-lede">
        Pool your shots with thousands of GSPro golfers, see where you actually
        stack up, and find out what deserves a spot in your bag.
      </p>

      <div class="hero-cta">
        <a href="/download" class="btn btn-primary btn-lg">Download the free app</a>
        <a href="/lab" class="btn btn-secondary btn-lg">Preview the Lab ↗</a>
      </div>

      {/* One row, mission only: why you can join without hesitation. The
          gear-tracking counts live on the Gear Guide where they're relevant. */}
      <p class="hero-contrast" role="note">
        Free · No account · Opt-in sharing · Open method
      </p>
    </div>
  </section>

  <!-- ========================= THE IDEA ========================= -->
  <section class="section" id="why">
    <div class="container">
      <p class="eyebrow">Why this exists</p>
      <h2 class="mission-h">The clubs and ball you use matter</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:64ch;">
        OpenGolfLab exists to build the data you need to choose them well.
      </p>
      <p class="text-muted moat" style="max-width:70ch;">
        The data that could answer it doesn't exist anywhere else. Tour numbers
        describe professionals. Shot-tracker datasets are closed, and blown
        around by wind, temperature and elevation. Manufacturer claims come
        from robots and marketing departments. A sim bay is a controlled lab,
        so pooled indoor shots, tagged with club, ball and launch monitor, make
        cleaner comparisons than any of them. That's the dataset we're
        building, in the open.
      </p>

      <ol class="idea-grid">
        {
          ideas.map((it) => (
            <li class="card idea">
              <span class="idea-n tnum">{it.n}</span>
              <h3>{it.title}</h3>
              <p class="text-muted">{it.body}</p>
            </li>
          ))
        }
      </ol>

    </div>
  </section>

  <!-- ==================== THE TOOL (APP) ==================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="tool card">
        <div class="tool-copy">
          <p class="eyebrow">The instrument</p>
          <h2>{PRODUCT_NAME} is the instrument</h2>
          <p class="text-muted" style="margin-top:0.85rem;max-width:52ch;">
            {PRODUCT_NAME}, our free GSPro companion, captures every shot
            automatically and turns it into 15 dashboards, so you get sharper
            practice today and (only if you opt in) help build the shared
            dataset tomorrow.
          </p>
          <div class="hero-cta">
            <a href="/golf-sim-analytics" class="btn btn-primary">Explore the app</a>
            <a href="/download" class="btn btn-secondary">Download for Windows</a>
          </div>
        </div>
        <div class="tool-shot">
          <img
            src="/images/screenshots/dispersion.jpg"
            alt="Golf Sim Analytics dispersion dashboard plotting shot landing positions by club against an ideal target ellipse."
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== THE LAB: TWO PILLARS ==================== -->
  <section class="section" id="lab" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">The Lab</p>
      <h2>From community shots to gear answers</h2>
      <p class="lede" style="margin-top:0.9rem;max-width:66ch;">
        Community Data is the input: anonymized, opt-in GSPro sessions pooled
        into measured performance numbers. The Gear Guide is where they pay
        off: the insights that tell you what to actually buy.
      </p>

      <div class="lab-tiles">
        {
          labTiles.map((t, i) => (
            <Fragment>
              {i > 0 && (
                <div class="lab-arrow" aria-hidden="true">
                  <span class="lab-arrow-glyph">→</span>
                  <span class="lab-arrow-label">feeds&nbsp;into</span>
                </div>
              )}
              <a href={t.href} class="card lab-tile">
              <div class="lab-tile-top">
                <span class="lab-tile-eyebrow">{t.eyebrow}</span>
                <span class:list={["pill", "lab-tile-pill", t.live ? "live" : "progress"]}>
                  {t.live ? "Live now" : "In progress"}
                </span>
              </div>
              <h3>{t.label}</h3>
              <p class="lab-tile-stat tnum">{t.liveText}</p>
              <p class="lab-tile-blurb">{t.blurb}</p>
              <ul class="lab-tile-list">
                {t.covers.map((c) => (
                  <li>
                    <span class="lab-tile-mark">{t.live ? "✓" : "◐"}</span>
                    {c}
                  </li>
                ))}
              </ul>
                <span class="lab-tile-go">Open {t.label} →</span>
              </a>
            </Fragment>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== OPEN & FREE CALLOUT ==================== -->
  <section class="section-tight">
    <div class="container">
      <div class="openfree">
        <div class="grid-bg" style="opacity:0.6"></div>
        <div class="openfree-inner">
          <h2>Independent and community-driven.</h2>
          <p class="lede mx-auto" style="text-align:center;margin-top:0.8rem;">
            OpenGolfLab is built in the open, by golfers for golfers, the data
            belongs to the community, not to any single brand. Fueling the Lab
            keeps it running, and every shot you choose to contribute makes the
            picture sharper for everyone.
          </p>
          <div class="hero-cta" style="justify-content:center;">
            <a href={KOFI_URL} class="btn btn-coffee" rel="noopener" target="_blank">Fuel the Lab</a>
            <a href={GITHUB_URL} class="btn btn-secondary" rel="noopener" target="_blank">Watch on GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, var(--bg-translucent) 0%, rgba(20, 19, 17, 0.86) 60%, var(--bg) 100%),
      radial-gradient(120% 90% at 50% -10%, var(--green-tint), transparent 55%);
  }
  .hero .grid-bg {
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2.25rem, 5vw, 3.75rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-openpill {
    color: var(--green);
    border-color: var(--green-dim);
    background: rgba(20, 19, 17, 0.5);
    margin-bottom: 1.2rem;
  }
  .hero-title {
    max-width: 20ch;
    background: linear-gradient(180deg, #ffffff 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    margin-top: 1.2rem;
    text-align: center;
    color: var(--text-muted);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
    justify-content: center;
  }
  .hero-contrast {
    margin-top: 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    text-align: center;
  }
  .mission-h {
    max-width: 22ch;
  }
  .moat {
    margin-top: 1rem;
    font-size: 0.97rem;
  }

  /* ---- Idea trio ---- */
  .idea-grid {
    margin-top: 2.5rem;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .idea {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .idea-n {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--green);
    letter-spacing: 0.1em;
  }
  .idea h3 {
    margin-top: 0.5rem;
    font-size: 1.2rem;
  }
  /* ---- Lab tiles (promoted from the Lab overview) ---- */
  .lab-tiles {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.1rem;
    align-items: stretch;
  }
  .lab-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding-inline: 0.15rem;
  }
  .lab-arrow-glyph {
    font-size: 1.7rem;
    line-height: 1;
    color: var(--green);
  }
  .lab-arrow-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .lab-tile {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: inherit;
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .lab-tile:hover {
    border-color: var(--green-dim);
    transform: translateY(-2px);
  }
  .lab-tile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .lab-tile-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .lab-tile-pill.live {
    color: var(--green);
    border-color: var(--green-dim);
  }
  .lab-tile-pill.progress {
    color: var(--text-muted);
  }
  .lab-tile h3 {
    margin-top: 0.3rem;
    color: var(--text);
  }
  .lab-tile-stat {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--green);
  }
  .lab-tile-blurb {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .lab-tile-list {
    list-style: none;
    padding: 0;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .lab-tile-list li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .lab-tile-mark {
    color: var(--green);
  }
  .lab-tile-go {
    margin-top: auto;
    padding-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--green);
  }
  .lab-tile:hover .lab-tile-go {
    color: var(--green-bright);
  }

  /* ---- Tool (app) split ---- */
  .tool {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .tool-copy {
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
  .tool-shot {
    position: relative;
    border-left: 1px solid var(--border);
    min-height: 260px;
    background: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Show the full screenshot at its natural shape, no cropping. */
  .tool-shot img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* ---- Open & free callout ---- */
  .openfree {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.75rem);
    text-align: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .openfree-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 900px) {
    .idea-grid,
    .lab-tiles {
      grid-template-columns: 1fr;
    }
    .lab-arrow {
      flex-direction: row;
      padding-block: 0.1rem;
    }
    .lab-arrow-glyph {
      transform: rotate(90deg);
    }
    .tool {
      grid-template-columns: 1fr;
    }
    .tool-shot {
      border-left: none;
      border-top: 1px solid var(--border);
      min-height: 220px;
      order: -1;
    }
  }
</style>
