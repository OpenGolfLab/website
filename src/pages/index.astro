---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PRODUCT_NAME, KOFI_URL, GITHUB_URL } from "../consts";
import { loadMarket, loadBallMarket, loadCommunity } from "../lib/lab";

// Real counts, computed at build from the lineup datasets. No slogans.
const market = loadMarket();
const balls = loadBallMarket();
const community = loadCommunity();

// The three big-ticket items, front and center right after the hero: the
// app, the community dataset it can feed, and the gear guide that dataset
// will sharpen. Each tile is the short pitch; a brief unpack section below
// teases each one, and the full story lives on its own page.
const pillars = [
  {
    href: "/golf-sim-analytics",
    eyebrow: "The app",
    label: PRODUCT_NAME,
    live: true,
    liveText: "Free · Windows · 15 dashboards",
    blurb:
      "Plugs straight into GSPro and logs every shot on its own. No CSV exports, no pushing files to a phone app. Carry trends, club gapping, dispersion and shot quality build themselves while you play.",
    covers: [
      "Automatic shot capture",
      "Carry trends & club gapping",
      "Dispersion & shot quality",
    ],
  },
  {
    href: "/lab",
    eyebrow: "The community dataset",
    label: "Community Data",
    live: community.hasCommunityData,
    liveText: community.hasCommunityData
      ? `${community.totalContributors} golfers · ${community.totalShots.toLocaleString()} shots`
      : "Collecting first dataset",
    blurb:
      "If you want, share your shots (anonymized, one opt-in) and help answer what nobody else can: how far clubs actually go, how launch monitors really compare, which balls hold up for big hitters.",
    covers: [
      "How far clubs actually carry",
      "Launch monitors, compared",
      "Ball vs. ball, measured",
    ],
  },
  {
    href: "/gear",
    eyebrow: "Data-driven gear guide",
    label: "Gear Guide",
    live: market.hasLineups,
    liveText: market.hasLineups
      ? `${market.modelCount} drivers · ${balls.hasLineups ? `${balls.modelCount} balls · ` : ""}irons · wedges`
      : "Not published yet",
    blurb:
      "Every major driver, iron, wedge and ball mapped by what it's built to do, at today's prices. As community data comes online, the guide gets graded against real shots from real golfers.",
    covers: [
      "Full lineups mapped",
      "Today's price vs. MSRP",
      "Community numbers, next",
    ],
  },
];

// The community unpack's teaser questions — the short version of the
// "Answer what nobody else can" payoffs on /lab#roadmap, where each one
// is spelled out in full.
const questions = [
  "What does a premium ball actually buy you?",
  "What do real gaps look like at your handicap?",
  "How do launch monitors truly compare?",
  "What does a 2020 driver give up to a 2026?",
];
---

<BaseLayout>
  <!-- ============================ HERO ============================ -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true">
      <picture>
        <source media="(max-width: 760px)" srcset="/images/course_bg-mobile.jpg" />
        <img
          src="/images/course_bg.jpg"
          alt=""
          width="2400"
          height="1350"
          fetchpriority="high"
        />
      </picture>
      <div class="hero-scrim"></div>
    </div>
    <div class="grid-bg"></div>

    <div class="container hero-inner">
      <span class="pill hero-openpill">◆ GSPro-driven community analytics · free &amp; open</span>
      <h1 class="hero-title">Your sim is the lab. Your swings are the data.</h1>
      <p class="lede hero-lede">
        Pool your shots with thousands of GSPro golfers, see where you actually
        stack up, and find out what deserves a spot in your bag.
      </p>

      <div class="hero-cta">
        <a href="/download" class="btn btn-primary btn-lg">Download the free app</a>
        <a href="/lab" class="btn btn-secondary btn-lg">Preview the Lab ↗</a>
      </div>

      {/* One row, mission only: why you can join without hesitation. The
          gear-tracking counts live on the Gear Guide where they're relevant. */}
      <p class="hero-contrast" role="note">
        Free · No account · Opt-in sharing · Open method
      </p>
    </div>
  </section>

  <!-- ==================== THE BIG THREE ==================== -->
  <section class="section" id="pillars">
    <div class="container">
      <div class="lab-tiles">
        {
          pillars.map((t) => (
            <a href={t.href} class="card lab-tile">
              <div class="lab-tile-top">
                <span class="lab-tile-eyebrow">{t.eyebrow}</span>
                <span class:list={["pill", "lab-tile-pill", t.live ? "live" : "progress"]}>
                  {t.live ? "Live now" : "In progress"}
                </span>
              </div>
              <h3>{t.label}</h3>
              <p class="lab-tile-stat tnum">{t.liveText}</p>
              <p class="lab-tile-blurb">{t.blurb}</p>
              <ul class="lab-tile-list">
                {t.covers.map((c) => (
                  <li>
                    <span class="lab-tile-mark">{t.live ? "✓" : "◐"}</span>
                    {c}
                  </li>
                ))}
              </ul>
              <span class="lab-tile-go">Open {t.label} →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ==================== UNPACK 1: THE APP ==================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <div class="tool card">
        <div class="tool-copy">
          <p class="eyebrow">01 · The app</p>
          <h2>Every shot, analyzed automatically</h2>
          <p class="text-muted" style="margin-top:0.85rem;max-width:52ch;">
            {PRODUCT_NAME} sits alongside GSPro and captures every swing as
            you hit it, range sessions and full rounds alike. Fifteen
            dashboards turn them into carry trends, gapping, dispersion and
            strike quality, with no spreadsheets and nothing to export. It's
            fully useful on its own, before you ever share a shot.
          </p>
          <div class="hero-cta">
            <a href="/golf-sim-analytics" class="btn btn-primary">Explore the app</a>
            <a href="/download" class="btn btn-secondary">Download for Windows</a>
          </div>
        </div>
        <div class="tool-shot">
          <img
            src="/images/screenshots/dispersion.jpg"
            alt="Golf Sim Analytics dispersion dashboard plotting shot landing positions by club against an ideal target ellipse."
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== UNPACK 2: COMMUNITY DATA ==================== -->
  <section class="section" id="lab" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">02 · The community dataset</p>
      <h2>Answer what nobody else can</h2>
      <p class="text-muted moat" style="max-width:70ch;">
        Tour numbers describe professionals. Shot-tracker datasets are closed,
        and blown around by wind and temperature. Robot testing isn't golfers.
        A sim bay is a controlled lab, so pooled indoor shots, tagged with
        club, ball and launch monitor, can settle questions nothing else can:
      </p>
      <ul class="q-list">
        {questions.map((q) => <li class="card q-item">{q}</li>)}
      </ul>
      <p class="text-muted" style="margin-top:1.1rem;max-width:70ch;">
        Sharing is entirely your choice, anonymized on your machine before
        anything is sent, and every golfer counts once no matter how much they
        play. The full method is public.
      </p>
      <div class="hero-cta">
        <a href="/lab" class="btn btn-secondary">See how the Lab works →</a>
      </div>
    </div>
  </section>

  <!-- ==================== UNPACK 3: GEAR GUIDE ==================== -->
  <section class="section" style="padding-top:0;">
    <div class="container">
      <p class="eyebrow">03 · Data-driven gear guide</p>
      <h2>A gear guide graded by measurements, not marketing</h2>
      <p class="text-muted moat" style="max-width:70ch;">
        Today the Gear Guide maps every major driver, iron, wedge and ball by
        what it's built to do, at today's prices, useful the day you need it.
        The long game is better: as community data starts to come online, it
        gets woven into the guide, checking claims against how gear actually
        performs for everyday golfers. When the numbers show a bargain ball
        hanging with a premium one at your swing speed, the guide will say
        so.
      </p>
      <div class="hero-cta">
        <a href="/gear" class="btn btn-secondary">Browse the Gear Guide →</a>
      </div>
    </div>
  </section>

  <!-- ==================== OPEN & FREE CALLOUT ==================== -->
  <section class="section-tight">
    <div class="container">
      <div class="openfree">
        <div class="grid-bg" style="opacity:0.6"></div>
        <div class="openfree-inner">
          <h2>Independent and community-driven.</h2>
          <p class="lede mx-auto" style="text-align:center;margin-top:0.8rem;">
            OpenGolfLab is built in the open, by golfers for golfers, the data
            belongs to the community, not to any single brand. Fueling the Lab
            keeps it running, and every shot you choose to contribute makes the
            picture sharper for everyone.
          </p>
          <div class="hero-cta" style="justify-content:center;">
            <a href={KOFI_URL} class="btn btn-coffee" rel="noopener" target="_blank">Fuel the Lab</a>
            <a href={GITHUB_URL} class="btn btn-secondary" rel="noopener" target="_blank">Watch on GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .hero-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, var(--bg-translucent) 0%, rgba(20, 19, 17, 0.86) 60%, var(--bg) 100%),
      radial-gradient(120% 90% at 50% -10%, var(--green-tint), transparent 55%);
  }
  .hero .grid-bg {
    z-index: -1;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(3rem, 8vw, 6rem) clamp(2.25rem, 5vw, 3.75rem);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-openpill {
    color: var(--green);
    border-color: var(--green-dim);
    background: rgba(20, 19, 17, 0.5);
    margin-bottom: 1.2rem;
  }
  .hero-title {
    max-width: 20ch;
    background: linear-gradient(180deg, #ffffff 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    margin-top: 1.2rem;
    text-align: center;
    color: var(--text-muted);
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
    justify-content: center;
  }
  .hero-contrast {
    margin-top: 1.15rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    text-align: center;
  }
  .moat {
    margin-top: 1rem;
    font-size: 0.97rem;
  }

  /* ---- The big three tiles ---- */
  .lab-tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
    align-items: stretch;
  }

  /* ---- Community unpack: teaser questions ---- */
  .q-list {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
  }
  .q-item {
    font-size: 0.97rem;
    color: var(--text);
    padding: 0.95rem 1.1rem;
  }
  .lab-tile {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    color: inherit;
    transition: border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .lab-tile:hover {
    border-color: var(--green-dim);
    transform: translateY(-2px);
  }
  .lab-tile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .lab-tile-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .lab-tile-pill.live {
    color: var(--green);
    border-color: var(--green-dim);
  }
  .lab-tile-pill.progress {
    color: var(--text-muted);
  }
  .lab-tile h3 {
    margin-top: 0.3rem;
    color: var(--text);
  }
  .lab-tile-stat {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--green);
  }
  .lab-tile-blurb {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .lab-tile-list {
    list-style: none;
    padding: 0;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .lab-tile-list li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .lab-tile-mark {
    color: var(--green);
  }
  .lab-tile-go {
    margin-top: auto;
    padding-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--green);
  }
  .lab-tile:hover .lab-tile-go {
    color: var(--green-bright);
  }

  /* ---- Tool (app) split ---- */
  .tool {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .tool-copy {
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }
  .tool-shot {
    position: relative;
    border-left: 1px solid var(--border);
    min-height: 260px;
    background: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Show the full screenshot at its natural shape, no cropping. */
  .tool-shot img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  /* ---- Open & free callout ---- */
  .openfree {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.75rem);
    text-align: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-elevated) 100%);
  }
  .openfree-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media (max-width: 900px) {
    .lab-tiles,
    .q-list {
      grid-template-columns: 1fr;
    }
    .tool {
      grid-template-columns: 1fr;
    }
    .tool-shot {
      border-left: none;
      border-top: 1px solid var(--border);
      min-height: 220px;
      order: -1;
    }
  }
</style>
